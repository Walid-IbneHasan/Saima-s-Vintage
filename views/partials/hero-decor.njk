{#
  Background hero motifs — Lippan-art mandalas/mirror tiles + Jharoka arches,
  spread across the hero (left/centre + far-right margin). Pure inline SVG + CSS
  animation (no JS, CSP-safe); compositor-only transform/opacity, gated on
  prefers-reduced-motion, so it stays smooth on low-end devices. This layer
  sits behind the content (-z-10); motifs that fall over the product image are
  added separately in hero-decor-image.njk. Decorative: aria-hidden, clipped.
#}
<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
  {# Lippan mirror mandala — top-left #}
  <span class="hero-motif absolute left-[4%] top-[14%] text-primary opacity-20"
        style="--dur:13s; --dx:16px; --dy:-22px; --delay:-3s">
    <svg class="hero-spin h-24 w-24 md:h-32 md:w-32" style="--spin:42s" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.4">
      <circle cx="50" cy="50" r="47" />
      <circle cx="50" cy="50" r="34" stroke-dasharray="2 6" />
      <circle cx="50" cy="50" r="20" />
      <circle cx="50" cy="50" r="6" fill="currentColor" stroke="none" />
    </svg>
  </span>

  {# Jharoka arched window — lower-left #}
  <span class="hero-motif absolute bottom-[12%] left-[8%] hidden text-secondary opacity-25 sm:block"
        style="--dur:15s; --dx:-14px; --dy:-18px; --delay:-5s">
    <svg class="h-24 w-16 md:h-32 md:w-20" viewBox="0 0 60 92" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M6 90 V40 a24 24 0 0 1 48 0 V90" />
      <path d="M30 18 V90" />
      <path d="M6 58 H54" />
      <circle cx="30" cy="40" r="5" />
    </svg>
  </span>

  {# Mirror-tile diamond cluster — top-center #}
  <span class="hero-motif absolute left-[30%] top-[5%] text-primary opacity-20"
        style="--dur:12s; --dx:-18px; --dy:20px; --delay:-6s">
    <svg class="hero-spin h-20 w-20 md:h-28 md:w-28" style="--spin:54s" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="32" y="6" width="16" height="16" transform="rotate(45 40 14)" />
      <rect x="14" y="34" width="14" height="14" transform="rotate(45 21 41)" />
      <rect x="52" y="34" width="14" height="14" transform="rotate(45 59 41)" />
      <rect x="33" y="52" width="16" height="16" transform="rotate(45 41 60)" />
    </svg>
  </span>

  {# Dotted sun ring — far-right margin (beside the image) #}
  <span class="hero-motif absolute right-[2%] top-[28%] hidden text-secondary opacity-25 md:block"
        style="--dur:10s; --dx:-12px; --dy:-14px; --delay:-2s">
    <svg class="hero-spin h-16 w-16" style="--spin:34s" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="30" cy="30" r="22" stroke-dasharray="1.5 5" />
      <circle cx="30" cy="30" r="11" />
    </svg>
  </span>

  {# Small mandala — mid-left edge #}
  <span class="hero-motif absolute left-[2%] top-[50%] text-primary opacity-20"
        style="--dur:14s; --dx:-12px; --dy:-16px; --delay:-10s">
    <svg class="hero-spin h-16 w-16 md:h-20 md:w-20" style="--spin:46s" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.4">
      <circle cx="30" cy="30" r="27" stroke-dasharray="2 6" />
      <circle cx="30" cy="30" r="15" />
      <circle cx="30" cy="30" r="4" fill="currentColor" stroke="none" />
    </svg>
  </span>
</div>
