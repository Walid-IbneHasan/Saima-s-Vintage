{#
  Decorative hero motifs — Lippan-art mandalas/mirror tiles + Jharoka arches.
  Pure inline SVG + CSS animation (no JS, CSP-safe). Animations are
  compositor-only (transform/opacity) and gated on prefers-reduced-motion, so
  they stay smooth on low-end devices and go static for reduced-motion users.
  Decorative only: aria-hidden + pointer-events-none, clipped by the hero.
#}
<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
  {# Lippan mirror mandala — top-left, slow spin #}
  <span class="hero-motif absolute left-[4%] top-[14%] text-primary opacity-20"
        style="--dur:27s; --dx:16px; --dy:-22px; --delay:-3s">
    <svg class="hero-spin h-24 w-24 md:h-32 md:w-32" style="--spin:90s" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.4">
      <circle cx="50" cy="50" r="47" />
      <circle cx="50" cy="50" r="34" stroke-dasharray="2 6" />
      <circle cx="50" cy="50" r="20" />
      <circle cx="50" cy="50" r="6" fill="currentColor" stroke="none" />
    </svg>
  </span>

  {# Jharoka arched window — lower-left #}
  <span class="hero-motif absolute bottom-[12%] left-[8%] hidden text-secondary opacity-25 sm:block"
        style="--dur:32s; --dx:-14px; --dy:-18px; --delay:-9s">
    <svg class="h-24 w-16 md:h-32 md:w-20" viewBox="0 0 60 92" fill="none" stroke="currentColor" stroke-width="1.6">
      <path d="M6 90 V40 a24 24 0 0 1 48 0 V90" />
      <path d="M30 18 V90" />
      <path d="M6 58 H54" />
      <circle cx="30" cy="40" r="5" />
    </svg>
  </span>

  {# Mirror-tile diamond cluster — top-center #}
  <span class="hero-motif absolute left-[30%] top-[5%] text-primary opacity-20"
        style="--dur:24s; --dx:-18px; --dy:20px; --delay:-6s">
    <svg class="hero-spin h-20 w-20 md:h-28 md:w-28" style="--spin:120s" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="32" y="6" width="16" height="16" transform="rotate(45 40 14)" />
      <rect x="14" y="34" width="14" height="14" transform="rotate(45 21 41)" />
      <rect x="52" y="34" width="14" height="14" transform="rotate(45 59 41)" />
      <rect x="33" y="52" width="16" height="16" transform="rotate(45 41 60)" />
    </svg>
  </span>

  {# Dotted sun ring — lower-center #}
  <span class="hero-motif absolute bottom-[18%] left-[24%] hidden text-secondary opacity-25 md:block"
        style="--dur:21s; --dx:12px; --dy:-14px; --delay:-2s">
    <svg class="hero-spin h-16 w-16" style="--spin:70s" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="30" cy="30" r="22" stroke-dasharray="1.5 5" />
      <circle cx="30" cy="30" r="11" />
    </svg>
  </span>

  {# Small mandala — mid-left edge #}
  <span class="hero-motif absolute left-[2%] top-[50%] text-primary opacity-20"
        style="--dur:29s; --dx:-12px; --dy:-16px; --delay:-12s">
    <svg class="hero-spin h-16 w-16 md:h-20 md:w-20" style="--spin:110s" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.4">
      <circle cx="30" cy="30" r="27" stroke-dasharray="2 6" />
      <circle cx="30" cy="30" r="15" />
      <circle cx="30" cy="30" r="4" fill="currentColor" stroke="none" />
    </svg>
  </span>
</div>
