<form method="get" action="{{ formAction }}"
      class="mb-6 flex flex-wrap items-end gap-4 rounded-lg border border-stone-200 bg-white p-4 text-sm">
  <label class="block">
    <span class="text-xs text-stone-500">Sort</span>
    <select name="sort" class="mt-1 block rounded border-stone-300 text-sm">
      <option value="newest" {% if filters.sort == 'newest' %}selected{% endif %}>Newest</option>
      <option value="price_asc" {% if filters.sort == 'price_asc' %}selected{% endif %}>Price: low to high</option>
      <option value="price_desc" {% if filters.sort == 'price_desc' %}selected{% endif %}>Price: high to low</option>
      <option value="name" {% if filters.sort == 'name' %}selected{% endif %}>Name: A–Z</option>
    </select>
  </label>

  {# Price range. Dual-handle slider (JS) with number-input fallback (no-JS). #}
  <div class="block"
       x-data="{
         floor: {{ bounds.min | default(0) }},
         ceil: {{ bounds.max | default(0) }},
         from: {{ filters.priceMin | default(bounds.min | default(0)) }},
         to: {{ filters.priceMax | default(bounds.max | default(0)) }},
         get span() { return Math.max(this.ceil - this.floor, 1); },
         get lo() { return Math.min(this.from, this.to); },
         get hi() { return Math.max(this.from, this.to); },
         get pctLo() { return (this.lo - this.floor) / this.span * 100; },
         get pctHi() { return (this.hi - this.floor) / this.span * 100; },
         normalize() { if (this.from > this.to) { const t = this.from; this.from = this.to; this.to = t; } }
       }">
    <div class="flex items-center justify-between gap-6">
      <span class="text-xs text-stone-500">Price</span>
      <span class="price-slider text-xs font-medium text-stone-700" x-cloak>
        ৳<span x-text="lo"></span> – ৳<span x-text="hi"></span>
      </span>
    </div>

    {# Slider (shown only when JS is present) #}
    <div class="price-slider relative mt-2 h-5 w-56" x-cloak>
      <div class="absolute top-1/2 h-1 w-full -translate-y-1/2 rounded bg-stone-200"></div>
      <div class="absolute top-1/2 h-1 -translate-y-1/2 rounded bg-amber-600"
           :style="`left:${pctLo}%; right:${100 - pctHi}%`"></div>
      <input type="range" class="price-range" :min="floor" :max="ceil" step="1"
             x-model.number="from" @change="normalize()" aria-label="Minimum price" />
      <input type="range" class="price-range" :min="floor" :max="ceil" step="1"
             x-model.number="to" @change="normalize()" aria-label="Maximum price" />
    </div>

    {# No-JS fallback: number inputs. These are the submitted source; the slider
       drives the same values via x-model. Hidden (but still submitted) when JS. #}
    <div class="price-fallback mt-1 flex items-end gap-2">
      <label class="block">
        <span class="text-xs text-stone-500">Min ৳</span>
        <input type="number" name="priceMin" min="0" step="1" x-model.number="from"
               value="{{ filters.priceMin | default('') }}" placeholder="{{ bounds.min | default(0) }}"
               class="mt-1 block w-24 rounded border-stone-300 text-sm" />
      </label>
      <label class="block">
        <span class="text-xs text-stone-500">Max ৳</span>
        <input type="number" name="priceMax" min="0" step="1" x-model.number="to"
               value="{{ filters.priceMax | default('') }}" placeholder="{{ bounds.max | default(0) }}"
               class="mt-1 block w-24 rounded border-stone-300 text-sm" />
      </label>
    </div>
  </div>

  <label class="flex items-center gap-1.5">
    <input type="checkbox" name="inStock" value="1" {% if filters.inStock %}checked{% endif %} /> In stock
  </label>
  <label class="flex items-center gap-1.5">
    <input type="checkbox" name="onSale" value="1" {% if filters.onSale %}checked{% endif %} /> On sale
  </label>
  <button type="submit" class="rounded bg-stone-900 px-4 py-2 text-white hover:bg-stone-700">Apply</button>
  <a href="{{ formAction }}" class="px-2 py-2 text-stone-500 hover:text-amber-700">Clear</a>
</form>
