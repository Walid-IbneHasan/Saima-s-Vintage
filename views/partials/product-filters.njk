<form method="get" action="{{ formAction }}"
      class="overflow-hidden rounded-2xl border border-outline/30 bg-surface-container-lowest shadow-luxe">
  <div class="border-b border-outline/30 px-6 py-5">
    <h2 class="font-headline-md text-xl text-on-surface">Refine</h2>
    <p class="mt-1 text-sm text-on-surface-variant">Find your perfect piece</p>
  </div>

  {# Category quick-nav — links navigate directly to category pages. The one for
     the page you're on is highlighted; a sub-category highlights its top-level
     parent (since only top-level categories appear in this list). #}
  {% set activeSlug = category.slug if category else null %}
  {% set activeParent = category.parent.slug if (category and category.parent) else null %}
  <nav class="flex flex-col gap-1 px-4 py-5">
    <a href="/products" aria-current="{{ 'page' if not activeSlug else 'false' }}"
       class="rounded-full px-4 py-2.5 font-label-md text-label-md uppercase tracking-[0.14em] {{ 'bg-primary text-on-primary shadow-luxe' if not activeSlug else 'text-on-surface-variant transition-colors hover:bg-surface-container-high hover:text-accent-deep' }}">All items</a>
    {% for cat in navCategories() %}
      <a href="/c/{{ cat.slug }}" aria-current="{{ 'page' if (cat.slug == activeSlug) else 'false' }}"
         class="rounded-full px-4 py-2.5 font-label-md text-label-md uppercase tracking-[0.14em] {{ 'bg-primary text-on-primary shadow-luxe' if (cat.slug == activeSlug or cat.slug == activeParent) else 'text-on-surface-variant transition-colors hover:bg-surface-container-high hover:text-accent-deep' }}">{{ cat.name }}</a>
    {% endfor %}
  </nav>

  <div class="space-y-6 border-t border-outline/30 px-6 py-6">
    <label class="block">
      <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Sort by</span>
      <select name="sort" class="mt-2 block w-full rounded-lg border border-outline bg-surface-container-lowest px-3.5 py-2.5 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0">
        <option value="newest" {% if filters.sort == 'newest' %}selected{% endif %}>Newest</option>
        <option value="price_asc" {% if filters.sort == 'price_asc' %}selected{% endif %}>Price: low to high</option>
        <option value="price_desc" {% if filters.sort == 'price_desc' %}selected{% endif %}>Price: high to low</option>
        <option value="name" {% if filters.sort == 'name' %}selected{% endif %}>Name: A–Z</option>
      </select>
    </label>

    {# Price range. Dual-handle slider (JS) with number-input fallback (no-JS). #}
    <div x-data="{
           floor: {{ bounds.min | default(0) }},
           ceil: {{ bounds.max | default(0) }},
           from: {{ filters.priceMin | default(bounds.min | default(0)) }},
           to: {{ filters.priceMax | default(bounds.max | default(0)) }},
           get span() { return Math.max(this.ceil - this.floor, 1); },
           get lo() { return Math.min(this.from, this.to); },
           get hi() { return Math.max(this.from, this.to); },
           get pctLo() { return (this.lo - this.floor) / this.span * 100; },
           get pctHi() { return (this.hi - this.floor) / this.span * 100; },
           normalize() { if (this.from > this.to) { const t = this.from; this.from = this.to; this.to = t; } }
         }">
      <div class="flex items-center justify-between">
        <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Price</span>
        <span class="price-slider font-label-md text-label-md text-accent-deep" x-cloak>
          ৳<span x-text="lo"></span> – ৳<span x-text="hi"></span>
        </span>
      </div>

      {# Slider (shown only when JS is present) #}
      <div class="price-slider relative mt-4 h-5 w-full" x-cloak>
        <div class="absolute top-1/2 h-1 w-full -translate-y-1/2 rounded-full bg-outline-variant"></div>
        <div class="absolute top-1/2 h-1 -translate-y-1/2 rounded-full bg-accent"
             :style="`left:${pctLo}%; right:${100 - pctHi}%`"></div>
        <input type="range" class="price-range" :min="floor" :max="ceil" step="1"
               x-model.number="from" @change="normalize()" aria-label="Minimum price" />
        <input type="range" class="price-range" :min="floor" :max="ceil" step="1"
               x-model.number="to" @change="normalize()" aria-label="Maximum price" />
      </div>

      {# No-JS fallback: number inputs. These are the submitted source; the slider
         drives the same values via x-model. Hidden (but still submitted) when JS. #}
      <div class="price-fallback mt-3 flex items-end gap-3">
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Min ৳</span>
          <input type="number" name="priceMin" min="0" step="1" x-model.number="from"
                 value="{{ filters.priceMin | default('') }}" placeholder="{{ bounds.min | default(0) }}"
                 class="mt-1.5 block w-full rounded-lg border border-outline bg-surface-container-lowest px-3 py-2 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
        </label>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Max ৳</span>
          <input type="number" name="priceMax" min="0" step="1" x-model.number="to"
                 value="{{ filters.priceMax | default('') }}" placeholder="{{ bounds.max | default(0) }}"
                 class="mt-1.5 block w-full rounded-lg border border-outline bg-surface-container-lowest px-3 py-2 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
        </label>
      </div>
    </div>

    <div class="space-y-3 border-t border-outline/30 pt-5">
      <label class="flex cursor-pointer items-center gap-3 text-on-surface">
        <input type="checkbox" name="inStock" value="1" {% if filters.inStock %}checked{% endif %} class="h-4 w-4 rounded border-outline text-primary focus:ring-accent-deep/40" />
        <span class="text-sm">In stock</span>
      </label>
      <label class="flex cursor-pointer items-center gap-3 text-on-surface">
        <input type="checkbox" name="onSale" value="1" {% if filters.onSale %}checked{% endif %} class="h-4 w-4 rounded border-outline text-primary focus:ring-accent-deep/40" />
        <span class="text-sm">On sale</span>
      </label>
    </div>

    {# Filters auto-apply on change when JS is on; this Apply button is a no-JS
       fallback only (hidden via `.js .filter-apply`). #}
    <div class="space-y-3 pt-1">
      <button type="submit" class="filter-apply w-full items-center justify-center rounded-full bg-primary px-5 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">Apply filters</button>
      <a href="{{ formAction }}" @click="if (typeof sessionStorage !== 'undefined') sessionStorage.removeItem('svFiltersOpen')"
         class="flex w-full items-center justify-center gap-2 rounded-full border border-outline/50 px-5 py-3 font-label-md text-label-md uppercase tracking-[0.14em] text-on-surface-variant transition-colors duration-300 hover:border-accent hover:text-accent-deep">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 3v5h5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Clear all
      </a>
    </div>
  </div>
</form>
