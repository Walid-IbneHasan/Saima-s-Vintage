{% if meta.totalPages > 1 %}
<nav class="mt-12 flex items-center justify-center gap-4 text-sm" aria-label="Pagination">
  {% if meta.hasPrev %}
    <a class="rounded border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface transition-colors hover:border-primary hover:text-primary" href="{{ basePath }}page={{ meta.page - 1 }}">Previous</a>
  {% endif %}
  <span class="font-label-md text-label-md uppercase tracking-widest text-on-surface-variant">Page {{ meta.page }} of {{ meta.totalPages }}</span>
  {% if meta.hasNext %}
    <a class="rounded border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface transition-colors hover:border-primary hover:text-primary" href="{{ basePath }}page={{ meta.page + 1 }}">Next</a>
  {% endif %}
</nav>
{% endif %}
