{% macro statusBadge(status) -%}
{%- set cls = 'bg-surface-container-high text-on-surface-variant' -%}
{%- if status in ['PAID', 'PROCESSING', 'SHIPPED', 'DELIVERED'] -%}{%- set cls = 'bg-secondary-container text-on-secondary-container' -%}
{%- elif status in ['AWAITING_PAYMENT', 'PAYMENT_REVIEW'] -%}{%- set cls = 'bg-tertiary-fixed text-on-tertiary-fixed-variant' -%}
{%- elif status in ['FAILED', 'CANCELLED', 'EXPIRED'] -%}{%- set cls = 'bg-error-container text-on-error-container' -%}{%- endif -%}
<span class="rounded-full px-3 py-1 font-label-md text-label-md uppercase tracking-wider {{ cls }}">{{ status }}</span>
{%- endmacro %}
