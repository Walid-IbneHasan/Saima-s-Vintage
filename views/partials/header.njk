{# ── Announcement marquee (scrolls away; nav below stays sticky) ─────────── #}
<div class="marquee bg-tertiary text-on-tertiary-container">
  <div class="marquee-track gap-0 py-2.5" style="--marquee-dur: 42s" aria-hidden="true">
    {% for _ in range(0, 2) %}
      <div class="flex shrink-0 items-center">
        {% set bites = ['Handcrafted Lippan mirror art & Mughal Jharoka decor', 'Complimentary gift wrapping on every order', 'One-of-a-kind heritage pieces', 'Shipped with care across Bangladesh'] %}
        {% for b in bites %}
          <span class="px-6 font-label-sm text-[11px] uppercase tracking-[0.22em] text-on-tertiary-container/90">{{ b }}</span>
          <svg class="h-1.5 w-1.5 text-accent-bright" viewBox="0 0 8 8" fill="currentColor" aria-hidden="true"><path d="M4 0l1.4 2.6L8 4 5.4 5.4 4 8 2.6 5.4 0 4l2.6-1.4z"/></svg>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<header x-data="{ open: false, scrolled: false }"
        @scroll.window="scrolled = window.scrollY > 12"
        :class="scrolled ? 'border-outline/25 bg-background/90 shadow-[0_8px_30px_-18px_rgba(36,28,20,0.35)]' : 'border-transparent bg-background/70'"
        class="sticky top-0 z-50 border-b backdrop-blur-xl transition-[background-color,border-color,box-shadow] duration-500 ease-lux">
  <div :class="scrolled ? 'h-16 md:h-[4.5rem]' : 'h-20 md:h-24'"
       class="mx-auto flex max-w-container-max items-center justify-between gap-4 px-margin-mobile transition-[height] duration-500 ease-lux md:px-margin-desktop">
    <div class="flex items-center gap-9">
      {# Wordmark with a small gold mirror-plate mark. #}
      <a href="/" class="group flex items-center gap-2.5" aria-label="{{ appName }} — home">
        <span class="grid h-8 w-8 shrink-0 place-items-center text-accent transition-transform duration-700 ease-lux group-hover:rotate-90" aria-hidden="true">
          <svg class="h-full w-full" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4">
            <circle cx="20" cy="20" r="18" stroke-dasharray="1 4" />
            <circle cx="20" cy="20" r="12.5" />
            <circle cx="20" cy="20" r="4.5" fill="currentColor" stroke="none" />
            <path d="M20 2v6M20 32v6M2 20h6M32 20h6" stroke-linecap="round" />
          </svg>
        </span>
        <span class="flex flex-col leading-none">
          <span class="font-display-lg text-xl text-primary md:text-2xl">{{ appName }}</span>
          <span class="mt-1 hidden font-label-sm text-[9px] uppercase tracking-[0.42em] text-on-surface-variant sm:block">Heritage Atelier</span>
        </span>
      </a>

      <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
        <div class="relative" x-data="{ shop: false }" @mouseenter="shop = true" @mouseleave="shop = false">
          <a href="/products" class="link-underline inline-flex items-center gap-1.5 font-label-md text-label-md uppercase tracking-[0.18em] text-on-surface transition-colors hover:text-accent-deep" @click="shop = !shop">
            Shop
            <svg class="h-3 w-3 transition-transform duration-300" :class="shop && 'rotate-180'" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          {# pt-3 keeps the hover area continuous so the menu doesn't close in the gap. #}
          <div x-show="shop" x-cloak x-transition.opacity.duration.200ms class="absolute left-1/2 top-full z-30 -translate-x-1/2 pt-4">
            <div class="w-[40rem] overflow-hidden rounded-xl border border-outline/30 bg-surface-container-lowest p-7 shadow-luxe-lg">
              <p class="mb-5 font-label-sm text-label-sm uppercase tracking-[0.3em] text-accent-deep">Browse the collection</p>
              <div class="grid grid-cols-3 gap-x-8 gap-y-5">
                {% for cat in navCategories() %}
                  <div>
                    <a href="/c/{{ cat.slug }}" class="link-underline inline-block font-headline-sm text-base text-on-surface transition-colors hover:text-accent-deep">{{ cat.name }}</a>
                    {% if cat.children.length %}
                      <div class="mt-2 space-y-1.5">
                        {% for sub in cat.children %}
                          <a href="/c/{{ sub.slug }}" class="block text-sm text-on-surface-variant transition-colors hover:text-accent-deep">{{ sub.name }}</a>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
              <a href="/products" class="mt-6 flex items-center justify-between border-t border-outline/30 pt-4 font-label-md text-label-md uppercase tracking-[0.18em] text-primary transition-colors hover:text-accent-deep">
                <span>Shop all pieces</span>
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>
        <a href="/products?onSale=1" class="link-underline font-label-md text-label-md uppercase tracking-[0.18em] text-accent-deep transition-colors hover:text-primary">Flash Deals</a>
        <a href="/pages/about" class="link-underline font-label-md text-label-md uppercase tracking-[0.18em] text-on-surface transition-colors hover:text-accent-deep">Our Story</a>
      </nav>
    </div>

    <div class="flex items-center gap-3 text-primary md:gap-5">
      {# Inline search (desktop): plain GET form, works without JS. #}
      <form action="/search" method="get" class="group hidden items-center gap-2 border-b border-outline pb-1.5 transition-colors focus-within:border-accent-deep lg:flex">
        <svg class="h-5 w-5 text-on-surface-variant transition-colors group-focus-within:text-accent-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="Search the collection…"
               class="w-44 border-none bg-transparent p-0 text-sm text-on-surface placeholder:text-on-surface-variant/60 focus:ring-0" />
      </form>

      <a href="/search" class="grid h-10 w-10 place-items-center rounded-full transition-colors duration-300 hover:bg-surface-container-high lg:hidden" aria-label="Search">
        <svg class="h-[1.35rem] w-[1.35rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
      </a>

      <a href="/cart" class="relative grid h-10 w-10 place-items-center rounded-full transition-colors duration-300 hover:bg-surface-container-high" aria-label="Cart{% if cartCount %} ({{ cartCount }} item{% if cartCount != 1 %}s{% endif %}){% endif %}">
        <svg class="h-[1.35rem] w-[1.35rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 7h12l-1 13H7L6 7z" stroke-linejoin="round"/><path d="M9 7a3 3 0 016 0" stroke-linecap="round"/></svg>
        {% if cartCount %}<span class="absolute right-1 top-1 flex h-4 min-w-4 items-center justify-center rounded-full bg-accent px-1 text-[10px] font-bold leading-none text-primary">{{ cartCount }}</span>{% endif %}
      </a>

      {% if currentCustomer %}
        <a href="/account" class="grid h-10 w-10 place-items-center rounded-full transition-colors duration-300 hover:bg-surface-container-high" aria-label="My account">
          <svg class="h-[1.35rem] w-[1.35rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke-linecap="round"/></svg>
        </a>
        <form action="/logout" method="post" class="hidden sm:block">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="link-underline font-label-md text-label-md uppercase tracking-[0.18em] text-on-surface-variant transition-colors hover:text-accent-deep">Log out</button>
        </form>
      {% else %}
        <a href="/login" class="grid h-10 w-10 place-items-center rounded-full transition-colors duration-300 hover:bg-surface-container-high" aria-label="Log in">
          <svg class="h-[1.35rem] w-[1.35rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke-linecap="round"/></svg>
        </a>
        <a href="/register" class="hidden items-center rounded-full bg-primary px-5 py-2.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary transition-colors duration-300 hover:bg-on-primary-fixed-variant sm:inline-flex">Register</a>
      {% endif %}

      <button type="button" class="grid h-10 w-10 place-items-center rounded-full transition-colors hover:bg-surface-container-high lg:hidden" @click="open = !open" aria-label="Toggle menu" aria-controls="mobile-menu" :aria-expanded="open ? 'true' : 'false'">
        <svg x-show="!open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
        <svg x-show="open" x-cloak class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" x-show="open" x-cloak x-transition.opacity.duration.200ms class="max-h-[78vh] overflow-y-auto border-t border-outline/30 bg-surface-container-lowest lg:hidden">
    <nav class="flex flex-col px-margin-mobile py-4 text-sm">
      <a href="/" class="border-b border-outline/15 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface">Home</a>
      <a href="/products" class="border-b border-outline/15 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface">Shop all</a>
      <a href="/products?onSale=1" class="border-b border-outline/15 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-accent-deep">Flash Deals</a>
      <p class="pb-2 pt-5 font-label-sm text-label-sm uppercase tracking-[0.3em] text-on-surface-variant/70">Categories</p>
      {% for cat in navCategories() %}
        <a href="/c/{{ cat.slug }}" class="py-2 font-headline-sm text-base text-on-surface">{{ cat.name }}</a>
        {% for sub in cat.children %}
          <a href="/c/{{ sub.slug }}" class="py-1 pl-4 text-on-surface-variant">{{ sub.name }}</a>
        {% endfor %}
      {% endfor %}
      <a href="/pages/about" class="mt-2 border-t border-outline/15 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface">Our Story</a>
      {% if currentCustomer %}
        <a href="/account" class="py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface">My account</a>
        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="py-2 text-left text-on-surface-variant">Log out</button>
        </form>
      {% else %}
        <div class="mt-4 grid grid-cols-2 gap-3">
          <a href="/login" class="inline-flex items-center justify-center rounded-full border border-outline px-5 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface">Log in</a>
          <a href="/register" class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary">Register</a>
        </div>
      {% endif %}
    </nav>
  </div>
</header>
