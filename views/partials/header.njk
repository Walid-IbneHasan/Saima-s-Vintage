<header class="sticky top-0 z-50 border-b border-outline/10 bg-surface/80 backdrop-blur-md" x-data="{ open: false }">
  <div class="mx-auto flex h-20 max-w-container-max items-center justify-between gap-4 px-margin-mobile md:h-24 md:px-margin-desktop">
    <div class="flex items-center gap-8">
      <a href="/" class="font-display-lg text-2xl leading-none text-primary lg:text-headline-md">{{ appName }}</a>

      <nav class="hidden items-center gap-6 lg:flex" aria-label="Primary">
        <div class="relative" x-data="{ shop: false }" @mouseenter="shop = true" @mouseleave="shop = false">
          <a href="/products" class="inline-flex items-center gap-1 font-label-md text-label-md uppercase tracking-widest text-on-surface-variant transition-colors hover:text-primary" @click="shop = !shop">
            Shop
            <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          {# pt-2 (not mt-2) keeps the hover area continuous so the menu doesn't close in the gap #}
          <div x-show="shop" x-cloak class="absolute left-0 top-full z-30 pt-3">
            <div class="w-[36rem] rounded border border-outline/10 bg-surface-container-lowest p-5 shadow-[0_20px_40px_-15px_rgba(130,59,24,0.12)]">
              <div class="grid grid-cols-3 gap-x-6 gap-y-4">
                {% for cat in navCategories() %}
                  <div>
                    <a href="/c/{{ cat.slug }}" class="block text-sm font-medium text-on-surface transition-colors hover:text-primary">{{ cat.name }}</a>
                    {% if cat.children.length %}
                      <div class="mt-1.5 space-y-1">
                        {% for sub in cat.children %}
                          <a href="/c/{{ sub.slug }}" class="block text-xs text-on-surface-variant transition-colors hover:text-primary">{{ sub.name }}</a>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
              <a href="/products" class="mt-4 block border-t border-outline/10 pt-3 font-label-md text-label-md uppercase tracking-widest text-primary hover:underline">Shop all products →</a>
            </div>
          </div>
        </div>
        <a href="/products?onSale=1" class="font-label-md text-label-md uppercase tracking-widest text-primary transition-colors hover:opacity-70">Sale</a>
        <a href="/pages/about" class="font-label-md text-label-md uppercase tracking-widest text-on-surface-variant transition-colors hover:text-primary">About</a>
      </nav>
    </div>

    <div class="flex items-center gap-3 text-primary md:gap-4">
      {# Inline search (desktop): plain GET form, works without JS. #}
      <form action="/search" method="get" class="hidden items-center border-b border-outline-variant pb-1 lg:flex">
        <svg class="mr-2 h-5 w-5 text-on-surface-variant" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="Search heritage pieces…"
               class="w-48 border-none bg-transparent p-0 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:ring-0" />
      </form>

      <a href="/search" class="transition-all duration-300 hover:opacity-70 lg:hidden" aria-label="Search">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
      </a>

      <a href="/cart" class="relative transition-all duration-300 hover:opacity-70" aria-label="Cart{% if cartCount %} ({{ cartCount }} item{% if cartCount != 1 %}s{% endif %}){% endif %}">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 7h12l-1 13H7L6 7z" stroke-linejoin="round"/><path d="M9 7a3 3 0 016 0" stroke-linecap="round"/></svg>
        {% if cartCount %}<span class="absolute -right-2 -top-2 flex h-4 min-w-4 items-center justify-center rounded-full bg-primary px-1 text-[10px] font-bold leading-none text-on-primary">{{ cartCount }}</span>{% endif %}
      </a>

      {% if currentCustomer %}
        <a href="/account" class="transition-all duration-300 hover:opacity-70" aria-label="My account">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke-linecap="round"/></svg>
        </a>
        <form action="/logout" method="post" class="hidden sm:block">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="font-label-md text-label-md uppercase tracking-widest text-on-surface-variant transition-colors hover:text-primary">Log out</button>
        </form>
      {% else %}
        <a href="/login" class="transition-all duration-300 hover:opacity-70" aria-label="Log in">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke-linecap="round"/></svg>
        </a>
        <a href="/register" class="hidden rounded bg-primary px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant sm:inline-block">Register</a>
      {% endif %}

      <button type="button" class="lg:hidden" @click="open = !open" aria-label="Toggle menu" aria-controls="mobile-menu" :aria-expanded="open ? 'true' : 'false'">
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" x-show="open" x-cloak class="max-h-[70vh] overflow-y-auto border-t border-outline/10 bg-surface-container-lowest lg:hidden">
    <nav class="flex flex-col gap-1 px-margin-mobile py-3 text-sm">
      <a href="/" class="py-1 text-on-surface">Home</a>
      <a href="/products" class="py-1 text-on-surface">Shop all</a>
      <a href="/products?onSale=1" class="py-1 font-medium text-primary">Sale</a>
      {% for cat in navCategories() %}
        <a href="/c/{{ cat.slug }}" class="py-1 font-medium text-on-surface">{{ cat.name }}</a>
        {% for sub in cat.children %}
          <a href="/c/{{ sub.slug }}" class="py-0.5 pl-4 text-on-surface-variant">{{ sub.name }}</a>
        {% endfor %}
      {% endfor %}
      <a href="/pages/about" class="mt-1 py-1 text-on-surface">About</a>
      {% if currentCustomer %}
        <a href="/account" class="border-t border-outline/10 pt-2 py-1 font-medium text-on-surface">My account</a>
        <form action="/logout" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="py-1 text-left text-on-surface-variant">Log out</button>
        </form>
      {% else %}
        <a href="/login" class="border-t border-outline/10 pt-2 py-1 text-on-surface">Log in</a>
        <a href="/register" class="py-1 font-medium text-primary">Register</a>
      {% endif %}
    </nav>
  </div>
</header>
