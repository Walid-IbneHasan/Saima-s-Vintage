<a href="/p/{{ p.slug }}" class="group block">
  <div class="relative aspect-[3/4] overflow-hidden rounded-lg bg-surface-container-low ambient-shadow">
    {% if p.image %}
      <img src="{{ p.image.url }}" alt="{{ p.image.alt or p.name }}" loading="lazy"
           class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
    {% endif %}
    {% if p.pricing.onSale %}
      <span class="absolute left-3 top-3 rounded-full bg-primary-container px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider text-on-primary-container">-{{ p.pricing.discountPercent }}%</span>
    {% endif %}
    {% if not p.inStock %}
      <span class="absolute right-3 top-3 rounded-full bg-surface/90 px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant backdrop-blur-sm">Sold out</span>
    {% endif %}
  </div>
  <div class="mt-4 flex items-start justify-between gap-3">
    <h3 class="min-w-0 break-words font-headline-md text-body-lg leading-snug text-on-surface transition-colors group-hover:text-primary">{{ p.name }}</h3>
    <div class="shrink-0 text-right">
      <span class="font-label-md text-label-md text-primary">{{ p.pricing.current | money(p.currency) }}</span>
      {% if p.pricing.onSale %}
        <span class="block text-xs text-on-surface-variant line-through">{{ p.pricing.regular | money(p.currency) }}</span>
      {% endif %}
    </div>
  </div>
</a>
