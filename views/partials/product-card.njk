<article class="group relative">
  <a href="/p/{{ p.slug }}" class="block">
    <div class="relative aspect-[3/4] overflow-hidden rounded-lg border border-outline/20 bg-surface-container-low shadow-luxe transition-shadow duration-500 ease-lux group-hover:shadow-luxe-lg">
      {% if p.image %}
        <img src="{{ p.image.url }}" alt="{{ p.image.alt or p.name }}" loading="lazy"
             class="h-full w-full object-cover transition-transform duration-[900ms] ease-lux group-hover:scale-[1.06]" />
      {% else %}
        <div class="grid h-full w-full place-items-center text-on-surface-variant/50">
          <svg class="h-12 w-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M3 17l5-5 4 4 3-3 6 6"/></svg>
        </div>
      {% endif %}

      {# Tonal hover wash + reveal CTA. #}
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-primary/55 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
      <span class="pointer-events-none absolute inset-x-4 bottom-4 flex translate-y-3 items-center justify-center gap-2 rounded-full bg-surface-container-lowest/95 py-2.5 font-label-md text-label-md uppercase tracking-[0.16em] text-primary opacity-0 shadow-luxe backdrop-blur-sm transition-all duration-500 ease-lux group-hover:translate-y-0 group-hover:opacity-100">
        View piece
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>

      {% if p.pricing.onSale %}
        <span class="absolute left-4 top-4 rounded-full bg-primary px-3 py-1 font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-primary">−{{ p.pricing.discountPercent }}%</span>
      {% endif %}
      {% if not p.inStock %}
        <span class="absolute right-4 top-4 rounded-full bg-surface-container-lowest/90 px-3 py-1 font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant backdrop-blur-sm">Sold out</span>
      {% endif %}
    </div>

    <div class="mt-5 flex items-start justify-between gap-3">
      <div class="min-w-0">
        {% if p.categories and p.categories.length %}
          <p class="font-label-sm text-[11px] uppercase tracking-[0.2em] text-on-surface-variant">{{ p.categories[0].category.name }}</p>
        {% endif %}
        <h3 class="mt-1.5 break-words font-headline-sm text-headline-sm leading-snug text-on-surface transition-colors duration-300 group-hover:text-accent-deep">{{ p.name }}</h3>
      </div>
      <div class="shrink-0 text-right">
        <span class="font-headline-sm text-lg text-primary">{{ p.pricing.current | money(p.currency) }}</span>
        {% if p.pricing.onSale %}
          <span class="block text-xs text-on-surface-variant line-through">{{ p.pricing.regular | money(p.currency) }}</span>
        {% endif %}
      </div>
    </div>
  </a>

  {# Wishlist affordance — client-only visual toggle (no wishlist backend yet). #}
  <button type="button" x-data="{ fav: false }" @click="fav = !fav"
          :aria-pressed="fav ? 'true' : 'false'" aria-label="Save {{ p.name }} to wishlist"
          class="absolute right-3 top-3 grid h-10 w-10 place-items-center rounded-full bg-surface-container-lowest/85 text-primary opacity-0 shadow-luxe backdrop-blur-sm transition-all duration-300 hover:bg-primary hover:text-on-primary focus-visible:opacity-100 group-hover:opacity-100">
    <svg class="h-5 w-5 transition-colors" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" :fill="fav ? 'currentColor' : 'none'" :class="fav && 'text-accent'" aria-hidden="true">
      <path d="M12 21s-7-4.6-9.5-9C1 9 2.5 5.5 6 5.5c2 0 3.2 1.2 4 2.3.8-1.1 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 16.4 12 21 12 21z" stroke-linejoin="round" />
    </svg>
  </button>
</article>
