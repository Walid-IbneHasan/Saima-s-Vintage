<div class="group relative">
  <a href="/p/{{ p.slug }}" class="block">
    <div class="relative aspect-[3/4] overflow-hidden rounded-lg bg-surface-container-low ambient-shadow transition-shadow duration-300 group-hover:shadow-lg">
      {% if p.image %}
        <img src="{{ p.image.url }}" alt="{{ p.image.alt or p.name }}" loading="lazy"
             class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
      {% endif %}
      {% if p.pricing.onSale %}
        <span class="absolute left-4 top-4 rounded-full bg-primary px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider text-on-primary">-{{ p.pricing.discountPercent }}%</span>
      {% endif %}
      {% if not p.inStock %}
        <span class="absolute bottom-4 left-4 rounded-full bg-surface/90 px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant backdrop-blur-sm">Sold out</span>
      {% endif %}
    </div>
    <div class="mt-5 flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h3 class="break-words font-headline-sm text-headline-sm leading-snug text-on-surface transition-colors group-hover:text-primary">{{ p.name }}</h3>
        {% if p.categories and p.categories.length %}
          <p class="mt-1 text-sm text-on-surface-variant">{{ p.categories[0].category.name }}</p>
        {% endif %}
      </div>
      <div class="shrink-0 text-right">
        <span class="font-label-md text-label-md text-primary">{{ p.pricing.current | money(p.currency) }}</span>
        {% if p.pricing.onSale %}
          <span class="block text-xs text-on-surface-variant line-through">{{ p.pricing.regular | money(p.currency) }}</span>
        {% endif %}
      </div>
    </div>
  </a>
  {# Wishlist affordance — client-only visual toggle (no wishlist backend yet). #}
  <button type="button" x-data="{ fav: false }" @click="fav = !fav"
          :aria-pressed="fav ? 'true' : 'false'" aria-label="Save {{ p.name }} to wishlist"
          class="absolute right-3 top-3 flex h-10 w-10 items-center justify-center rounded-full bg-surface/80 text-primary backdrop-blur-sm transition-colors hover:bg-primary hover:text-on-primary">
    <svg class="h-5 w-5" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" :fill="fav ? 'currentColor' : 'none'" aria-hidden="true">
      <path d="M12 21s-7-4.6-9.5-9C1 9 2.5 5.5 6 5.5c2 0 3.2 1.2 4 2.3.8-1.1 2-2.3 4-2.3 3.5 0 5 3.5 3.5 6.5C19 16.4 12 21 12 21z" stroke-linejoin="round" />
    </svg>
  </button>
</div>
