<footer class="relative w-full overflow-hidden bg-brand-wine text-brand-cream">
  {# Soft red + gold glow and a faint mandala motif for depth. #}
  <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full" aria-hidden="true" style="background:radial-gradient(closest-side,rgba(196,40,59,.28),transparent);"></div>
  <div class="pointer-events-none absolute -bottom-28 left-1/4 h-80 w-80 rounded-full" aria-hidden="true" style="background:radial-gradient(closest-side,rgba(176,141,63,.16),transparent);"></div>
  <svg class="pointer-events-none absolute -bottom-20 -left-20 h-80 w-80 opacity-[0.06]" viewBox="0 0 100 100" fill="none" stroke-width="0.8" style="stroke:#dcb978;" aria-hidden="true">
    <circle cx="50" cy="50" r="47" stroke-dasharray="1.5 5"/><circle cx="50" cy="50" r="38"/><circle cx="50" cy="50" r="26" stroke-dasharray="2 5"/><circle cx="50" cy="50" r="12"/>
  </svg>

  <div class="relative mx-auto max-w-container-max px-margin-mobile md:px-margin-desktop">
    {# ── Link columns ────────────────────────────────────────────────── #}
    <div class="grid grid-cols-2 gap-x-8 gap-y-12 py-16 md:grid-cols-4 md:py-20">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2.5" aria-label="{{ appName }} — home">
          <span class="text-brand-gold-bright" aria-hidden="true">
            <svg class="h-7 w-7" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="20" cy="20" r="18" stroke-dasharray="1 4"/><circle cx="20" cy="20" r="12.5"/><circle cx="20" cy="20" r="4.5" fill="currentColor" stroke="none"/></svg>
          </span>
          <span class="font-brand-serif text-2xl font-medium text-brand-cream">{{ appName }}</span>
        </a>
        <p class="mt-5 max-w-xs font-brand-sans text-brand-cream/80">
          Hand-picked vintage treasures and handcrafted Lippan &amp; Jharoka art, restored with a reverent hand by Saima.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a href="https://www.facebook.com/share/17pPPFZUNe/?mibextid=wwXIfr" target="_blank" rel="noopener" aria-label="Facebook" class="grid h-10 w-10 place-items-center rounded-full border border-white/15 text-brand-cream/90 transition-colors hover:border-brand-gold-bright hover:text-brand-gold-bright">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H8.5v3H11v6h3v-6h2.5l.5-3H14v-1.5c0-.3.2-.5.5-.5z"/></svg>
          </a>
          <a href="https://wa.me/8801628936239" target="_blank" rel="noopener" aria-label="WhatsApp" class="grid h-10 w-10 place-items-center rounded-full border border-white/15 text-brand-cream/90 transition-colors hover:border-brand-gold-bright hover:text-brand-gold-bright">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.207zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.612-.916-2.207-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="mb-5 font-brand-sans text-[12px] font-semibold uppercase tracking-[0.24em] text-brand-cream">Shop</h3>
        <ul class="space-y-3.5 font-brand-sans">
          <li><a href="/products" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">All pieces</a></li>
          <li><a href="/products?onSale=1" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">Flash Deals</a></li>
          {% for cat in navCategories() %}{% if loop.index0 < 3 %}
            <li><a href="/c/{{ cat.slug }}" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">{{ cat.name }}</a></li>
          {% endif %}{% endfor %}
        </ul>
      </div>

      <div>
        <h3 class="mb-5 font-brand-sans text-[12px] font-semibold uppercase tracking-[0.24em] text-brand-cream">Atelier</h3>
        <ul class="space-y-3.5 font-brand-sans">
          <li><a href="/pages/about" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">Our story</a></li>
          <li><a href="/search" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">Search</a></li>
          <li><a href="/cart" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">Your cart</a></li>
          <li><a href="/account" class="ul-grow text-brand-cream/80 transition-colors hover:text-brand-gold-bright">My account</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-5 font-brand-sans text-[12px] font-semibold uppercase tracking-[0.24em] text-brand-cream">Care</h3>
        <ul class="space-y-3.5 font-brand-sans text-brand-cream/80">
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-gold-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 7l8-4 8 4v6c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V7z" stroke-linejoin="round"/></svg>
            <span>Restored &amp; authenticated</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-gold-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M3 8h13v8H3zM16 11h3l2 2v3h-5z" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.6"/><circle cx="18" cy="17" r="1.6"/></svg>
            <span>Nationwide delivery</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-gold-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 9h16v11H4zM4 9l2-5h12l2 5M12 4v5M9 13h6" stroke-linejoin="round"/></svg>
            <span>Complimentary wrapping</span>
          </li>
        </ul>
      </div>
    </div>

    {# ── Legal / trust bar ───────────────────────────────────────────── #}
    <div class="flex flex-col items-center justify-between gap-4 border-t border-white/10 py-7 text-center md:flex-row md:text-left">
      <p class="font-brand-sans text-xs text-brand-cream/65">&copy; {{ currentYear }} {{ appName }}. Handcrafted heritage, made to be lived with.</p>
      <div class="flex items-center gap-2 text-brand-cream/60">
        <span class="font-brand-sans text-[11px] uppercase tracking-[0.18em]">Secure checkout via</span>
        <span class="rounded border border-white/15 px-2.5 py-1 font-brand-sans text-[10px] uppercase tracking-[0.14em] text-brand-cream/80">bKash</span>
      </div>
    </div>
  </div>
</footer>
