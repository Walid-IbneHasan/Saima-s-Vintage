{#
  Foreground hero motifs that float OVER the product image (right side of the
  hero). Light-toned so they read on photography; same pure-CSS animation as the
  background layer. Included inside the product anchor (which is
  relative + overflow-hidden) so these are clipped to the image and sit above it
  but below the product-name overlay. pointer-events-none keeps the link
  clickable. aria-hidden — decorative only.
#}
<div class="pointer-events-none absolute inset-0" aria-hidden="true">
  {# Mirror mandala — top-right of the image #}
  <span class="hero-motif absolute right-[7%] top-[7%] text-surface opacity-50"
        style="--dur:11s; --dx:-14px; --dy:18px; --delay:-3s">
    <svg class="hero-spin h-16 w-16 md:h-24 md:w-24" style="--spin:38s" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.6">
      <circle cx="50" cy="50" r="47" />
      <circle cx="50" cy="50" r="33" stroke-dasharray="2 6" />
      <circle cx="50" cy="50" r="18" />
      <circle cx="50" cy="50" r="5" fill="currentColor" stroke="none" />
    </svg>
  </span>

  {# Mirror-tile diamonds — upper-left of the image #}
  <span class="hero-motif absolute left-[8%] top-[16%] text-surface opacity-40"
        style="--dur:13s; --dx:14px; --dy:-12px; --delay:-7s">
    <svg class="hero-spin h-14 w-14 md:h-20 md:w-20" style="--spin:48s" viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.6">
      <rect x="32" y="6" width="16" height="16" transform="rotate(45 40 14)" />
      <rect x="14" y="34" width="14" height="14" transform="rotate(45 21 41)" />
      <rect x="52" y="34" width="14" height="14" transform="rotate(45 59 41)" />
      <rect x="33" y="52" width="16" height="16" transform="rotate(45 41 60)" />
    </svg>
  </span>

  {# Dotted sun ring — mid-right of the image #}
  <span class="hero-motif absolute right-[14%] top-[46%] text-surface opacity-45"
        style="--dur:10s; --dx:10px; --dy:-14px; --delay:-2s">
    <svg class="hero-spin h-12 w-12 md:h-16 md:w-16" style="--spin:30s" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.6">
      <circle cx="30" cy="30" r="22" stroke-dasharray="1.5 5" />
      <circle cx="30" cy="30" r="11" />
    </svg>
  </span>
</div>
