{% extends "layouts/base.njk" %}

{% block content %}
<section class="relative flex min-h-[78vh] items-center justify-center overflow-hidden px-margin-mobile py-16 md:px-margin-desktop md:py-24">
  <div class="pointer-events-none absolute -left-32 top-1/4 -z-10 h-[26rem] w-[26rem] rounded-full bg-accent/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 bottom-0 -z-10 h-72 w-72 rounded-full bg-accent/[0.07] blur-3xl" aria-hidden="true"></div>

  <div class="w-full max-w-md" data-reveal>
    <div class="mb-8 text-center">
      <p class="eyebrow text-accent-deep">Almost there</p>
      <h1 class="mt-4 font-display-lg text-headline-lg text-on-surface">Verify your email</h1>
      <p class="mt-3 text-body-md text-on-surface-variant">One quick step to activate your account.</p>
    </div>

    <div class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-8 shadow-luxe">
      {% if sent or needVerify %}
        <p class="mb-5 rounded-lg border border-accent/30 bg-accent/5 px-4 py-3 text-sm text-on-surface">We sent a 6-digit code to <strong>{{ email }}</strong>. Enter it below to activate your account.</p>
      {% endif %}
      {% if resent %}<p class="mb-5 rounded-lg border border-accent/30 bg-accent/5 px-4 py-3 text-sm text-on-surface">A new code has been sent.</p>{% endif %}
      {% if error %}<p class="mb-5 rounded-lg border border-error/20 bg-error-container px-4 py-3 text-sm text-on-error-container">{{ error }}</p>{% endif %}

      <form action="/verify" method="post" class="space-y-5">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <input type="hidden" name="email" value="{{ email }}" />
        <label class="block">
          <span class="block text-center font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Verification code</span>
          <input name="code" inputmode="numeric" maxlength="6" required autofocus placeholder="000000"
                 class="mt-2 w-full rounded-lg border border-outline bg-surface-container-low px-4 py-4 text-center font-display-lg text-3xl tracking-[0.4em] text-on-surface placeholder:text-on-surface-variant/30 transition-colors focus:border-accent-deep focus:ring-0" />
        </label>
        <button class="w-full rounded-full bg-primary px-6 py-3.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">Verify</button>
      </form>

      <form action="/verify/resend" method="post" class="mt-4 text-center">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <input type="hidden" name="email" value="{{ email }}" />
        <button class="link-underline text-sm text-accent-deep">Resend code</button>
      </form>

      <p class="mt-6 border-t border-outline/30 pt-5 text-center text-sm text-on-surface-variant">
        Used the wrong email or didn't get a code? <a href="/register" class="link-underline text-accent-deep">Re-register</a>.
      </p>
    </div>
  </div>
</section>
{% endblock %}
