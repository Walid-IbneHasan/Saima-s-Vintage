{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-md px-4 py-16">
  <h1 class="font-serif text-3xl">Verify your email</h1>
  {% if sent or needVerify %}
    <p class="mt-4 rounded bg-amber-50 px-3 py-2 text-sm text-amber-800">We sent a 6-digit code to <strong>{{ email }}</strong>. Enter it below to activate your account.</p>
  {% endif %}
  {% if resent %}<p class="mt-4 rounded bg-green-50 px-3 py-2 text-sm text-green-700">A new code has been sent.</p>{% endif %}
  {% if error %}<p class="mt-4 rounded bg-red-50 px-3 py-2 text-sm text-red-700">{{ error }}</p>{% endif %}

  <form action="/verify" method="post" class="mt-6 space-y-4">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <input type="hidden" name="email" value="{{ email }}" />
    <label class="block text-sm font-medium">Verification code
      <input name="code" inputmode="numeric" maxlength="6" required autofocus
             class="mt-1 w-full rounded border-stone-300 tracking-[0.4em]" />
    </label>
    <button class="w-full rounded-full bg-stone-900 px-6 py-3 text-white hover:bg-stone-700">Verify</button>
  </form>

  <form action="/verify/resend" method="post" class="mt-3">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <input type="hidden" name="email" value="{{ email }}" />
    <button class="text-sm text-amber-700 hover:underline">Resend code</button>
  </form>

  <p class="mt-5 border-t border-stone-100 pt-4 text-sm text-stone-500">
    Used the wrong email or didn't get a code? <a href="/register" class="text-amber-700 hover:underline">Re-register</a>.
  </p>
</div>
{% endblock %}
