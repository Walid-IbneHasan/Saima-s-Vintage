{% extends "layouts/base.njk" %}

{% block content %}
<section class="relative flex min-h-[78vh] items-center justify-center overflow-hidden px-margin-mobile py-16 md:px-margin-desktop md:py-24">
  <div class="pointer-events-none absolute -left-32 top-1/4 -z-10 h-[26rem] w-[26rem] rounded-full bg-accent/10 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 bottom-0 -z-10 h-72 w-72 rounded-full bg-accent/[0.07] blur-3xl" aria-hidden="true"></div>

  <div class="w-full max-w-md" data-reveal>
    <div class="mb-8 text-center">
      <p class="eyebrow text-accent-deep">Welcome back</p>
      <h1 class="mt-4 font-display-lg text-headline-lg text-on-surface">Log in</h1>
      <p class="mt-3 text-body-md text-on-surface-variant">Sign in to continue collecting heritage pieces.</p>
    </div>

    <div class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-8 shadow-luxe">
      {% if reset %}<p class="mb-5 rounded-lg border border-accent/30 bg-accent/5 px-4 py-3 text-sm text-on-surface">Your password was reset. Please log in.</p>{% endif %}
      {% if oauthError %}<p class="mb-5 rounded-lg border border-error/20 bg-error-container px-4 py-3 text-sm text-on-error-container">Google sign-in failed. Please try again.</p>{% endif %}
      {% if error %}<p class="mb-5 rounded-lg border border-error/20 bg-error-container px-4 py-3 text-sm text-on-error-container">{{ error }}</p>{% endif %}

      <form action="/login" method="post" class="space-y-5">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Email</span>
          <input name="email" type="email" required value="{{ values.email or '' }}" autocomplete="email"
                 class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface placeholder:text-on-surface-variant/50 transition-colors focus:border-accent-deep focus:ring-0" />
        </label>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Password</span>
          <input name="password" type="password" required autocomplete="current-password"
                 class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface placeholder:text-on-surface-variant/50 transition-colors focus:border-accent-deep focus:ring-0" />
        </label>
        <div class="text-right">
          <a href="/forgot" class="link-underline text-sm text-accent-deep">Forgot password?</a>
        </div>
        <button class="w-full rounded-full bg-primary px-6 py-3.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">Log in</button>
      </form>

      {% if googleEnabled %}
        <div class="my-6 flex items-center gap-4 font-label-sm text-[11px] uppercase tracking-[0.2em] text-on-surface-variant/70">
          <span class="h-px flex-1 bg-outline/30"></span>or<span class="h-px flex-1 bg-outline/30"></span>
        </div>
        <a href="/auth/google" class="inline-flex w-full items-center justify-center gap-2.5 rounded-full border border-outline px-6 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface transition-colors duration-300 hover:border-accent hover:text-accent-deep">
          <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.27-4.74 3.27-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0012 23z"/><path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 010-4.2V7.06H2.18a11 11 0 000 9.88l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A11 11 0 002.18 7.06l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z"/></svg>
          Continue with Google
        </a>
      {% endif %}
    </div>

    <p class="mt-7 text-center text-sm text-on-surface-variant">New here? <a href="/register" class="link-underline text-accent-deep">Create an account</a></p>
  </div>
</section>
{% endblock %}
