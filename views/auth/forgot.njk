{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-md px-4 py-16">
  <h1 class="font-serif text-3xl">Forgot password</h1>
  <p class="mt-2 text-sm text-stone-500">Enter your email and we'll send a 6-digit reset code.</p>
  <form action="/forgot" method="post" class="mt-6 space-y-4">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <label class="block text-sm font-medium">Email
      <input name="email" type="email" required class="mt-1 w-full rounded border-stone-300" />
    </label>
    <button class="w-full rounded-full bg-stone-900 px-6 py-3 text-white hover:bg-stone-700">Send reset code</button>
  </form>
  <p class="mt-6 text-sm text-stone-500"><a href="/login" class="text-amber-700 hover:underline">Back to login</a></p>
</div>
{% endblock %}
