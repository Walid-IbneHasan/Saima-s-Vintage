{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto flex min-h-[70vh] max-w-md flex-col justify-center px-margin-mobile py-16">
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-8 ambient-shadow">
    <h1 class="font-display-lg text-headline-lg text-on-surface">Forgot password</h1>
    <p class="mt-2 text-sm text-on-surface-variant">Enter your email and we'll send a 6-digit reset code.</p>
    <form action="/forgot" method="post" class="mt-6 space-y-4">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Email</span>
        <input name="email" type="email" required class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <button class="w-full rounded bg-primary px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Send reset code</button>
    </form>
  </div>
  <p class="mt-6 text-center text-sm text-on-surface-variant"><a href="/login" class="text-primary hover:underline">Back to login</a></p>
</div>
{% endblock %}
