{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto flex min-h-[70vh] max-w-md flex-col justify-center px-margin-mobile py-16">
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-8 ambient-shadow">
    <h1 class="font-display-lg text-headline-lg text-on-surface">Create account</h1>
    {% if error %}<p class="mt-4 rounded bg-error-container px-4 py-3 text-sm text-on-error-container">{{ error }}</p>{% endif %}

    <form action="/register" method="post" class="mt-6 space-y-4">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Name</span>
        <input name="name" required value="{{ values.name or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Email</span>
        <input name="email" type="email" required value="{{ values.email or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Password</span>
        <input name="password" type="password" required minlength="8" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        <span class="mt-1 block text-xs text-on-surface-variant">At least 8 characters.</span>
      </label>
      <button class="w-full rounded bg-primary px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Create account</button>
    </form>

    {% if googleEnabled %}
      <div class="my-5 flex items-center gap-3 text-xs text-on-surface-variant"><span class="h-px flex-1 bg-outline/20"></span>or<span class="h-px flex-1 bg-outline/20"></span></div>
      <a href="/auth/google" class="flex w-full items-center justify-center gap-2 rounded border border-outline/30 px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-surface transition-colors hover:border-primary">Continue with Google</a>
    {% endif %}
  </div>

  <p class="mt-6 text-center text-sm text-on-surface-variant">Already have an account? <a href="/login" class="text-primary hover:underline">Log in</a></p>
</div>
{% endblock %}
