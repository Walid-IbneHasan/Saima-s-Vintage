{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto flex min-h-[70vh] max-w-md flex-col justify-center px-margin-mobile py-16">
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-8 ambient-shadow">
    <h1 class="font-display-lg text-headline-lg text-on-surface">Reset password</h1>
    {% if sent %}<p class="mt-4 rounded bg-secondary-container/40 px-4 py-3 text-sm text-on-surface">If an account exists for <strong>{{ email }}</strong>, a reset code has been sent. Enter it below.</p>{% endif %}
    {% if error %}<p class="mt-4 rounded bg-error-container px-4 py-3 text-sm text-on-error-container">{{ error }}</p>{% endif %}

    <form action="/reset" method="post" class="mt-6 space-y-4">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Email</span>
        <input name="email" type="email" required value="{{ email }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Reset code</span>
        <input name="code" inputmode="numeric" maxlength="6" required class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md tracking-[0.4em] text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">New password</span>
        <input name="password" type="password" required minlength="8" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <button class="w-full rounded bg-primary px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Reset password</button>
    </form>
  </div>
</div>
{% endblock %}
