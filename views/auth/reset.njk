{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-md px-4 py-16">
  <h1 class="font-serif text-3xl">Reset password</h1>
  {% if sent %}<p class="mt-4 rounded bg-amber-50 px-3 py-2 text-sm text-amber-800">If an account exists for <strong>{{ email }}</strong>, a reset code has been sent. Enter it below.</p>{% endif %}
  {% if error %}<p class="mt-4 rounded bg-red-50 px-3 py-2 text-sm text-red-700">{{ error }}</p>{% endif %}

  <form action="/reset" method="post" class="mt-6 space-y-4">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <label class="block text-sm font-medium">Email
      <input name="email" type="email" required value="{{ email }}" class="mt-1 w-full rounded border-stone-300" />
    </label>
    <label class="block text-sm font-medium">Reset code
      <input name="code" inputmode="numeric" maxlength="6" required class="mt-1 w-full rounded border-stone-300 tracking-[0.4em]" />
    </label>
    <label class="block text-sm font-medium">New password
      <input name="password" type="password" required minlength="8" class="mt-1 w-full rounded border-stone-300" />
    </label>
    <button class="w-full rounded-full bg-stone-900 px-6 py-3 text-white hover:bg-stone-700">Reset password</button>
  </form>
</div>
{% endblock %}
