{% extends "admin/layout.njk" %}

{% block content %}
<form action="/admin/coupons" method="post" class="max-w-xl space-y-5">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <div class="grid gap-4 md:grid-cols-2">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Code
        <input name="code" required class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 font-mono uppercase text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Type
        <select name="type" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0">
          <option value="PERCENT">Percent (%)</option>
          <option value="FIXED">Fixed (৳)</option>
        </select>
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Value
        <input name="value" type="number" step="0.01" min="0" required class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Min subtotal (optional)
        <input name="minSubtotal" type="number" step="0.01" min="0" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Max discount (percent caps)
        <input name="maxDiscount" type="number" step="0.01" min="0" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Usage limit (total)
        <input name="usageLimit" type="number" min="1" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Starts at
        <input name="startsAt" type="datetime-local" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Expires at
        <input name="expiresAt" type="datetime-local" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
    </div>
    <label class="mt-4 flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" name="isActive" checked /> Active</label>
  </div>
  <div class="flex gap-3">
    <button type="submit" class="rounded bg-primary px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">Create coupon</button>
    <a href="/admin/coupons" class="rounded border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface hover:border-primary hover:text-primary">Cancel</a>
  </div>
</form>
{% endblock %}
