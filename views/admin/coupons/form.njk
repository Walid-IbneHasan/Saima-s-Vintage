{% extends "admin/layout.njk" %}

{% block content %}
<form action="/admin/coupons" method="post" class="max-w-xl space-y-5">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
  <div class="rounded-lg bg-white p-6 shadow-sm">
    <div class="grid gap-4 md:grid-cols-2">
      <label class="block text-sm font-medium">Code
        <input name="code" required class="mt-1 w-full rounded border-stone-300 font-mono uppercase" />
      </label>
      <label class="block text-sm font-medium">Type
        <select name="type" class="mt-1 w-full rounded border-stone-300">
          <option value="PERCENT">Percent (%)</option>
          <option value="FIXED">Fixed (৳)</option>
        </select>
      </label>
      <label class="block text-sm font-medium">Value
        <input name="value" type="number" step="0.01" min="0" required class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Min subtotal (optional)
        <input name="minSubtotal" type="number" step="0.01" min="0" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Max discount (percent caps)
        <input name="maxDiscount" type="number" step="0.01" min="0" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Usage limit (total)
        <input name="usageLimit" type="number" min="1" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Starts at
        <input name="startsAt" type="datetime-local" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Expires at
        <input name="expiresAt" type="datetime-local" class="mt-1 w-full rounded border-stone-300" />
      </label>
    </div>
    <label class="mt-4 flex items-center gap-2 text-sm"><input type="checkbox" name="isActive" checked /> Active</label>
  </div>
  <div class="flex gap-3">
    <button type="submit" class="rounded bg-stone-900 px-5 py-2.5 text-sm text-white hover:bg-stone-700">Create coupon</button>
    <a href="/admin/coupons" class="rounded border border-stone-300 px-5 py-2.5 text-sm">Cancel</a>
  </div>
</form>
{% endblock %}
