{% extends "admin/layout.njk" %}

{% block content %}
{% set action = "/admin/products/" + product.id if product else "/admin/products" %}
<form action="{{ action }}" method="post" class="max-w-3xl space-y-5">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

  <div class="rounded-lg bg-white p-6 shadow-sm">
    <label class="block text-sm font-medium">Name
      <input name="name" required value="{{ product.name or '' }}" class="mt-1 w-full rounded border-stone-300" />
    </label>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <label class="block text-sm font-medium">Slug (optional)
        <input name="slug" value="{{ product.slug or '' }}" placeholder="auto from name" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">SKU
        <input name="sku" value="{{ product.sku or '' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <label class="block text-sm font-medium">Base price (BDT)
        <input name="basePrice" type="number" step="0.01" min="0" required
               value="{{ product.basePrice or '' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Discounted price
        <input name="salePrice" type="number" step="0.01" min="0"
               value="{{ product.salePrice or '' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Currency
        <input name="currency" value="{{ product.currency or 'BDT' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <label class="block text-sm font-medium">Brand
        <input name="brand" value="{{ product.brand or '' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Condition
        <input name="condition" value="{{ product.condition or '' }}" placeholder="e.g. Excellent" class="mt-1 w-full rounded border-stone-300" />
      </label>
    </div>
    <label class="mt-4 block text-sm font-medium">Short description
      <textarea name="shortDescription" rows="2" class="mt-1 w-full rounded border-stone-300">{{ product.shortDescription or '' }}</textarea>
    </label>
    <label class="mt-4 block text-sm font-medium">Description (HTML allowed; sanitized on save)
      <textarea name="description" rows="6" class="mt-1 w-full rounded border-stone-300 font-mono text-xs">{{ product.description | safe if product else '' }}</textarea>
    </label>
  </div>

  <div class="rounded-lg bg-white p-6 shadow-sm">
    <p class="mb-2 text-sm font-medium">Categories</p>
    <div class="grid grid-cols-2 gap-2 md:grid-cols-3">
      {% for c in categories %}
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" name="categoryIds" value="{{ c.id }}"
                 {% if c.id in selectedCategoryIds %}checked{% endif %} />
          {{ c.name }}
        </label>
      {% endfor %}
    </div>
  </div>

  <div class="rounded-lg bg-white p-6 shadow-sm">
    <div class="flex flex-wrap gap-6">
      <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="isActive" {% if product.isActive %}checked{% endif %} /> Active (visible)</label>
      <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="isFeatured" {% if product.isFeatured %}checked{% endif %} /> Featured</label>
      <label class="flex items-center gap-2 text-sm"><input type="checkbox" name="allowBackorder" {% if product.allowBackorder %}checked{% endif %} /> Allow backorder</label>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <label class="block text-sm font-medium">Featured order
        <input name="featuredOrder" type="number" value="{{ product.featuredOrder or 0 }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Min per order
        <input name="minPerOrder" type="number" min="1" value="{{ product.minPerOrder or 1 }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Max per order (blank = unlimited)
        <input name="maxPerOrder" type="number" min="1" value="{{ product.maxPerOrder or '' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
    </div>
  </div>

  <div class="flex gap-3">
    <button type="submit" class="rounded bg-stone-900 px-5 py-2.5 text-sm text-white hover:bg-stone-700">
      {{ 'Save changes' if product else 'Create product' }}
    </button>
    <a href="/admin/products" class="rounded border border-stone-300 px-5 py-2.5 text-sm">Cancel</a>
  </div>
</form>

{% if product %}
  {# ---- Variants ---- #}
  <div class="mt-8 max-w-3xl rounded-lg bg-white p-6 shadow-sm">
    <h2 class="text-base font-medium">Variants</h2>
    <div class="mt-3 space-y-2">
      {% for v in product.variants %}
      <div class="flex flex-wrap items-end gap-2 border-t border-stone-100 pt-2">
        <form action="/admin/products/{{ product.id }}/variants/{{ v.id }}" method="post" class="flex flex-wrap items-end gap-2">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <label class="text-xs">SKU<input name="sku" value="{{ v.sku }}" class="mt-1 block w-32 rounded border-stone-300 text-xs" /></label>
          <label class="text-xs">Name<input name="name" value="{{ v.name }}" class="mt-1 block w-32 rounded border-stone-300 text-xs" /></label>
          <label class="text-xs">Price<input name="price" type="number" step="0.01" value="{{ v.price or '' }}" placeholder="base" class="mt-1 block w-24 rounded border-stone-300 text-xs" /></label>
          <label class="text-xs">Sale<input name="salePrice" type="number" step="0.01" value="{{ v.salePrice or '' }}" placeholder="sale" class="mt-1 block w-24 rounded border-stone-300 text-xs" /></label>
          <label class="text-xs">Stock<input name="stock" type="number" value="{{ v.stock }}" class="mt-1 block w-20 rounded border-stone-300 text-xs" /></label>
          <button class="rounded bg-stone-200 px-3 py-2 text-xs hover:bg-stone-300">Save</button>
        </form>
        <form action="/admin/products/{{ product.id }}/variants/{{ v.id }}/delete" method="post" onsubmit="return confirm('Delete variant?')">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="rounded px-2 py-2 text-xs text-red-600 hover:underline">Delete</button>
        </form>
      </div>
      {% endfor %}
      {% if not product.variants.length %}<p class="text-sm text-stone-400">No variants yet — add one below.</p>{% endif %}
    </div>

    <form action="/admin/products/{{ product.id }}/variants" method="post" class="mt-4 flex flex-wrap items-end gap-2 border-t border-stone-200 pt-4">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="text-xs">SKU<input name="sku" required class="mt-1 block w-32 rounded border-stone-300 text-xs" /></label>
      <label class="text-xs">Name<input name="name" required value="Default" class="mt-1 block w-32 rounded border-stone-300 text-xs" /></label>
      <label class="text-xs">Price<input name="price" type="number" step="0.01" placeholder="base" class="mt-1 block w-24 rounded border-stone-300 text-xs" /></label>
      <label class="text-xs">Sale<input name="salePrice" type="number" step="0.01" placeholder="sale" class="mt-1 block w-24 rounded border-stone-300 text-xs" /></label>
      <label class="text-xs">Stock<input name="stock" type="number" value="0" class="mt-1 block w-20 rounded border-stone-300 text-xs" /></label>
      <button class="rounded bg-stone-900 px-3 py-2 text-xs text-white">Add variant</button>
    </form>
  </div>

  {# ---- Images ---- #}
  <div class="mt-8 max-w-3xl rounded-lg bg-white p-6 shadow-sm">
    <h2 class="text-base font-medium">Images</h2>
    <div class="mt-3 grid grid-cols-3 gap-3 md:grid-cols-5">
      {% for img in product.images %}
        <div class="relative">
          <img src="{{ img.url }}" alt="" class="aspect-square w-full rounded object-cover" />
          <form action="/admin/products/{{ product.id }}/images/{{ img.id }}/delete" method="post" class="absolute right-1 top-1">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button class="rounded bg-white/90 px-1.5 text-xs text-red-600">✕</button>
          </form>
        </div>
      {% endfor %}
    </div>
    <form action="/admin/products/{{ product.id }}/images?_csrf={{ csrfToken }}" method="post" enctype="multipart/form-data" class="mt-4 flex items-center gap-3 border-t border-stone-200 pt-4">
      <input type="file" name="image" accept="image/jpeg,image/png,image/webp,image/avif" required class="text-sm" />
      <button class="rounded bg-stone-900 px-3 py-2 text-xs text-white">Upload</button>
      <span class="text-xs text-stone-400">JPEG/PNG/WebP/AVIF, max 5 MB</span>
    </form>
  </div>
{% endif %}
{% endblock %}
