{% extends "admin/layout.njk" %}

{% block content %}
{% set action = "/admin/products/" + product.id if product.id else "/admin/products" %}
<form action="{{ action }}" method="post" class="max-w-3xl space-y-5">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

  {% if error %}
    <div class="flex items-start gap-2 rounded-lg border border-error/30 bg-error-container px-4 py-3 text-sm text-on-error-container">
      <svg class="mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01" stroke-linecap="round"/></svg>
      <span>{{ error }}</span>
    </div>
  {% endif %}

  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Name
      <input name="name" required value="{{ product.name or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
    </label>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Slug (optional)
        <input name="slug" value="{{ product.slug or '' }}" placeholder="auto from name" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">SKU
        <input name="sku" value="{{ product.sku or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Base price (BDT)
        <input name="basePrice" type="number" step="0.01" min="0" required
               value="{{ product.basePrice or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Discounted price
        <input name="salePrice" type="number" step="0.01" min="0"
               value="{{ product.salePrice or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Currency
        <input name="currency" value="{{ product.currency or 'BDT' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Brand
        <input name="brand" value="{{ product.brand or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Condition
        <input name="condition" value="{{ product.condition or '' }}" placeholder="e.g. Excellent" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
    </div>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Short description
      <textarea name="shortDescription" rows="2" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0">{{ product.shortDescription or '' }}</textarea>
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Description (HTML allowed; sanitized on save)
      <textarea name="description" rows="6" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 font-mono text-xs text-on-surface focus:border-primary focus:ring-0">{{ product.description | safe if product else '' }}</textarea>
    </label>
  </div>

  {# ---- Flash deal (time-bound discount) ---- #}
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="font-headline-md text-headline-md text-on-surface">Flash deal</h2>
      <span class="rounded-full bg-primary-container px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider text-on-primary-container">Time-limited</span>
    </div>
    <p class="mt-1 text-sm text-on-surface-variant">Set a discounted price and an end time. The deal goes live within the window and automatically disappears once it ends — no further action needed.</p>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Flash price (BDT)
        <input name="flashPrice" type="number" step="0.01" min="0" value="{{ product.flashPrice or '' }}" placeholder="blank = off"
               class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Starts at (optional)
        <input name="flashStartAt" type="datetime-local" value="{{ product.flashStartAt | dtLocal }}"
               class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Ends at <span class="text-error">(required with a flash price)</span>
        <input name="flashEndAt" type="datetime-local" value="{{ product.flashEndAt | dtLocal }}"
               class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
    </div>
    <p class="mt-2 text-xs text-on-surface-variant">Leave the flash price <strong>blank</strong> to disable. When you set a flash price you <strong>must</strong> set an end time (the deal disappears after it). Blank start = live immediately. The flash price must be lower than the base price to show as a deal. Times use the server's timezone.</p>
  </div>

  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <p class="mb-2 font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Categories</p>
    <div class="grid grid-cols-2 gap-2 md:grid-cols-3">
      {% for c in categories %}
        <label class="flex items-center gap-2 text-sm text-on-surface">
          <input type="checkbox" name="categoryIds" value="{{ c.id }}"
                 {% if c.id in selectedCategoryIds %}checked{% endif %} />
          {{ c.name }}
        </label>
      {% endfor %}
    </div>
  </div>

  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <div class="flex flex-wrap gap-6">
      <label class="flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" name="isActive" {% if product.isActive %}checked{% endif %} /> Active (visible)</label>
      <label class="flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" name="isFeatured" {% if product.isFeatured %}checked{% endif %} /> Featured</label>
      <label class="flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" name="allowBackorder" {% if product.allowBackorder %}checked{% endif %} /> Allow backorder</label>
    </div>
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Featured order
        <input name="featuredOrder" type="number" value="{{ product.featuredOrder or 0 }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Min per order
        <input name="minPerOrder" type="number" min="1" value="{{ product.minPerOrder or 1 }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Max per order (blank = unlimited)
        <input name="maxPerOrder" type="number" min="1" value="{{ product.maxPerOrder or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
    </div>
  </div>

  {% if not product.id %}
    <div class="flex items-start gap-2 rounded-lg border border-dashed border-outline/30 bg-surface-container-low/40 p-4 text-sm text-on-surface-variant">
      <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 16l5-5 4 4 3-3 6 6M3 8h18" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>Save the product first — then you can upload <strong>multiple images</strong> and add variants on the next screen.</span>
    </div>
  {% endif %}

  <div class="flex gap-3">
    <button type="submit" class="rounded bg-primary px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">
      {{ 'Save changes' if product.id else 'Create product' }}
    </button>
    <a href="/admin/products" class="rounded border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface hover:border-primary hover:text-primary">Cancel</a>
  </div>
</form>

{% if product.id %}
  {# ---- Variants ---- #}
  <div class="mt-8 max-w-3xl rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <h2 class="font-headline-md text-headline-md text-on-surface">Variants</h2>
    <div class="mt-3 space-y-2">
      {% for v in product.variants %}
      <div class="flex flex-wrap items-end gap-2 border-t border-outline/10 pt-2">
        <form action="/admin/products/{{ product.id }}/variants/{{ v.id }}" method="post" class="flex flex-wrap items-end gap-2">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <label class="text-xs text-on-surface-variant">SKU<input name="sku" value="{{ v.sku }}" class="mt-1 block w-32 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
          <label class="text-xs text-on-surface-variant">Name<input name="name" value="{{ v.name }}" class="mt-1 block w-32 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
          <label class="text-xs text-on-surface-variant">Price<input name="price" type="number" step="0.01" value="{{ v.price or '' }}" placeholder="base" class="mt-1 block w-24 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
          <label class="text-xs text-on-surface-variant">Sale<input name="salePrice" type="number" step="0.01" value="{{ v.salePrice or '' }}" placeholder="sale" class="mt-1 block w-24 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
          <label class="text-xs text-on-surface-variant">Stock<input name="stock" type="number" value="{{ v.stock }}" class="mt-1 block w-20 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
          <button class="rounded border border-outline px-3 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface hover:border-primary hover:text-primary">Save</button>
        </form>
        <form action="/admin/products/{{ product.id }}/variants/{{ v.id }}/delete" method="post" data-confirm="Delete variant?">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="rounded px-2 py-2 text-xs text-error hover:underline">Delete</button>
        </form>
      </div>
      {% endfor %}
      {% if not product.variants.length %}<p class="text-sm text-on-surface-variant">No variants yet — add one below.</p>{% endif %}
    </div>

    <form action="/admin/products/{{ product.id }}/variants" method="post" class="mt-4 flex flex-wrap items-end gap-2 border-t border-outline/20 pt-4">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="text-xs text-on-surface-variant">SKU<input name="sku" required class="mt-1 block w-32 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
      <label class="text-xs text-on-surface-variant">Name<input name="name" required value="Default" class="mt-1 block w-32 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
      <label class="text-xs text-on-surface-variant">Price<input name="price" type="number" step="0.01" placeholder="base" class="mt-1 block w-24 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
      <label class="text-xs text-on-surface-variant">Sale<input name="salePrice" type="number" step="0.01" placeholder="sale" class="mt-1 block w-24 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
      <label class="text-xs text-on-surface-variant">Stock<input name="stock" type="number" value="0" class="mt-1 block w-20 rounded border border-outline/30 bg-surface px-2 py-1 text-xs text-on-surface focus:border-primary focus:ring-0" /></label>
      <button class="rounded bg-primary px-3 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">Add variant</button>
    </form>
  </div>

  {# ---- Images (multi-upload) ---- #}
  <div class="mt-8 max-w-3xl rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <h2 class="font-headline-md text-headline-md text-on-surface">Images</h2>
    <p class="mt-1 text-sm text-on-surface-variant">Upload one or more photos. The first image is the primary thumbnail; they keep upload order.</p>
    {% if product.images.length %}
      <div class="mt-3 grid grid-cols-3 gap-3 md:grid-cols-5">
        {% for img in product.images %}
          <div class="relative">
            <img src="{{ img.url }}" alt="" class="aspect-square w-full rounded object-cover" />
            {% if loop.first %}<span class="absolute left-1 top-1 rounded bg-primary px-1.5 py-0.5 text-[10px] uppercase tracking-wider text-on-primary">Primary</span>{% endif %}
            <form action="/admin/products/{{ product.id }}/images/{{ img.id }}/delete" method="post" class="absolute right-1 top-1">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
              <button class="rounded bg-surface-container-lowest/90 px-1.5 text-xs text-error" aria-label="Delete image">✕</button>
            </form>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="mt-3 text-sm text-on-surface-variant">No images yet.</p>
    {% endif %}
    <form action="/admin/products/{{ product.id }}/images?_csrf={{ csrfToken }}" method="post" enctype="multipart/form-data" class="mt-4 flex flex-wrap items-center gap-3 border-t border-outline/20 pt-4">
      <input type="file" name="images" accept="image/jpeg,image/png,image/webp,image/avif" multiple required class="text-sm text-on-surface" />
      <button class="rounded bg-primary px-3 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">Upload images</button>
      <span class="text-xs text-on-surface-variant">JPEG/PNG/WebP/AVIF · up to 12 files · max 5 MB each</span>
    </form>
  </div>
{% endif %}
{% endblock %}
