{% extends "admin/layout.njk" %}

{% block content %}
<div class="mb-4 flex items-center justify-between">
  <p class="text-sm text-stone-500">{{ meta.total }} product(s)</p>
  <a href="/admin/products/new" class="rounded bg-stone-900 px-4 py-2 text-sm text-white hover:bg-stone-700">New product</a>
</div>

<div class="overflow-x-auto rounded-lg bg-white shadow-sm">
  <table class="w-full text-left text-sm">
    <thead class="border-b border-stone-200 text-xs uppercase text-stone-500">
      <tr>
        <th class="px-4 py-3">Name</th>
        <th class="px-4 py-3">SKU</th>
        <th class="px-4 py-3">Price</th>
        <th class="px-4 py-3">Stock</th>
        <th class="px-4 py-3">Status</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for p in products %}
      <tr class="border-b border-stone-100">
        <td class="px-4 py-3">{{ p.name }}</td>
        <td class="px-4 py-3 text-stone-500">{{ p.sku or '—' }}</td>
        <td class="px-4 py-3">
          {% if p.salePrice %}
            <div class="flex flex-wrap items-center gap-2">
              <span>{{ p.salePrice | money(p.currency) }}</span>
              <span class="text-stone-400 line-through">{{ p.basePrice | money(p.currency) }}</span>
            </div>
          {% else %}
            {{ p.basePrice | money(p.currency) }}
          {% endif %}
        </td>
        <td class="px-4 py-3">{{ p.variantCount }} var · {{ p.totalStock }}</td>
        <td class="px-4 py-3">
          {% if p.isActive %}<span class="text-green-700">Active</span>{% else %}<span class="text-stone-400">Hidden</span>{% endif %}
          {% if p.isFeatured %}<span class="ml-1 text-amber-600">★</span>{% endif %}
        </td>
        <td class="px-4 py-3 text-right">
          <a href="/admin/products/{{ p.id }}/edit" class="text-amber-700 hover:underline">Edit</a>
          <form action="/admin/products/{{ p.id }}/delete" method="post" class="ml-3 inline"
                onsubmit="return confirm('Delete this product?')">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button class="text-red-600 hover:underline">Delete</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-4 py-8 text-center text-stone-400">No products yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% include "partials/pagination.njk" %}
{% endblock %}
