{% extends "admin/layout.njk" %}

{% block content %}
<p class="mb-4 text-sm text-on-surface-variant">{{ meta.total }} review(s)</p>
<div class="overflow-x-auto rounded-lg border border-outline/10 bg-surface-container-lowest">
  <table class="w-full text-left text-sm">
    <thead class="border-b border-outline/10 font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">
      <tr>
        <th class="px-4 py-3">Product</th>
        <th class="px-4 py-3">Rating</th>
        <th class="px-4 py-3">Review</th>
        <th class="px-4 py-3">Author</th>
        <th class="px-4 py-3">Date</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for r in reviews %}
      <tr class="border-b border-outline/10 align-top text-on-surface hover:bg-surface-container-low">
        <td class="px-4 py-3"><a href="/p/{{ r.product.slug }}" class="text-primary hover:underline">{{ r.product.name }}</a></td>
        <td class="px-4 py-3 text-primary">{% for i in range(0, r.rating) %}★{% endfor %}</td>
        <td class="px-4 py-3">
          {% if r.title %}<p class="font-medium">{{ r.title }}</p>{% endif %}
          <p class="text-on-surface-variant">{{ r.body }}</p>
          {% if not r.customerId %}<span class="text-xs text-on-surface-variant">(admin/seed)</span>{% endif %}
        </td>
        <td class="px-4 py-3">{{ r.authorName }}</td>
        <td class="px-4 py-3 text-on-surface-variant">{{ r.createdAt | date }}</td>
        <td class="px-4 py-3 text-right">
          <form action="/admin/reviews/{{ r.id }}/delete" method="post" onsubmit="return confirm('Delete this review?')">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button class="text-error hover:underline">Delete</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-4 py-8 text-center text-on-surface-variant">No reviews yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% include "partials/pagination.njk" %}
{% endblock %}
