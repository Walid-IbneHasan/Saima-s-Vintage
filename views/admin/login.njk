<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin Login · {{ appName }}</title>
    <link rel="stylesheet" href="{{ asset('src/client/styles.css') }}" />
  </head>
  <body class="flex min-h-full items-center justify-center bg-surface px-4">
    <form action="/admin/login" method="post" class="w-full max-w-md rounded-lg border border-outline/10 bg-surface-container-lowest p-8">
      <h1 class="font-display-lg text-headline-lg text-primary">{{ appName }} Admin</h1>
      {% if error %}
        <p class="mt-3 rounded bg-error-container px-3 py-2 text-sm text-on-error-container">{{ error }}</p>
      {% endif %}
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="mt-6 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Email
        <input name="email" type="email" value="{{ email or '' }}" required autofocus
               class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Password
        <input name="password" type="password" required
               class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <button type="submit" class="mt-6 w-full rounded bg-primary px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">
        Sign in
      </button>
    </form>
  </body>
</html>
