<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Admin Login · {{ appName }}</title>
    <link rel="stylesheet" href="{{ asset('src/client/styles.css') }}" />
  </head>
  <body class="flex min-h-full items-center justify-center bg-stone-100">
    <form action="/admin/login" method="post" class="w-full max-w-sm rounded-lg bg-white p-8 shadow">
      <h1 class="font-serif text-2xl">{{ appName }} Admin</h1>
      {% if error %}
        <p class="mt-3 rounded bg-red-50 px-3 py-2 text-sm text-red-700">{{ error }}</p>
      {% endif %}
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <label class="mt-4 block text-sm font-medium">Email
        <input name="email" type="email" value="{{ email or '' }}" required autofocus
               class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="mt-3 block text-sm font-medium">Password
        <input name="password" type="password" required
               class="mt-1 w-full rounded border-stone-300" />
      </label>
      <button type="submit" class="mt-5 w-full rounded bg-stone-900 px-4 py-2 text-white hover:bg-stone-700">
        Sign in
      </button>
    </form>
  </body>
</html>
