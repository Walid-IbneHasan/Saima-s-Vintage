<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{{ title }} · Admin · {{ appName }}</title>
    <link rel="stylesheet" href="{{ asset('src/client/styles.css') }}" />
  </head>
  <body class="flex min-h-full bg-stone-100 text-stone-900">
    <aside class="hidden w-56 shrink-0 bg-stone-900 p-4 text-stone-100 md:block">
      <a href="/admin" class="font-serif text-lg">{{ appName }}</a>
      <nav class="mt-6 space-y-1 text-sm">
        <a href="/admin" class="block rounded px-3 py-2 hover:bg-stone-800">Dashboard</a>
        <a href="/admin/products" class="block rounded px-3 py-2 hover:bg-stone-800">Products</a>
        <a href="/admin/orders" class="block rounded px-3 py-2 hover:bg-stone-800">Orders</a>
        <a href="/admin/categories" class="block rounded px-3 py-2 hover:bg-stone-800">Categories</a>
        <a href="/admin/coupons" class="block rounded px-3 py-2 hover:bg-stone-800">Coupons</a>
        <a href="/admin/reviews" class="block rounded px-3 py-2 hover:bg-stone-800">Reviews</a>
        <a href="/admin/analytics" class="block rounded px-3 py-2 hover:bg-stone-800">Analytics</a>
        <a href="/" class="block rounded px-3 py-2 text-stone-400 hover:bg-stone-800">View store ↗</a>
      </nav>
    </aside>
    <div class="flex-1">
      <header class="flex items-center justify-between border-b border-stone-200 bg-white px-6 py-3">
        <h1 class="text-lg font-medium">{{ title }}</h1>
        <form action="/admin/logout" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <button class="text-sm text-stone-500 hover:text-stone-900">Log out</button>
        </form>
      </header>
      <main class="p-6">{% block content %}{% endblock %}</main>
    </div>
  </body>
</html>
