{% extends "admin/layout.njk" %}
{% from "partials/order-status.njk" import statusBadge %}

{% block content %}
{% macro actionButton(id, action, label, color, token) %}
<form action="/admin/orders/{{ id }}/{{ action }}" method="post">
  <input type="hidden" name="_csrf" value="{{ token }}" />
  <button class="w-full rounded px-3 py-2 text-sm text-white {{ color }} hover:opacity-90">{{ label }}</button>
</form>
{% endmacro %}

<a href="/admin/orders" class="text-sm text-stone-500 hover:text-amber-700">← All orders</a>

<div class="mt-3 flex items-center gap-3">
  <h2 class="font-serif text-2xl">{{ order.orderNumber }}</h2>
  {{ statusBadge(order.status) }}
  <span class="text-sm text-stone-400">{{ order.createdAt | date }}</span>
</div>

<div class="mt-5 grid gap-6 lg:grid-cols-3">
  <div class="space-y-6 lg:col-span-2">
    {# Items #}
    <div class="rounded-lg bg-white p-6 shadow-sm">
      <h3 class="text-base font-medium">Items</h3>
      <table class="mt-3 w-full text-left text-sm">
        <thead class="text-xs uppercase text-stone-500"><tr><th class="py-2">Product</th><th>SKU</th><th>Qty</th><th>Unit</th><th class="text-right">Total</th></tr></thead>
        <tbody>
          {% for i in order.items %}
          <tr class="border-t border-stone-100">
            <td class="py-2">{{ i.productName }} <span class="text-stone-400">({{ i.variantName }})</span></td>
            <td class="text-stone-500">{{ i.sku }}</td>
            <td>{{ i.quantity }}</td>
            <td>{{ i.unitPrice | money(order.currency) }}</td>
            <td class="text-right">{{ i.lineTotal | money(order.currency) }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <div class="mt-4 space-y-1 border-t border-stone-200 pt-4 text-sm">
        <div class="flex justify-between"><span class="text-stone-500">Subtotal</span><span>{{ order.subtotal | money(order.currency) }}</span></div>
        {% if order.discountTotal and order.discountTotal > 0 %}<div class="flex justify-between text-green-700"><span>Discount {% if order.couponCode %}({{ order.couponCode }}){% endif %}</span><span>−{{ order.discountTotal | money(order.currency) }}</span></div>{% endif %}
        <div class="flex justify-between"><span class="text-stone-500">Shipping</span><span>{{ order.shippingTotal | money(order.currency) }}</span></div>
        <div class="flex justify-between text-base font-medium"><span>Total</span><span>{{ order.grandTotal | money(order.currency) }}</span></div>
      </div>
    </div>

    {# Customer + shipping #}
    <div class="rounded-lg bg-white p-6 shadow-sm">
      <h3 class="text-base font-medium">Customer &amp; shipping</h3>
      <div class="mt-3 grid gap-4 text-sm md:grid-cols-2">
        <div>
          <p class="text-stone-500">Contact</p>
          <p>{{ order.customer.name or order.shipName }}</p>
          <p>{{ order.email }}</p>
          {% if order.phone %}<p>{{ order.phone }}</p>{% endif %}
        </div>
        <div>
          <p class="text-stone-500">Ship to</p>
          <p>{{ order.shipName }}</p>
          <p>{{ order.shipLine1 }}{% if order.shipLine2 %}, {{ order.shipLine2 }}{% endif %}</p>
          <p>{{ order.shipCity }}{% if order.shipDistrict %}, {{ order.shipDistrict }}{% endif %} {{ order.shipPostalCode }}</p>
          <p>{{ order.shipCountry }} · {{ order.shipPhone }}</p>
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    {# Actions #}
    <div class="rounded-lg bg-white p-6 shadow-sm">
      <h3 class="text-base font-medium">Actions</h3>
      <div class="mt-3 flex flex-col gap-2">
        {% if order.status == 'PAYMENT_REVIEW' %}
          {{ actionButton(order.id, 'approve-review', 'Approve payment', 'bg-green-700', csrfToken) }}
        {% endif %}
        {% if order.status == 'PAID' %}
          {{ actionButton(order.id, 'processing', 'Mark processing', 'bg-stone-900', csrfToken) }}
        {% endif %}
        {% if order.status == 'PROCESSING' %}
          {{ actionButton(order.id, 'shipped', 'Mark shipped', 'bg-stone-900', csrfToken) }}
        {% endif %}
        {% if order.status == 'SHIPPED' %}
          {{ actionButton(order.id, 'delivered', 'Mark delivered', 'bg-stone-900', csrfToken) }}
        {% endif %}
        {% if order.status not in ['CANCELLED', 'REFUNDED', 'PARTIALLY_REFUNDED', 'FAILED', 'EXPIRED', 'DELIVERED'] %}
          <form action="/admin/orders/{{ order.id }}/cancel" method="post" onsubmit="return confirm('Cancel this order and restock its items?')">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button class="w-full rounded border border-red-300 px-3 py-2 text-sm text-red-700 hover:bg-red-50">Cancel &amp; restock</button>
          </form>
        {% endif %}
        {% if order.status in ['CANCELLED', 'DELIVERED', 'REFUNDED'] %}
          <p class="text-sm text-stone-400">No further actions.</p>
        {% endif %}
      </div>
    </div>

    {# Payments #}
    <div class="rounded-lg bg-white p-6 shadow-sm">
      <h3 class="text-base font-medium">Payments</h3>
      {% for p in order.payments %}
        <div class="mt-3 border-t border-stone-100 pt-3 text-sm first:border-t-0 first:pt-0">
          <div class="flex justify-between"><span>{{ statusBadge(p.status) }}</span><span>{{ p.amount | money(p.currency) }}</span></div>
          <p class="mt-1 text-xs text-stone-500">tran: {{ p.tranId }}</p>
          {% if p.valId %}<p class="text-xs text-stone-500">val: {{ p.valId }}</p>{% endif %}
          {% if p.riskLevel != null %}<p class="text-xs text-stone-500">risk: {{ p.riskLevel }} {{ p.riskTitle }}</p>{% endif %}
        </div>
      {% else %}
        <p class="mt-2 text-sm text-stone-400">No payments.</p>
      {% endfor %}
    </div>

    {# Reservations + shipments #}
    <div class="rounded-lg bg-white p-6 shadow-sm">
      <h3 class="text-base font-medium">Inventory &amp; shipments</h3>
      <div class="mt-2 text-sm">
        {% for r in order.reservations %}
          <p class="text-xs text-stone-500">{{ r.variant.sku }} × {{ r.quantity }} — {{ r.status }}</p>
        {% endfor %}
        {% for s in order.shipments %}
          <p class="mt-1 text-xs text-stone-500">Shipment: {{ s.status }}{% if s.shippedAt %} · shipped {{ s.shippedAt | date }}{% endif %}</p>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
{% endblock %}
