{% extends "admin/layout.njk" %}
{% from "partials/order-status.njk" import statusBadge %}

{% block content %}
<div class="mb-4 flex flex-wrap items-center gap-2 text-xs">
  <a href="/admin/orders" class="rounded-full border px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider {% if not activeStatus %}border-primary bg-primary text-on-primary{% else %}border-outline text-on-surface hover:border-primary hover:text-primary{% endif %}">All</a>
  {% for s in statuses %}
    <a href="/admin/orders?status={{ s }}" class="rounded-full border px-3 py-1 font-label-sm text-label-sm uppercase tracking-wider {% if activeStatus == s %}border-primary bg-primary text-on-primary{% else %}border-outline text-on-surface hover:border-primary hover:text-primary{% endif %}">{{ s }}</a>
  {% endfor %}
</div>

<div class="overflow-x-auto rounded-lg border border-outline/10 bg-surface-container-lowest">
  <table class="w-full text-left text-sm">
    <thead class="border-b border-outline/20 text-on-surface-variant font-label-sm text-label-sm uppercase tracking-wider">
      <tr>
        <th class="px-4 py-3">Order</th>
        <th class="px-4 py-3">Date</th>
        <th class="px-4 py-3">Customer</th>
        <th class="px-4 py-3">Items</th>
        <th class="px-4 py-3">Total</th>
        <th class="px-4 py-3">Status</th>
      </tr>
    </thead>
    <tbody>
      {% for o in orders %}
      <tr class="border-b border-outline/10 hover:bg-surface-container-low text-sm text-on-surface">
        <td class="px-4 py-3"><a href="/admin/orders/{{ o.id }}" class="font-medium text-primary hover:underline">{{ o.orderNumber }}</a></td>
        <td class="px-4 py-3 text-on-surface-variant">{{ o.createdAt | date }}</td>
        <td class="px-4 py-3">{{ o.customer.name or o.email }}</td>
        <td class="px-4 py-3">{{ o._count.items }}</td>
        <td class="px-4 py-3">{{ o.grandTotal | money(o.currency) }}</td>
        <td class="px-4 py-3">{{ statusBadge(o.status) }}</td>
      </tr>
      {% else %}
      <tr><td colspan="6" class="px-4 py-8 text-center text-on-surface-variant">No orders found.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% include "partials/pagination.njk" %}
{% endblock %}
