{% extends "admin/layout.njk" %}

{% block content %}
{% set action = "/admin/categories/" + category.id if category.id else "/admin/categories" %}
<form action="{{ action }}?_csrf={{ csrfToken }}" method="post" enctype="multipart/form-data" class="max-w-xl space-y-5">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

  {% if error %}
    <div class="flex items-start gap-2 rounded-lg border border-error/30 bg-error-container px-4 py-3 text-sm text-on-error-container">
      <svg class="mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01" stroke-linecap="round"/></svg>
      <span>{{ error }}</span>
    </div>
  {% endif %}

  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Name
      <input name="name" required maxlength="191" value="{{ category.name or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Slug (optional)
      <input name="slug" maxlength="191" value="{{ category.slug or '' }}" placeholder="auto from name" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Parent
      <select name="parentId" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0">
        <option value="">— none —</option>
        {% for p in parents %}
          <option value="{{ p.id }}" {% if category and category.parentId == p.id %}selected{% endif %}>{{ p.name }}</option>
        {% endfor %}
      </select>
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Description
      <textarea name="description" rows="3" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0">{{ category.description or '' }}</textarea>
    </label>
    <div class="mt-4 grid grid-cols-2 items-end gap-4">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Sort order
        <input name="sortOrder" type="number" step="1" value="{{ category.sortOrder or 0 }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" name="isActive" {% if category.isActive %}checked{% endif %} /> Active (visible)</label>
    </div>
  </div>

  {# ---- Cover image (shown in the home "Shop by Category" section) ---- #}
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6" x-data="{ preview: '' }">
    <p class="font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Cover image</p>
    <p class="mt-1 text-sm text-on-surface-variant">Shown on the homepage “Shop by Category” section. Landscape works best. Converted to WebP automatically.</p>
    <div class="mt-4 flex items-center gap-5">
      <div class="grid h-28 w-28 shrink-0 place-items-center overflow-hidden rounded-xl border border-outline/30 bg-surface">
        <template x-if="preview"><img :src="preview" alt="" class="h-full w-full object-cover" /></template>
        <template x-if="!preview">
          {% if category.imageUrl %}
            <img src="{{ category.imageUrl }}" alt="{{ category.name }}" class="h-full w-full object-cover" />
          {% else %}
            <svg class="h-8 w-8 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M3 17l5-5 4 4 3-3 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {% endif %}
        </template>
      </div>
      <div class="min-w-0">
        <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface transition-colors hover:border-primary hover:text-primary">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 16V4m0 0L8 8m4-4l4 4M4 20h16" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {{ 'Replace image' if category.imageUrl else 'Choose image' }}
          <input type="file" name="image" accept="image/jpeg,image/png,image/webp,image/avif" class="sr-only"
                 @change="const f=$event.target.files[0]; if(f){const r=new FileReader(); r.onload=e=>preview=e.target.result; r.readAsDataURL(f)}" />
        </label>
        <p class="mt-2 text-xs text-on-surface-variant">JPEG/PNG/WebP/AVIF · max 5 MB{% if category.imageUrl %} · leave empty to keep the current image{% endif %}</p>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <button type="submit" class="rounded bg-primary px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">
      {{ 'Save changes' if category.id else 'Create category' }}
    </button>
    <a href="/admin/categories" class="rounded border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface hover:border-primary hover:text-primary">Cancel</a>
  </div>
</form>
{% endblock %}
