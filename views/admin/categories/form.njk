{% extends "admin/layout.njk" %}

{% block content %}
{% set action = "/admin/categories/" + category.id if category else "/admin/categories" %}
<form action="{{ action }}" method="post" class="max-w-xl space-y-5">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
  <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
    <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Name
      <input name="name" required value="{{ category.name or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Slug (optional)
      <input name="slug" value="{{ category.slug or '' }}" placeholder="auto from name" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Parent
      <select name="parentId" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0">
        <option value="">— none —</option>
        {% for p in parents %}
          <option value="{{ p.id }}" {% if category and category.parentId == p.id %}selected{% endif %}>{{ p.name }}</option>
        {% endfor %}
      </select>
    </label>
    <label class="mt-4 block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Description
      <textarea name="description" rows="3" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0">{{ category.description or '' }}</textarea>
    </label>
    <div class="mt-4 grid grid-cols-2 items-end gap-4">
      <label class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Sort order
        <input name="sortOrder" type="number" value="{{ category.sortOrder or 0 }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-body-md text-on-surface focus:border-primary focus:ring-0" />
      </label>
      <label class="flex items-center gap-2 text-sm text-on-surface"><input type="checkbox" name="isActive" {% if category.isActive %}checked{% endif %} /> Active (visible)</label>
    </div>
  </div>
  <div class="flex gap-3">
    <button type="submit" class="rounded bg-primary px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-primary hover:bg-on-primary-fixed-variant">
      {{ 'Save changes' if category else 'Create category' }}
    </button>
    <a href="/admin/categories" class="rounded border border-outline px-4 py-2 font-label-md text-label-md uppercase tracking-widest text-on-surface hover:border-primary hover:text-primary">Cancel</a>
  </div>
</form>
{% endblock %}
