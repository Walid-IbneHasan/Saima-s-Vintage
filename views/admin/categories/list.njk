{% extends "admin/layout.njk" %}

{% block content %}
<div class="mb-4 flex items-center justify-between">
  <p class="text-sm text-stone-500">{{ categories.length }} category(ies)</p>
  <a href="/admin/categories/new" class="rounded bg-stone-900 px-4 py-2 text-sm text-white hover:bg-stone-700">New category</a>
</div>

<div class="overflow-x-auto rounded-lg bg-white shadow-sm">
  <table class="w-full text-left text-sm">
    <thead class="border-b border-stone-200 text-xs uppercase text-stone-500">
      <tr>
        <th class="px-4 py-3">Name</th>
        <th class="px-4 py-3">Parent</th>
        <th class="px-4 py-3">Products</th>
        <th class="px-4 py-3">Status</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      {% for c in categories %}
      <tr class="border-b border-stone-100">
        <td class="px-4 py-3">{{ c.name }} <span class="text-stone-400">/{{ c.slug }}</span></td>
        <td class="px-4 py-3 text-stone-500">{{ c.parent.name or '—' }}</td>
        <td class="px-4 py-3">{{ c._count.products }}</td>
        <td class="px-4 py-3">{% if c.isActive %}<span class="text-green-700">Active</span>{% else %}<span class="text-stone-400">Hidden</span>{% endif %}</td>
        <td class="px-4 py-3 text-right">
          <a href="/admin/categories/{{ c.id }}/edit" class="text-amber-700 hover:underline">Edit</a>
          <form action="/admin/categories/{{ c.id }}/delete" method="post" class="ml-3 inline"
                onsubmit="return confirm('Delete this category?')">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button class="text-red-600 hover:underline">Delete</button>
          </form>
        </td>
      </tr>
      {% else %}
      <tr><td colspan="5" class="px-4 py-8 text-center text-stone-400">No categories yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
