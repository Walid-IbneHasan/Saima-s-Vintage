{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-3xl px-4 py-12">
  <h1 class="font-serif text-3xl">My account</h1>
  {% if welcome %}<p class="mt-3 rounded bg-green-50 px-3 py-2 text-sm text-green-700">Welcome! Your email is verified.</p>{% endif %}
  {% if saved %}<p class="mt-3 rounded bg-green-50 px-3 py-2 text-sm text-green-700">Profile updated.</p>{% endif %}
  {% if pwSaved %}<p class="mt-3 rounded bg-green-50 px-3 py-2 text-sm text-green-700">Password updated.</p>{% endif %}

  <div class="mt-6 grid gap-6 md:grid-cols-3">
    {# Profile #}
    <form action="/account?_csrf={{ csrfToken }}" method="post" enctype="multipart/form-data" class="space-y-4 rounded-lg border border-stone-200 bg-white p-6 md:col-span-2">
      <h2 class="text-base font-medium">Profile details</h2>
      <div class="flex items-center gap-4">
        <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full bg-stone-200">
          {% if customer.imageUrl %}<img src="{{ customer.imageUrl }}" alt="{{ customer.name }}" class="h-full w-full object-cover" />{% endif %}
        </div>
        <label class="text-sm">Profile photo
          <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp,image/avif" class="mt-1 block text-sm" />
        </label>
      </div>
      <label class="block text-sm font-medium">Name
        <input name="name" required value="{{ customer.name }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <label class="block text-sm font-medium">Email
        <input value="{{ customer.email }}" disabled class="mt-1 w-full rounded border-stone-200 bg-stone-50 text-stone-500" />
        {% if customer.emailVerifiedAt %}<span class="mt-1 block text-xs text-green-700">✓ Verified</span>{% endif %}
      </label>
      <label class="block text-sm font-medium">Phone
        <input name="phone" value="{{ customer.phone or '' }}" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <div class="grid gap-3 md:grid-cols-2">
        <label class="block text-sm font-medium md:col-span-2">Address
          <input name="addressLine1" value="{{ address.line1 or '' }}" placeholder="House, road, area" class="mt-1 w-full rounded border-stone-300" />
        </label>
        <label class="block text-sm font-medium">City
          <input name="city" value="{{ address.city or '' }}" class="mt-1 w-full rounded border-stone-300" />
        </label>
        <label class="block text-sm font-medium">District
          <input name="district" value="{{ address.district or '' }}" class="mt-1 w-full rounded border-stone-300" />
        </label>
        <label class="block text-sm font-medium">Postal code
          <input name="postalCode" value="{{ address.postalCode or '' }}" class="mt-1 w-full rounded border-stone-300" />
        </label>
      </div>
      <button class="rounded-full bg-stone-900 px-6 py-2.5 text-sm text-white hover:bg-stone-700">Save changes</button>
    </form>

    {# Security #}
    <form action="/account/password" method="post" class="space-y-4 rounded-lg border border-stone-200 bg-white p-6">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <h2 class="text-base font-medium">{% if hasPassword %}Change password{% else %}Set a password{% endif %}</h2>
      {% if pwError %}<p class="rounded bg-red-50 px-3 py-2 text-sm text-red-700">{{ pwError }}</p>{% endif %}
      {% if not hasPassword %}<p class="text-xs text-stone-500">Your account uses Google sign-in. Set a password to also log in with email.</p>{% endif %}
      {% if hasPassword %}
        <label class="block text-sm font-medium">Current password
          <input name="currentPassword" type="password" required class="mt-1 w-full rounded border-stone-300" />
        </label>
      {% endif %}
      <label class="block text-sm font-medium">New password
        <input name="newPassword" type="password" required minlength="8" class="mt-1 w-full rounded border-stone-300" />
      </label>
      <button class="rounded-full border border-stone-300 px-6 py-2.5 text-sm hover:border-stone-400">Update password</button>
    </form>
  </div>
</div>
{% endblock %}
