{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-3xl px-margin-mobile py-16 md:px-margin-desktop">
  <h1 class="font-display-lg text-headline-lg text-on-surface">My account</h1>
  {% if welcome %}<p class="mt-3 rounded bg-secondary-container/40 px-4 py-3 text-sm text-on-surface">Welcome! Your email is verified.</p>{% endif %}
  {% if saved %}<p class="mt-3 rounded bg-secondary-container/40 px-4 py-3 text-sm text-on-surface">Profile updated.</p>{% endif %}
  {% if pwSaved %}<p class="mt-3 rounded bg-secondary-container/40 px-4 py-3 text-sm text-on-surface">Password updated.</p>{% endif %}

  <div class="mt-6 grid gap-6 md:grid-cols-3">
    {# Profile #}
    <form action="/account?_csrf={{ csrfToken }}" method="post" enctype="multipart/form-data" class="space-y-4 rounded-lg border border-outline/10 bg-surface-container-lowest p-6 md:col-span-2">
      <h2 class="font-headline-md text-headline-md text-on-surface">Profile details</h2>
      <div class="flex items-center gap-4">
        <div class="h-16 w-16 shrink-0 overflow-hidden rounded-full bg-surface-container">
          {% if customer.imageUrl %}<img src="{{ customer.imageUrl }}" alt="{{ customer.name }}" class="h-full w-full object-cover" />{% endif %}
        </div>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Profile photo</span>
          <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp,image/avif" class="mt-1 block text-sm text-on-surface-variant" />
        </label>
      </div>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Name</span>
        <input name="name" required value="{{ customer.name }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Email</span>
        <input value="{{ customer.email }}" disabled class="mt-1 w-full rounded border border-outline/20 bg-surface-container px-3 py-2.5 text-body-md text-on-surface-variant" />
        {% if customer.emailVerifiedAt %}<span class="mt-1 block text-xs text-on-surface-variant">✓ Verified</span>{% endif %}
      </label>
      <label class="block">
        <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Phone</span>
        <input name="phone" value="{{ customer.phone or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
      </label>
      <div class="grid gap-3 md:grid-cols-2">
        <label class="block md:col-span-2">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Address</span>
          <input name="addressLine1" value="{{ address.line1 or '' }}" placeholder="House, road, area" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">City</span>
          <input name="city" value="{{ address.city or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">District</span>
          <input name="district" value="{{ address.district or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Postal code</span>
          <input name="postalCode" value="{{ address.postalCode or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
      </div>
      <button class="rounded bg-primary px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Save changes</button>
    </form>

    {# Security — password change is a two-step, email-OTP-verified flow. #}
    <form action="{% if pwOtpStage == 'confirm' %}/account/password{% else %}/account/password/request{% endif %}" method="post" class="space-y-4 rounded-lg border border-outline/10 bg-surface-container-lowest p-6">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
      <h2 class="font-headline-md text-headline-md text-on-surface">{% if hasPassword %}Change password{% else %}Set a password{% endif %}</h2>
      {% if pwError %}<p class="rounded bg-error-container px-4 py-3 text-sm text-on-error-container">{{ pwError }}</p>{% endif %}
      {% if not hasPassword %}<p class="text-xs text-on-surface-variant">Your account uses Google sign-in. Set a password to also log in with email.</p>{% endif %}
      {% if pwOtpStage == 'confirm' and pwSent %}
        <p class="rounded bg-secondary-container/40 px-4 py-3 text-sm text-on-surface">We sent a 6-digit code to <strong>{{ customer.email }}</strong>. Enter it below to confirm — it expires in 10 minutes.</p>
      {% endif %}

      {% if hasPassword %}
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Current password</span>
          <input name="currentPassword" type="password" required autocomplete="current-password" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
      {% endif %}

      {% if pwOtpStage == 'confirm' %}
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">New password</span>
          <input name="newPassword" type="password" required minlength="8" autocomplete="new-password" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
        <label class="block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Verification code</span>
          <input name="code" inputmode="numeric" maxlength="6" required autocomplete="one-time-code" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md tracking-[0.4em] text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
        </label>
        <div class="flex flex-wrap items-center gap-4">
          <button class="rounded bg-primary px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Confirm change</button>
          <button type="submit" formaction="/account/password/request" formnovalidate class="font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant transition-colors hover:text-primary">Resend code</button>
        </div>
      {% else %}
        <button class="rounded border border-outline/30 px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-surface transition-colors hover:border-primary">Send verification code</button>
      {% endif %}
    </form>
  </div>
</div>
{% endblock %}
