{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-14 md:px-margin-desktop md:py-20">
  <div class="flex flex-col gap-2">
    <p class="eyebrow text-accent-deep">Your selection</p>
    <h1 class="font-display-lg text-[2.25rem] leading-tight text-on-surface md:text-headline-lg">Your cart</h1>
  </div>

  {% if cart.items.length %}
    <div class="mt-10 grid gap-10 lg:grid-cols-12 lg:gap-12">
      {# Items #}
      <div class="space-y-4 lg:col-span-7 xl:col-span-8">
        {% for item in cart.items %}
          <div class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-5 shadow-luxe">
            <div class="flex items-start gap-5">
              <a href="/p/{{ item.productSlug }}" class="h-24 w-24 shrink-0 overflow-hidden rounded-xl border border-outline/20 bg-surface-container-low">
                {% if item.image %}<img src="{{ item.image.url }}" alt="{{ item.image.alt or item.productName }}" class="h-full w-full object-cover" />{% endif %}
              </a>
              <div class="min-w-0 flex-1">
                <a href="/p/{{ item.productSlug }}" class="font-headline-sm text-lg text-on-surface transition-colors hover:text-accent-deep">{{ item.productName }}</a>
                {% if item.variant %}
                  <p class="mt-0.5 inline-flex items-center gap-1.5 text-sm text-on-surface-variant">
                    {% if item.color %}<span class="h-3 w-3 shrink-0 rounded-full border border-outline/40" style="background-color: {{ item.color }}" aria-hidden="true"></span>{% endif %}
                    {{ item.variant }}
                  </p>
                {% endif %}
                <p class="mt-1.5 flex flex-wrap items-center gap-2 text-sm">
                  <span class="text-on-surface">{{ item.unitPrice | money(cart.currency) }}</span>
                  {% if item.onSale %}<span class="text-on-surface-variant line-through">{{ item.regularPrice | money(cart.currency) }}</span>{% endif %}
                </p>
                {% if not item.allowBackorder and item.stock <= 0 %}
                  <p class="mt-1 inline-flex items-center gap-1.5 text-xs font-medium text-error"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01" stroke-linecap="round"/></svg>No longer in stock</p>
                {% endif %}
              </div>
              <div class="shrink-0 text-right font-headline-sm text-lg text-on-surface">{{ item.lineTotal | money }}</div>
            </div>
            <div class="mt-4 flex flex-wrap items-center gap-3 border-t border-outline/30 pt-4">
              <form action="/cart/items/{{ item.id }}" method="post" class="flex items-center gap-2">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                <label for="qty-{{ item.id }}" class="font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Qty</label>
                <input id="qty-{{ item.id }}" type="number" name="quantity" value="{{ item.quantity }}" min="0"
                       class="w-16 rounded-lg border border-outline bg-surface-container-lowest px-3 py-2 text-sm text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
                <button class="rounded-full border border-outline px-4 py-2 font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface transition-colors hover:border-accent hover:text-accent-deep">Update</button>
              </form>
              <form action="/cart/items/{{ item.id }}/delete" method="post" class="ml-auto">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
                <button class="inline-flex items-center gap-1.5 text-sm text-on-surface-variant transition-colors hover:text-error">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 7h16M9 7V5a1 1 0 011-1h4a1 1 0 011 1v2M6 7l1 13h10l1-13" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Remove
                </button>
              </form>
            </div>
          </div>
        {% endfor %}

        <a href="/products" class="link-underline inline-flex items-center gap-2 pt-2 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface-variant transition-colors hover:text-accent-deep">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Continue shopping
        </a>
      </div>

      {# Summary (sticky) #}
      <div class="lg:col-span-5 xl:col-span-4">
        <div class="lg:sticky lg:top-28 rounded-2xl border border-outline/30 bg-surface-container-lowest p-7 shadow-luxe">
          <h2 class="font-headline-md text-xl text-on-surface">Order summary</h2>
          <dl class="mt-5 space-y-3 text-sm">
            <div class="flex items-center justify-between">
              <dt class="text-on-surface-variant">Subtotal</dt>
              <dd class="text-on-surface">{{ cart.subtotal | money }}</dd>
            </div>
            <div class="flex items-center justify-between">
              <dt class="text-on-surface-variant">Shipping</dt>
              <dd class="text-on-surface-variant">Calculated at checkout</dd>
            </div>
          </dl>
          <div class="mt-5 flex items-baseline justify-between border-t border-outline/30 pt-5">
            <span class="font-label-md text-label-md uppercase tracking-[0.12em] text-on-surface">Total</span>
            <span class="font-display-lg text-2xl text-primary">{{ cart.subtotal | money }}</span>
          </div>
          <a href="/checkout" class="mt-6 flex w-full items-center justify-center gap-2.5 rounded-full bg-primary px-8 py-3.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">
            Proceed to checkout
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <p class="mt-4 flex items-center justify-center gap-2 text-xs text-on-surface-variant">
            <svg class="h-4 w-4 text-accent-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 018 0v3" stroke-linecap="round"/></svg>
            Secure checkout · Complimentary gift wrapping
          </p>
        </div>
      </div>
    </div>
  {% else %}
    <div class="mt-12 grid place-items-center rounded-2xl border border-dashed border-outline/50 bg-surface-container-low/40 py-24 text-center">
      <svg class="h-12 w-12 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path d="M6 7h12l-1 13H7L6 7z" stroke-linejoin="round"/><path d="M9 7a3 3 0 016 0" stroke-linecap="round"/></svg>
      <p class="mt-5 font-headline-sm text-xl text-on-surface">Your cart is empty</p>
      <p class="mt-2 text-on-surface-variant">Discover one-of-a-kind heritage pieces, waiting for a new home.</p>
      <a href="/products" class="mt-7 inline-flex items-center justify-center gap-2.5 rounded-full bg-primary px-8 py-3.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">Browse the collection</a>
    </div>
  {% endif %}
</div>
{% endblock %}
