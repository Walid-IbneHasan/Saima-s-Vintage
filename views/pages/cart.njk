{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-4xl px-4 py-10">
  <h1 class="font-serif text-3xl">Your cart</h1>

  {% if cart.items.length %}
    <div class="mt-8 space-y-4">
      {% for item in cart.items %}
        <div class="flex items-center gap-4 rounded-lg border border-stone-200 bg-white p-4">
          <a href="/p/{{ item.productSlug }}" class="h-20 w-20 shrink-0 overflow-hidden rounded bg-stone-200">
            {% if item.image %}<img src="{{ item.image.url }}" alt="{{ item.image.alt or item.productName }}" class="h-full w-full object-cover" />{% endif %}
          </a>
          <div class="flex-1">
            <a href="/p/{{ item.productSlug }}" class="font-medium hover:text-amber-700">{{ item.productName }}</a>
            <p class="text-sm text-stone-500">{{ item.variantName }}</p>
            <p class="flex flex-wrap items-center gap-2 text-sm">
              <span>{{ item.unitPrice | money(cart.currency) }}</span>
              {% if item.onSale %}
                <span class="text-stone-400 line-through">{{ item.regularPrice | money(cart.currency) }}</span>
              {% endif %}
            </p>
            {% if not item.allowBackorder and item.stock <= 0 %}
              <p class="text-xs text-red-600">No longer in stock</p>
            {% endif %}
          </div>
          <form action="/cart/items/{{ item.id }}" method="post" class="flex items-center gap-2">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <input type="number" name="quantity" value="{{ item.quantity }}" min="0"
                   class="w-16 rounded border-stone-300 text-sm" />
            <button class="rounded border border-stone-300 px-3 py-1.5 text-sm hover:border-stone-400">Update</button>
          </form>
          <div class="w-24 text-right font-medium">{{ item.lineTotal | money }}</div>
          <form action="/cart/items/{{ item.id }}/delete" method="post">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <button class="text-sm text-red-600 hover:underline">Remove</button>
          </form>
        </div>
      {% endfor %}
    </div>

    <div class="mt-8 flex items-center justify-between border-t border-stone-200 pt-6">
      <a href="/search" class="text-sm text-stone-500 hover:text-amber-700">← Continue shopping</a>
      <div class="text-right">
        <p class="text-sm text-stone-500">Subtotal</p>
        <p class="text-2xl">{{ cart.subtotal | money }}</p>
        <a href="/checkout" class="mt-3 inline-block rounded-full bg-stone-900 px-8 py-3 text-sm text-white hover:bg-stone-700">
          Checkout
        </a>
      </div>
    </div>
  {% else %}
    <p class="mt-8 text-stone-500">Your cart is empty.</p>
    <a href="/search" class="mt-4 inline-block rounded-full bg-stone-900 px-6 py-3 text-sm text-white">Browse the collection</a>
  {% endif %}
</div>
{% endblock %}
