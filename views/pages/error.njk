{% extends "layouts/base.njk" %}

{% block content %}
<section class="mx-auto flex max-w-xl flex-col items-center px-margin-mobile py-24 text-center md:px-margin-desktop">
  <p class="font-display-lg text-headline-lg text-on-surface-variant/40">{{ status }}</p>
  <h1 class="mt-4 font-headline-md text-headline-md text-on-surface">{{ message }}</h1>
  <a href="/" class="mt-10 inline-flex items-center justify-center rounded bg-primary px-8 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Back to home</a>
</section>
{% endblock %}
