{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-12 md:px-margin-desktop md:py-16">
  <nav class="mb-6 text-sm text-on-surface-variant">
    <a href="/" class="hover:text-primary">Home</a>
    {% for c in product.categories %}
      / <a href="/c/{{ c.category.slug }}" class="hover:text-primary">{{ c.category.name }}</a>
    {% endfor %}
  </nav>

  <div class="grid gap-10 md:grid-cols-2 lg:gap-16">
    {# Gallery: click a thumbnail to swap the main image (Alpine); the main image
       links to the full-size file. No-JS: main shows the first image and each
       thumbnail is a real link that opens the full image in a new tab. #}
    <div x-data="{ sel: '', pick(u) { this.sel = u; this.$refs.main.src = u; this.$refs.mainlink.href = u; } }"
         x-init="sel = $refs.main ? $refs.main.src : ''">
      <a x-ref="mainlink" href="{% if product.images.length %}{{ product.images[0].url }}{% else %}#{% endif %}"
         {% if product.images.length %}target="_blank" rel="noopener"{% endif %}
         class="block aspect-[4/5] overflow-hidden rounded-lg bg-surface-container-low ambient-shadow">
        {% if product.images.length %}
          <img x-ref="main" src="{{ product.images[0].url }}" alt="{{ product.images[0].alt or product.name }}"
               {% if product.images[0].width %}width="{{ product.images[0].width }}" height="{{ product.images[0].height }}"{% endif %}
               class="h-full w-full object-cover" />
        {% else %}
          <div class="flex h-full w-full items-center justify-center">
            <p class="font-label-md text-label-md uppercase tracking-widest text-on-surface-variant">No image available</p>
          </div>
        {% endif %}
      </a>
      {% if product.images.length > 1 %}
        <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-4">
          {% for img in product.images %}
            <a href="{{ img.url }}" target="_blank" rel="noopener"
               @click.prevent="pick($el.href)"
               :class="sel === $el.href ? 'ring-2 ring-primary ring-offset-2 ring-offset-surface' : 'opacity-80 hover:opacity-100'"
               class="block aspect-square overflow-hidden rounded bg-surface-container-low transition"
               aria-label="View image {{ loop.index }}">
              <img src="{{ img.url }}" alt="{{ img.alt or product.name }}" loading="lazy" class="h-full w-full object-cover" />
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div>
      <h1 class="font-display-lg text-headline-lg leading-tight text-on-surface">{{ product.name }}</h1>
      {% if reviewStats.count %}
        {% set filledStars = reviewStats.average | round | int %}
        <a href="#reviews" class="mt-2 inline-flex items-center gap-2 text-sm text-on-surface-variant transition-colors hover:text-primary">
          <span class="text-primary" aria-hidden="true">{% for i in range(0, filledStars) %}★{% endfor %}<span class="text-outline-variant">{% for i in range(filledStars, 5) %}★{% endfor %}</span></span>
          <span>{{ reviewStats.average }} · {{ reviewStats.count }} review{% if reviewStats.count != 1 %}s{% endif %}</span>
        </a>
      {% endif %}
      {% if product.brand or product.condition %}
        <p class="mt-2 font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">
          {% if product.brand %}{{ product.brand }}{% endif %}
          {% if product.brand and product.condition %} · {% endif %}
          {% if product.condition %}Condition: {{ product.condition }}{% endif %}
        </p>
      {% endif %}

      <div class="mt-4 flex flex-wrap items-center gap-3">
        <p class="font-headline-md text-headline-md text-primary">{{ pricing.current | money(product.currency) }}</p>
        {% if pricing.onSale %}
          <p class="text-lg text-on-surface-variant line-through">{{ pricing.regular | money(product.currency) }}</p>
          <span class="rounded-full bg-primary-container px-3 py-1 font-label-md text-label-md uppercase tracking-wider text-on-primary-container">-{{ pricing.discountPercent }}% off</span>
        {% endif %}
      </div>
      {% if product.shortDescription %}
        <p class="mt-4 text-body-lg text-on-surface-variant">{{ product.shortDescription }}</p>
      {% endif %}

      <form action="/cart/items" method="post" class="mt-6 space-y-4">
        {% if csrfToken %}<input type="hidden" name="_csrf" value="{{ csrfToken }}" />{% endif %}
        {% if product.variants.length > 1 %}
          <div>
            <label for="variantId" class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Option</label>
            <select id="variantId" name="variantId" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0">
              {% for v in product.variants %}
                <option value="{{ v.id }}" {% if v.stock <= 0 %}disabled{% endif %}>
                  {{ v.name }}{% if v.stock <= 0 %} — sold out{% endif %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% elif product.variants.length == 1 %}
          <input type="hidden" name="variantId" value="{{ product.variants[0].id }}" />
        {% endif %}
        <div>
          <label for="quantity" class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Quantity</label>
          <input id="quantity" type="number" name="quantity" value="1" min="1"
                 class="mt-1 w-24 rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-2 focus:ring-primary/30" />
        </div>
        <button type="submit" {% if not inStock %}disabled{% endif %}
                class="w-full rounded bg-primary px-6 py-3.5 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant disabled:cursor-not-allowed disabled:bg-surface-container-high disabled:text-on-surface-variant">
          {% if inStock %}Add to cart{% else %}Sold out{% endif %}
        </button>
      </form>

      {% if product.description %}
        {# Rich text is sanitized on admin write (Phase 1 admin), so `safe` is OK here. #}
        <div class="prose mt-8 max-w-none text-on-surface-variant">{{ product.description | safe }}</div>
      {% endif %}
    </div>
  </div>

  <section id="reviews" class="mt-16 border-t border-outline/20 pt-10">
    <h2 class="font-display-lg text-headline-md text-on-surface">Reviews</h2>

    {% if reviewError %}<p class="mt-3 rounded bg-error-container px-4 py-3 text-sm text-on-error-container">{{ reviewError }}</p>{% endif %}

    {% if canReview and not hasReviewed %}
      <form action="/p/{{ product.slug }}/reviews" method="post" class="mt-4 max-w-lg space-y-3 rounded-lg border border-outline/10 bg-surface-container-low p-5">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <p class="font-label-md text-label-md uppercase tracking-widest text-on-surface">Write a review</p>
        <label class="block text-sm text-on-surface-variant">Rating
          <select name="rating" class="mt-1 block w-40 rounded border border-outline/30 bg-surface px-3 py-2 text-on-surface focus:border-primary focus:ring-0">
            <option value="5">★★★★★ (5)</option>
            <option value="4">★★★★ (4)</option>
            <option value="3">★★★ (3)</option>
            <option value="2">★★ (2)</option>
            <option value="1">★ (1)</option>
          </select>
        </label>
        <label class="block text-sm text-on-surface-variant">Title (optional)
          <input name="title" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-on-surface focus:border-primary focus:ring-0" />
        </label>
        <label class="block text-sm text-on-surface-variant">Your review
          <textarea name="body" rows="3" required class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2 text-on-surface focus:border-primary focus:ring-0"></textarea>
        </label>
        <button class="rounded bg-primary px-5 py-2.5 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Submit review</button>
      </form>
    {% elif currentCustomer and hasReviewed %}
      <p class="mt-3 text-sm text-on-surface-variant">You've already reviewed this product. Thank you!</p>
    {% elif currentCustomer and not canReview %}
      <p class="mt-3 text-sm text-on-surface-variant">Only verified purchasers can review this product.</p>
    {% elif not currentCustomer %}
      <p class="mt-3 text-sm text-on-surface-variant"><a href="/login" class="text-primary hover:underline">Log in</a> to review products you've purchased.</p>
    {% endif %}

    {% if reviewStats.count %}
      <p class="mt-4 text-sm text-on-surface-variant">
        <span class="text-primary">★</span> {{ reviewStats.average }} · {{ reviewStats.count }} review{% if reviewStats.count != 1 %}s{% endif %}
      </p>
      <div class="mt-6 max-w-2xl space-y-5">
        {% for r in product.reviews %}
          <div class="border-b border-outline/10 pb-4">
            <div class="flex items-center gap-2">
              <span class="text-primary">{% for i in range(0, r.rating) %}★{% endfor %}<span class="text-outline-variant">{% for i in range(r.rating, 5) %}★{% endfor %}</span></span>
              {% if r.title %}<span class="font-medium text-on-surface">{{ r.title }}</span>{% endif %}
            </div>
            <p class="mt-1 text-sm text-on-surface-variant">{{ r.body }}</p>
            <p class="mt-1 text-xs text-on-surface-variant/70">— {{ r.authorName }}</p>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="mt-2 text-on-surface-variant">No reviews yet.</p>
    {% endif %}
  </section>
</div>
{% endblock %}
