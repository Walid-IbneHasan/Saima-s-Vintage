{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-6xl px-4 py-10">
  <nav class="mb-6 text-sm text-stone-500">
    <a href="/" class="hover:text-amber-700">Home</a>
    {% for c in product.categories %}
      / <a href="/c/{{ c.category.slug }}" class="hover:text-amber-700">{{ c.category.name }}</a>
    {% endfor %}
  </nav>

  <div class="grid gap-10 md:grid-cols-2">
    <div>
      <div class="aspect-[4/5] overflow-hidden rounded-xl bg-stone-200">
        {% if product.images.length %}
          <img src="{{ product.images[0].url }}" alt="{{ product.images[0].alt or product.name }}"
               class="h-full w-full object-cover" />
        {% endif %}
      </div>
      {% if product.images.length > 1 %}
        <div class="mt-3 grid grid-cols-4 gap-2">
          {% for img in product.images %}
            <div class="aspect-square overflow-hidden rounded bg-stone-200">
              <img src="{{ img.url }}" alt="{{ img.alt or product.name }}" loading="lazy" class="h-full w-full object-cover" />
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div>
      <h1 class="font-serif text-3xl">{{ product.name }}</h1>
      {% if product.brand or product.condition %}
        <p class="mt-1 text-sm text-stone-500">
          {% if product.brand %}{{ product.brand }}{% endif %}
          {% if product.brand and product.condition %} · {% endif %}
          {% if product.condition %}Condition: {{ product.condition }}{% endif %}
        </p>
      {% endif %}

      <div class="mt-4 flex flex-wrap items-center gap-3">
        <p class="text-2xl">{{ pricing.current | money(product.currency) }}</p>
        {% if pricing.onSale %}
          <p class="text-lg text-stone-400 line-through">{{ pricing.regular | money(product.currency) }}</p>
          <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-medium text-amber-800">-{{ pricing.discountPercent }}% off</span>
        {% endif %}
      </div>
      {% if product.shortDescription %}
        <p class="mt-4 text-stone-600">{{ product.shortDescription }}</p>
      {% endif %}

      <form action="/cart/items" method="post" class="mt-6 space-y-4">
        {% if csrfToken %}<input type="hidden" name="_csrf" value="{{ csrfToken }}" />{% endif %}
        {% if product.variants.length > 1 %}
          <div>
            <label for="variantId" class="block text-sm font-medium">Option</label>
            <select id="variantId" name="variantId" class="mt-1 w-full rounded border-stone-300">
              {% for v in product.variants %}
                <option value="{{ v.id }}" {% if v.stock <= 0 %}disabled{% endif %}>
                  {{ v.name }}{% if v.stock <= 0 %} — sold out{% endif %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% elif product.variants.length == 1 %}
          <input type="hidden" name="variantId" value="{{ product.variants[0].id }}" />
        {% endif %}
        <input type="hidden" name="quantity" value="1" />
        <button type="submit" {% if not inStock %}disabled{% endif %}
                class="w-full rounded-full bg-stone-900 px-6 py-3 text-white hover:bg-stone-700 disabled:cursor-not-allowed disabled:bg-stone-300">
          {% if inStock %}Add to cart{% else %}Sold out{% endif %}
        </button>
      </form>

      {% if product.description %}
        {# Rich text is sanitized on admin write (Phase 1 admin), so `safe` is OK here. #}
        <div class="prose mt-8 max-w-none text-stone-700">{{ product.description | safe }}</div>
      {% endif %}
    </div>
  </div>

  <section id="reviews" class="mt-14 border-t border-stone-200 pt-8">
    <h2 class="font-serif text-2xl">Reviews</h2>

    {% if reviewError %}<p class="mt-3 rounded bg-red-50 px-3 py-2 text-sm text-red-700">{{ reviewError }}</p>{% endif %}

    {% if canReview and not hasReviewed %}
      <form action="/p/{{ product.slug }}/reviews" method="post" class="mt-4 max-w-lg space-y-3 rounded-lg border border-stone-200 bg-stone-50 p-4">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <p class="text-sm font-medium">Write a review</p>
        <label class="block text-sm">Rating
          <select name="rating" class="mt-1 block w-40 rounded border-stone-300">
            <option value="5">★★★★★ (5)</option>
            <option value="4">★★★★ (4)</option>
            <option value="3">★★★ (3)</option>
            <option value="2">★★ (2)</option>
            <option value="1">★ (1)</option>
          </select>
        </label>
        <label class="block text-sm">Title (optional)
          <input name="title" class="mt-1 w-full rounded border-stone-300" />
        </label>
        <label class="block text-sm">Your review
          <textarea name="body" rows="3" required class="mt-1 w-full rounded border-stone-300"></textarea>
        </label>
        <button class="rounded-full bg-stone-900 px-5 py-2 text-sm text-white hover:bg-stone-700">Submit review</button>
      </form>
    {% elif currentCustomer and hasReviewed %}
      <p class="mt-3 text-sm text-stone-500">You've already reviewed this product. Thank you!</p>
    {% elif currentCustomer and not canReview %}
      <p class="mt-3 text-sm text-stone-400">Only verified purchasers can review this product.</p>
    {% elif not currentCustomer %}
      <p class="mt-3 text-sm text-stone-400"><a href="/login" class="text-amber-700 hover:underline">Log in</a> to review products you've purchased.</p>
    {% endif %}

    {% if reviewStats.count %}
      <p class="mt-1 text-sm text-stone-500">
        <span class="text-amber-600">★</span> {{ reviewStats.average }} · {{ reviewStats.count }} review{% if reviewStats.count != 1 %}s{% endif %}
      </p>
      <div class="mt-6 max-w-2xl space-y-5">
        {% for r in product.reviews %}
          <div class="border-b border-stone-100 pb-4">
            <div class="flex items-center gap-2">
              <span class="text-amber-600">{% for i in range(0, r.rating) %}★{% endfor %}<span class="text-stone-300">{% for i in range(r.rating, 5) %}★{% endfor %}</span></span>
              {% if r.title %}<span class="font-medium">{{ r.title }}</span>{% endif %}
            </div>
            <p class="mt-1 text-sm text-stone-600">{{ r.body }}</p>
            <p class="mt-1 text-xs text-stone-400">— {{ r.authorName }}</p>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p class="mt-2 text-stone-500">No reviews yet.</p>
    {% endif %}
  </section>
</div>
{% endblock %}
