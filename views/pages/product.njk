{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-10 md:px-margin-desktop md:py-14">
  <nav aria-label="Breadcrumb" class="mb-8 text-sm text-on-surface-variant">
    <ol class="flex flex-wrap items-center gap-1.5">
      <li><a href="/" class="transition-colors hover:text-accent-deep">Home</a></li>
      {% for c in product.categories %}
        <li aria-hidden="true" class="text-on-surface-variant/50">/</li>
        <li><a href="/c/{{ c.category.slug }}" class="transition-colors hover:text-accent-deep">{{ c.category.name }}</a></li>
      {% endfor %}
      <li aria-hidden="true" class="text-on-surface-variant/50">/</li>
      <li><span class="text-on-surface" aria-current="page">{{ product.name }}</span></li>
    </ol>
  </nav>

  <div class="grid gap-10 lg:grid-cols-2 lg:gap-16"
       x-data="{
         variants: {{ variantsJson }},
         gallery: {{ galleryJson }},
         sel: {{ initialVariant }},
         mainImg: '{{ initialImage }}',
         get v() { return this.variants[this.sel] || null },
         pickVariant(i) { this.sel = i; const v = this.variants[i]; this.mainImg = (v && v.image) || this.gallery[0] || this.mainImg; if (v) { const p = new URLSearchParams(); p.set('variant', v.id); if (v.size) p.set('size', v.size); if (v.color) p.set('color', v.color); history.replaceState(null, '', location.pathname + '?' + p.toString()); } },
         pickThumb(u) { this.mainImg = u }
       }">
    {# ── Gallery (sticky on desktop) ──────────────────────────────────────
       The main image follows the selected variant (or a clicked thumbnail).
       No-JS: shows the initial image; thumbnails open the full file in a tab. #}
    <div class="lg:sticky lg:top-28 lg:self-start">
      <a href="{% if initialImage %}{{ initialImage }}{% else %}#{% endif %}" :href="mainImg || '#'"
         {% if initialImage %}target="_blank" rel="noopener"{% endif %}
         class="group block aspect-[4/5] overflow-hidden rounded-2xl border border-outline/20 bg-surface-container-low shadow-luxe-lg">
        {% if initialImage %}
          <img src="{{ initialImage }}" :src="mainImg" alt="{{ product.name }}"
               class="h-full w-full object-cover transition-transform duration-[900ms] ease-lux group-hover:scale-[1.04]" />
        {% else %}
          <div class="grid h-full w-full place-items-center">
            <p class="font-label-md text-label-md uppercase tracking-[0.2em] text-on-surface-variant">No image available</p>
          </div>
        {% endif %}
      </a>
      {% if product.images.length > 1 %}
        <div class="mt-4 grid grid-cols-4 gap-3 sm:grid-cols-5">
          {% for img in product.images %}
            <a href="{{ img.url }}" target="_blank" rel="noopener"
               @click.prevent="pickThumb('{{ img.url }}')"
               :class="mainImg === '{{ img.url }}' ? 'ring-2 ring-accent ring-offset-2 ring-offset-background' : 'opacity-75 hover:opacity-100'"
               class="block aspect-square overflow-hidden rounded-lg border border-outline/20 bg-surface-container-low transition"
               aria-label="View image {{ loop.index }}">
              <img src="{{ img.url }}" alt="{{ img.alt or product.name }}" loading="lazy" class="h-full w-full object-cover" />
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# ── Buying panel ─────────────────────────────────────────────────────── #}
    <div class="flex flex-col">
      {% if product.categories.length %}
        <p class="font-label-sm text-[11px] uppercase tracking-[0.22em] text-accent-deep">{{ product.categories[0].category.name }}</p>
      {% endif %}
      <h1 class="mt-2.5 font-display-lg text-[2.25rem] leading-[1.08] text-on-surface text-balance md:text-headline-lg">{{ product.name }}</h1>

      {% if reviewStats.count %}
        {% set filledStars = reviewStats.average | round | int %}
        <a href="#reviews" class="mt-3 inline-flex items-center gap-2 text-sm text-on-surface-variant transition-colors hover:text-accent-deep">
          <span class="text-accent" aria-hidden="true">{% for i in range(0, filledStars) %}★{% endfor %}<span class="text-outline">{% for i in range(filledStars, 5) %}★{% endfor %}</span></span>
          <span>{{ reviewStats.average }} · {{ reviewStats.count }} review{% if reviewStats.count != 1 %}s{% endif %}</span>
        </a>
      {% endif %}

      <div class="mt-5 flex flex-wrap items-center gap-3">
        <p class="font-display-lg text-3xl text-primary" x-text="v ? v.currentFmt : '{{ pricing.current | money(product.currency) }}'">{{ pricing.current | money(product.currency) }}</p>
        <template x-if="v && v.onSale">
          <p class="text-lg text-on-surface-variant line-through" x-text="v.regularFmt"></p>
        </template>
        <template x-if="v && v.onSale">
          <span class="rounded-full bg-primary-container px-3 py-1 font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-primary-container" x-text="'−' + v.discount + '% off'"></span>
        </template>
      </div>

      {# Stock status for the selected option. #}
      <p class="mt-3 inline-flex items-center gap-1.5 text-sm" x-show="v" x-cloak>
        <span x-show="v && v.stock > 5" class="inline-flex items-center gap-1.5 text-on-surface-variant"><span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>In stock</span>
        <span x-show="v && v.stock > 0 && v.stock <= 5" class="inline-flex items-center gap-1.5 font-medium text-accent-deep"><span class="h-1.5 w-1.5 rounded-full bg-accent"></span>Only <span x-text="v && v.stock"></span> left</span>
        <span x-show="v && v.stock <= 0" class="font-medium text-error">Sold out</span>
      </p>

      {% if flashEndsAtMs %}
        {# Flash-deal countdown — progressive enhancement (JS only). The discount
           is server-evaluated, so once it expires a refresh drops the deal. #}
        <div x-data="{
               end: {{ flashEndsAtMs }},
               now: Date.now(),
               get left() { return Math.max(0, this.end - this.now); },
               get d() { return Math.floor(this.left / 86400000); },
               get h() { return Math.floor(this.left % 86400000 / 3600000); },
               get m() { return Math.floor(this.left % 3600000 / 60000); },
               get s() { return Math.floor(this.left % 60000 / 1000); },
               pad(n) { return String(n).padStart(2, '0'); }
             }"
             x-init="setInterval(() => now = Date.now(), 1000)"
             x-show="left > 0" x-cloak
             class="mt-5 inline-flex flex-wrap items-center gap-x-3 gap-y-1 rounded-full border border-accent/40 bg-accent/10 px-4 py-2">
          <span class="inline-flex items-center gap-1.5 font-label-sm text-label-sm uppercase tracking-[0.12em] text-accent-deep">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2L4.5 13.5H11l-1 8.5 8.5-11.5H12l1-8.5z"/></svg>
            Flash deal ends in
          </span>
          <span class="text-sm font-semibold tabular-nums text-on-surface">
            <template x-if="d > 0"><span><span x-text="d"></span>d </span></template><span x-text="pad(h)"></span>:<span x-text="pad(m)"></span>:<span x-text="pad(s)"></span>
          </span>
        </div>
      {% endif %}

      {# Provenance trust chip. #}
      <p class="mt-5 inline-flex w-fit items-center gap-2 rounded-full border border-accent/30 bg-accent/5 px-4 py-1.5 font-label-sm text-label-sm uppercase tracking-[0.12em] text-accent-deep">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 7l8-4 8 4v6c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V7z" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Restored &amp; authenticated
      </p>

      {% if product.shortDescription %}
        <p class="mt-6 max-w-prose text-body-lg text-on-surface-variant">{{ product.shortDescription }}</p>
      {% endif %}

      <form action="/cart/items" method="post" class="mt-8 space-y-5">
        {% if csrfToken %}<input type="hidden" name="_csrf" value="{{ csrfToken }}" />{% endif %}
        {% if product.variants.length > 1 %}
          <fieldset>
            <legend class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">
              Option<span x-show="v" x-cloak class="lowercase tracking-normal text-on-surface"> — <span class="font-medium" x-text="v && v.name"></span></span>
            </legend>
            <div class="mt-2.5 flex flex-wrap gap-2.5">
              {% for v in product.variants %}
                <label class="cursor-pointer">
                  <input type="radio" name="variantId" value="{{ v.id }}" class="peer sr-only"
                         {% if loop.index0 == initialVariant %}checked{% endif %}
                         {% if v.stock <= 0 %}disabled{% endif %}
                         @change="pickVariant({{ loop.index0 }})" />
                  <span class="inline-flex min-h-[44px] items-center gap-2 rounded-full border border-outline px-4 py-2 text-sm font-medium text-on-surface transition hover:border-accent-deep peer-checked:border-accent peer-checked:bg-accent/10 peer-checked:text-accent-deep peer-checked:ring-1 peer-checked:ring-accent peer-focus-visible:ring-2 peer-focus-visible:ring-accent peer-disabled:cursor-not-allowed peer-disabled:text-on-surface-variant/40 peer-disabled:line-through peer-disabled:hover:border-outline">
                    {% if v.images.length %}<img src="{{ v.images[0].url }}" alt="" class="-ml-1.5 h-6 w-6 rounded-full object-cover ring-1 ring-outline/20" />{% elif v.color %}<span class="-ml-1 h-4 w-4 shrink-0 rounded-full border border-outline/40" style="background-color: {{ v.color }}" title="{{ v.color }}" aria-hidden="true"></span>{% endif %}
                    <span>{{ v.name }}{% if v.size %} · {{ v.size }}{% endif %}</span>
                    {% if v.stock <= 0 %}<span class="font-normal text-on-surface-variant/60"> · Sold out</span>{% endif %}
                  </span>
                </label>
              {% endfor %}
            </div>
            <p class="mt-2.5 text-sm text-on-surface-variant" x-show="v && (v.size || v.color)" x-cloak>
              <span x-show="v && v.size">Size: <span class="font-medium text-on-surface" x-text="v && v.size"></span></span>
              <span x-show="v && v.size && v.color"> · </span>
              <span x-show="v && v.color">Colour: <span class="font-medium text-on-surface" x-text="v && v.color"></span></span>
            </p>
          </fieldset>
        {% elif product.variants.length == 1 %}
          <input type="hidden" name="variantId" value="{{ product.variants[0].id }}" />
        {% endif %}

        <div class="flex flex-wrap items-end gap-5">
          {# Quantity stepper (Alpine) with plain number-input fallback. #}
          <div x-data="{ qty: 1 }">
            <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Quantity</span>
            <div class="mt-2 inline-flex items-center rounded-full border border-outline bg-surface-container-lowest">
              <button type="button" @click="qty = Math.max(1, qty - 1)" class="grid h-11 w-11 place-items-center rounded-full text-on-surface transition-colors hover:text-accent-deep" aria-label="Decrease quantity">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14" stroke-linecap="round"/></svg>
              </button>
              <input id="quantity" type="number" name="quantity" x-model.number="qty" value="1" min="1" inputmode="numeric"
                     class="w-12 border-0 bg-transparent p-0 text-center text-body-md font-medium text-on-surface focus:ring-0 [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
              <button type="button" @click="qty = qty + 1" class="grid h-11 w-11 place-items-center rounded-full text-on-surface transition-colors hover:text-accent-deep" aria-label="Increase quantity">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
              </button>
            </div>
          </div>

          <button type="submit" {% if not inStock %}disabled{% endif %} :disabled="!v || v.stock <= 0"
                  class="group inline-flex min-h-[3.25rem] flex-1 items-center justify-center gap-2.5 rounded-full bg-primary px-8 py-4 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant disabled:cursor-not-allowed disabled:bg-surface-container-high disabled:text-on-surface-variant disabled:shadow-none">
            <svg x-show="!v || v.stock > 0" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M6 7h12l-1 13H7L6 7z" stroke-linejoin="round"/><path d="M9 7a3 3 0 016 0" stroke-linecap="round"/></svg>
            <span x-text="(v && v.stock > 0) ? 'Add to bag' : 'Sold out'">{% if inStock %}Add to bag{% else %}Sold out{% endif %}</span>
          </button>
        </div>
      </form>

      {# Trust bullets. #}
      <ul class="mt-7 grid grid-cols-1 gap-3 border-t border-outline/30 pt-7 text-sm text-on-surface-variant sm:grid-cols-3">
        <li class="flex items-center gap-2.5">
          <svg class="h-5 w-5 shrink-0 text-accent-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M3 8h13v8H3zM16 11h3l2 2v3h-5z" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.7"/><circle cx="18" cy="17" r="1.7"/></svg>
          Nationwide delivery
        </li>
        <li class="flex items-center gap-2.5">
          <svg class="h-5 w-5 shrink-0 text-accent-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M4 9h16v11H4zM4 9l2-5h12l2 5M12 4v5M9 13h6" stroke-linejoin="round"/></svg>
          Gift wrapping
        </li>
        <li class="flex items-center gap-2.5">
          <svg class="h-5 w-5 shrink-0 text-accent-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          One-of-a-kind
        </li>
      </ul>

      {% if product.description %}
        <details class="group mt-7 border-t border-outline/30 pt-2" open>
          <summary class="flex cursor-pointer list-none items-center justify-between py-3 font-label-md text-label-md uppercase tracking-[0.14em] text-on-surface [&::-webkit-details-marker]:hidden">
            Description
            <svg class="h-4 w-4 text-on-surface-variant transition-transform duration-300 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          {# Rich text is sanitized on admin write (Phase 1 admin), so `safe` is OK here. #}
          <div class="prose prose-stone max-w-none pb-4 pt-1 text-on-surface-variant">{{ product.description | safe }}</div>
        </details>
      {% endif %}

      <details class="group border-t border-outline/30 pt-2">
        <summary class="flex cursor-pointer list-none items-center justify-between py-3 font-label-md text-label-md uppercase tracking-[0.14em] text-on-surface [&::-webkit-details-marker]:hidden">
          Shipping &amp; care
          <svg class="h-4 w-4 text-on-surface-variant transition-transform duration-300 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </summary>
        <div class="pb-4 pt-1 text-sm leading-relaxed text-on-surface-variant">
          Each piece is carefully packed and shipped across Bangladesh with complimentary gift wrapping. As vintage and handcrafted items, slight variations in patina and finish are part of their character. Dust gently with a soft, dry cloth.
        </div>
      </details>
    </div>
  </div>

  {# ── Reviews ──────────────────────────────────────────────────────────── #}
  <section id="reviews" class="mt-20 border-t border-outline/30 pt-14">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <p class="eyebrow text-accent-deep">Reviews</p>
        <h2 class="mt-3 font-display-lg text-headline-md text-on-surface">What collectors say</h2>
        {% if reviewStats.count %}
          <div class="mt-5 flex items-baseline gap-3">
            <span class="font-display-lg text-5xl text-primary">{{ reviewStats.average }}</span>
            <div>
              <span class="text-accent" aria-hidden="true">★★★★★</span>
              <p class="text-sm text-on-surface-variant">{{ reviewStats.count }} review{% if reviewStats.count != 1 %}s{% endif %}</p>
            </div>
          </div>
        {% endif %}

        {% if reviewError %}<p class="mt-4 rounded-lg bg-error-container px-4 py-3 text-sm text-on-error-container">{{ reviewError }}</p>{% endif %}

        {% if canReview and not hasReviewed %}
          <form action="/p/{{ product.slug }}/reviews" method="post" class="mt-6 space-y-3 rounded-2xl border border-outline/30 bg-surface-container-lowest p-6 shadow-luxe">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
            <p class="font-label-md text-label-md uppercase tracking-[0.14em] text-on-surface">Write a review</p>
            <label class="block text-sm text-on-surface-variant">Rating
              <select name="rating" class="mt-1.5 block w-44 rounded-lg border border-outline bg-surface-container-lowest px-3 py-2.5 text-on-surface focus:border-accent-deep focus:ring-0">
                <option value="5">★★★★★ (5)</option>
                <option value="4">★★★★ (4)</option>
                <option value="3">★★★ (3)</option>
                <option value="2">★★ (2)</option>
                <option value="1">★ (1)</option>
              </select>
            </label>
            <label class="block text-sm text-on-surface-variant">Title (optional)
              <input name="title" class="mt-1.5 w-full rounded-lg border border-outline bg-surface-container-lowest px-3 py-2.5 text-on-surface focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block text-sm text-on-surface-variant">Your review
              <textarea name="body" rows="3" required class="mt-1.5 w-full rounded-lg border border-outline bg-surface-container-lowest px-3 py-2.5 text-on-surface focus:border-accent-deep focus:ring-0"></textarea>
            </label>
            <button class="rounded-full bg-primary px-6 py-3 font-label-md text-label-md uppercase tracking-[0.14em] text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Submit review</button>
          </form>
        {% elif currentCustomer and hasReviewed %}
          <p class="mt-5 text-sm text-on-surface-variant">You've already reviewed this product. Thank you!</p>
        {% elif currentCustomer and not canReview %}
          <p class="mt-5 text-sm text-on-surface-variant">Only verified purchasers can review this product.</p>
        {% elif not currentCustomer %}
          <p class="mt-5 text-sm text-on-surface-variant"><a href="/login" class="text-accent-deep underline-offset-4 hover:underline">Log in</a> to review products you've purchased.</p>
        {% endif %}
      </div>

      <div class="lg:col-span-8">
        {% if reviewStats.count %}
          <div class="space-y-6">
            {% for r in product.reviews %}
              <article class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-6 shadow-luxe">
                <div class="flex items-center gap-3">
                  <span class="text-accent" aria-hidden="true">{% for i in range(0, r.rating) %}★{% endfor %}<span class="text-outline">{% for i in range(r.rating, 5) %}★{% endfor %}</span></span>
                  {% if r.title %}<span class="font-headline-sm text-base text-on-surface">{{ r.title }}</span>{% endif %}
                </div>
                <p class="mt-2.5 text-body-md text-on-surface-variant">{{ r.body }}</p>
                <p class="mt-3 font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant/70">— {{ r.authorName }}</p>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <div class="grid place-items-center rounded-2xl border border-dashed border-outline/50 bg-surface-container-low/40 py-16 text-center">
            <svg class="h-9 w-9 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linejoin="round"/></svg>
            <p class="mt-3 text-on-surface-variant">No reviews yet — be the first to share your impressions.</p>
          </div>
        {% endif %}
      </div>
    </div>
  </section>
</div>
{% endblock %}
