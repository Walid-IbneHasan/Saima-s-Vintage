{% extends "layouts/base.njk" %}

{% block content %}
{# ─── Hero ─────────────────────────────────────────────────────────────── #}
<section class="relative flex min-h-[86vh] items-center overflow-hidden">
  {# Base gradient is always painted; the WebGL shader (JS-only) layers over it. #}
  <div class="absolute inset-0 -z-10 bg-gradient-to-br from-surface via-surface to-tertiary-fixed/50"></div>
  <canvas id="hero-shader" class="hero-shader pointer-events-none absolute inset-0 -z-10 h-full w-full"></canvas>
  {% include "partials/hero-decor.njk" %}

  <div class="mx-auto grid w-full max-w-container-max grid-cols-1 items-center gap-12 px-margin-mobile py-20 md:px-margin-desktop lg:grid-cols-2">
    <div class="flex max-w-2xl flex-col items-start gap-6 rounded border border-outline/10 bg-surface/40 p-8 shadow-[0_20px_40px_-15px_rgba(130,59,24,0.05)] backdrop-blur-sm hero-fade">
      <span class="inline-block rounded-full bg-primary-container px-4 py-1.5 font-label-sm text-label-sm uppercase tracking-widest text-on-primary-container">New Collection</span>
      <h1 class="font-display-lg text-[2.75rem] leading-[1.05] tracking-tight text-on-surface md:text-display-lg lg:text-[5rem]">
        Handcrafted <br /><span class="font-light italic text-primary">Heritage</span>
      </h1>
      <p class="max-w-lg text-body-lg text-on-surface-variant">
        Curated vintage treasures — timeless, one-of-a-kind pieces that bring character and history into modern spaces.
      </p>
      <a href="/products" class="inline-flex h-12 items-center justify-center rounded bg-primary px-8 font-label-md text-label-md uppercase text-on-primary shadow-md transition-colors hover:bg-on-primary-fixed-variant">
        Shop Collection
      </a>
    </div>

    {% set hero = featured[0] %}
    <a href="{% if hero %}/p/{{ hero.slug }}{% else %}/products{% endif %}"
       class="tilt-3d group relative block h-[440px] w-full overflow-hidden rounded-xl border border-outline/10 shadow-[0_40px_80px_-20px_rgba(130,59,24,0.1)] md:h-[600px]">
      {% if hero and hero.image %}
        <img src="{{ hero.image.url }}" alt="{{ hero.image.alt or hero.name }}"
             class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
      {% else %}
        <img src="https://picsum.photos/seed/sv-hero/900/1100" alt="Featured vintage piece"
             class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
      {% endif %}
      {% if hero %}
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-surface/90 via-surface/40 to-transparent p-6">
          <div class="flex items-end justify-between gap-4">
            <div>
              <p class="font-label-sm text-label-sm uppercase tracking-widest text-on-surface-variant">Featured piece</p>
              <h3 class="mt-1 font-headline-md text-headline-md text-on-surface">{{ hero.name }}</h3>
            </div>
            <span class="shrink-0 font-label-md text-label-md text-primary">{{ hero.pricing.current | money(hero.currency) }}</span>
          </div>
        </div>
      {% endif %}
    </a>
  </div>
</section>

{# ─── Featured (bento grid) ────────────────────────────────────────────── #}
<section class="mx-auto max-w-container-max px-margin-mobile py-24 md:px-margin-desktop md:py-32">
  <div class="mb-12 flex flex-col items-start justify-between gap-6 md:mb-16 md:flex-row md:items-end">
    <div>
      <h2 class="font-display-lg text-headline-lg text-on-surface">Curated Collection</h2>
      <p class="mt-2 text-body-md text-on-surface-variant">A rotating selection of our latest finds, lovingly restored.</p>
    </div>
    <a href="/products" class="inline-flex items-center gap-2 border-b border-primary/30 pb-1 font-label-md text-label-md uppercase text-primary transition-opacity hover:opacity-70">
      View all
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>

  {% if featured.length %}
    <div class="grid grid-cols-1 gap-gutter md:grid-cols-12" data-reveal>
      {# Large feature tile #}
      {% set p = featured[0] %}
      <a href="/p/{{ p.slug }}" class="group relative col-span-1 h-[400px] overflow-hidden rounded border border-outline/10 bg-surface-container-low ambient-shadow md:col-span-8 md:row-span-2 md:h-[600px]">
        {% if p.image %}<img src="{{ p.image.url }}" alt="{{ p.image.alt or p.name }}" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />{% endif %}
        <div class="absolute left-6 top-6"><span class="rounded-full bg-surface/90 px-3 py-1 font-label-sm text-label-sm text-on-surface shadow-sm backdrop-blur-sm">Featured</span></div>
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-surface/90 via-surface/40 to-transparent p-8">
          <div class="flex items-end justify-between gap-4">
            <div>
              <h3 class="font-headline-md text-headline-md text-on-surface group-hover:text-primary">{{ p.name }}</h3>
              {% if not p.inStock %}<p class="mt-1 font-label-sm text-label-sm uppercase text-error">Sold out</p>{% endif %}
            </div>
            <span class="shrink-0 font-label-md text-label-md text-primary">{{ p.pricing.current | money(p.currency) }}</span>
          </div>
        </div>
      </a>

      {# Tall tile #}
      {% if featured[1] %}{% set p = featured[1] %}
      <a href="/p/{{ p.slug }}" class="group relative col-span-1 h-[300px] overflow-hidden rounded border border-outline/10 bg-surface-container-low ambient-shadow md:col-span-4 md:h-[288px]">
        {% if p.image %}<img src="{{ p.image.url }}" alt="{{ p.image.alt or p.name }}" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />{% endif %}
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-surface/90 via-surface/50 to-transparent p-4">
          <h3 class="font-headline-md text-body-lg font-medium text-on-surface">{{ p.name }}</h3>
          <div class="mt-1 flex items-center justify-between">
            <p class="font-label-sm text-label-sm text-on-surface-variant">Hand-picked</p>
            <span class="font-label-md text-label-md text-primary">{{ p.pricing.current | money(p.currency) }}</span>
          </div>
        </div>
      </a>
      {% endif %}

      {# Two small tiles #}
      {% for i in [2, 3] %}{% if featured[i] %}{% set p = featured[i] %}
      <a href="/p/{{ p.slug }}" class="group relative col-span-1 h-[260px] overflow-hidden rounded border border-outline/10 bg-surface-container-low ambient-shadow md:col-span-2 md:h-[288px]">
        {% if p.image %}<img src="{{ p.image.url }}" alt="{{ p.image.alt or p.name }}" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />{% endif %}
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-surface/0 p-4 text-center opacity-0 transition-all duration-300 group-hover:bg-surface/70 group-hover:opacity-100">
          <h3 class="font-headline-md text-body-lg font-medium text-on-surface">{{ p.name }}</h3>
          <span class="mt-1 font-label-md text-label-md text-primary">{{ p.pricing.current | money(p.currency) }}</span>
        </div>
      </a>
      {% endif %}{% endfor %}
    </div>
  {% else %}
    <p class="text-body-md text-on-surface-variant">New arrivals coming soon.</p>
  {% endif %}
</section>

{# ─── Our story ────────────────────────────────────────────────────────── #}
<section class="relative overflow-hidden bg-surface-container-low py-24 md:py-32">
  <div class="pointer-events-none absolute right-0 top-0 h-[50rem] w-[40rem] -translate-y-1/4 translate-x-1/3 rounded-t-[20rem] border border-outline/10"></div>
  <div class="relative z-10 mx-auto grid max-w-container-max grid-cols-1 items-center gap-16 px-margin-mobile md:px-margin-desktop lg:grid-cols-12">
    <div class="relative lg:col-span-5">
      <div class="relative z-10 aspect-[3/4] overflow-hidden rounded-[8rem] rounded-bl-none border border-outline/10 shadow-[0_40px_80px_-20px_rgba(130,59,24,0.08)]">
        {% set sp = featured[4] or featured[1] or featured[0] %}
        {% if sp and sp.image %}
          <img src="{{ sp.image.url }}" alt="{{ sp.image.alt or sp.name }}" class="h-full w-full object-cover" />
        {% else %}
          <div class="h-full w-full bg-tertiary-fixed"></div>
        {% endif %}
      </div>
      <div class="absolute -bottom-10 -right-10 -z-10 h-full w-full rounded-[8rem] rounded-bl-none bg-tertiary-fixed opacity-50"></div>
    </div>
    <div class="flex flex-col items-start justify-center lg:col-span-6 lg:col-start-7">
      <h2 class="mb-8 font-display-lg text-headline-lg leading-tight text-on-surface">
        Preserving the <br /><span class="font-light italic text-primary">Poetry</span> of the Past.
      </h2>
      <div class="max-w-xl space-y-6 text-body-lg text-on-surface-variant">
        <p>
          Every piece in Saima's Vintage is more than a decorative object; it is a fragment of history. We seek out
          authentic vintage treasures and bring them home to be admired again.
        </p>
        <p>
          Each find is cleaned, restored and cared for with a reverent hand — preserving its original, soulful patina so
          it can endure for generations to come.
        </p>
      </div>
      <a href="/pages/about" class="mt-10 inline-flex h-12 items-center justify-center rounded border border-outline px-8 font-label-md text-label-md uppercase text-on-surface transition-all duration-300 hover:border-primary hover:text-primary">
        Our Story
      </a>
    </div>
  </div>
</section>

{# ─── Shop by category ─────────────────────────────────────────────────── #}
{% if categories.length %}
<section class="mx-auto max-w-container-max px-margin-mobile py-24 md:px-margin-desktop md:py-32">
  <h2 class="mb-16 text-center font-display-lg text-headline-lg text-on-surface">Shop by Category</h2>
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:gap-16">
    {% for category in categories %}{% if loop.index0 < 4 %}
      <a href="/c/{{ category.slug }}"
         class="group relative block h-[420px] overflow-hidden rounded-xl border border-outline/10 ambient-shadow lg:h-[560px] {% if loop.index0 % 2 == 1 %}md:translate-y-16{% endif %}">
        {% if category.imageUrl %}
          <img src="{{ category.imageUrl }}" alt="{{ category.name }}" loading="lazy"
               class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105" />
        {% else %}
          <div class="absolute inset-0 bg-tertiary-fixed"></div>
        {% endif %}
        <div class="absolute inset-0 bg-surface/10 transition-colors duration-500 group-hover:bg-surface/0"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-gradient-to-t from-surface/80 via-transparent to-transparent p-8 text-center">
          <h3 class="mb-4 font-display-lg text-[2.5rem] leading-tight text-on-surface drop-shadow-sm">{{ category.name }}</h3>
          <span class="inline-flex items-center gap-2 border-b border-primary pb-1 font-label-md text-label-md uppercase text-primary">
            Explore
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </a>
    {% endif %}{% endfor %}
  </div>
</section>
{% endif %}
{% endblock %}
