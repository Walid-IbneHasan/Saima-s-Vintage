{% extends "layouts/base.njk" %}

{# ════════════════════════════════════════════════════════════════════════════
   ABOUT — "Our Story" · Maison Rouge editorial.
   White ground · red accent · champagne-gold detailing. Self-contained under
   `.lux` (brand fonts load globally). Mirrors the home page's visual language
   so the brand reads as one continuous world. Reveals reuse the global
   IntersectionObserver; motion is reduced-motion-guarded.
   ════════════════════════════════════════════════════════════════════════════ #}

{% block head %}
<style>
.lux{
  --red:#a31621; --red-deep:#7a1019; --red-soft:#c4283b; --wine:#3a0a0e;
  --gold:#b08d3f; --gold-soft:#cdab63; --gold-bright:#dcb978; --bronze:#8a6d2e;
  --ink:#2a1410; --ink-2:#6f5a54; --paper:#faf7f3; --cream:#f6ece0;
  --line:rgba(42,20,16,.10); --line-gold:rgba(176,141,63,.40);
  --e:cubic-bezier(.22,1,.36,1);
  font-family:'Hanken Grotesk',ui-sans-serif,system-ui,-apple-system,'Segoe UI',sans-serif;
  color:var(--ink); background:#fff; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
}
.lux ::selection{background:rgba(163,22,33,.14);color:var(--ink);}
.lux img{display:block;}

/* type */
.lux-serif{font-family:'Bodoni Moda',Georgia,'Times New Roman',serif;}
.lux-display{font-family:'Bodoni Moda',Georgia,serif;font-weight:500;line-height:1.05;letter-spacing:-.01em;}
.lux-eyebrow{font-weight:600;font-size:.72rem;line-height:1;letter-spacing:.34em;text-transform:uppercase;}
.lux-kicker{font-weight:600;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;}
.lux-h1{font-size:clamp(2.6rem,6vw,5rem);}
.lux-h2{font-size:clamp(1.9rem,4vw,3.1rem);}
.lux-quote{font-size:clamp(1.5rem,3.2vw,2.5rem);line-height:1.36;}
.lux-num{font-variant-numeric:tabular-nums;}

/* colour helpers */
.lux .t-ink{color:var(--ink);} .lux .t-ink-2{color:var(--ink-2);}
.lux .t-red{color:var(--red);} .lux .t-bronze{color:var(--bronze);} .lux .t-gold{color:var(--gold);}
.lux .t-cream{color:var(--cream);} .lux .t-cream-80{color:rgba(246,236,224,.82);} .lux .t-gold-br{color:var(--gold-bright);}
.lux .bg-paper{background:var(--paper);} .lux .bg-red{background:var(--red);} .lux .bg-wine{background:var(--wine);}

/* primary red button */
.lux-btn{display:inline-flex;align-items:center;justify-content:center;gap:.6rem;min-height:3.4rem;padding:0 2rem;border-radius:999px;background:var(--red);color:#fff;font-weight:600;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;box-shadow:0 12px 28px -14px rgba(163,22,33,.65);transition:background-color .3s var(--e),transform .3s var(--e),box-shadow .3s var(--e);cursor:pointer;}
.lux-btn:hover{background:var(--red-deep);transform:translateY(-2px);box-shadow:0 18px 34px -14px rgba(122,16,25,.7);}
.lux-btn:active{transform:translateY(0);}
.lux-btn .ar{transition:transform .3s var(--e);}
.lux-btn:hover .ar{transform:translateX(4px);}

/* ghost button */
.lux-ghost{display:inline-flex;align-items:center;gap:.6rem;min-height:3.4rem;padding:0 1.8rem;border-radius:999px;border:1px solid var(--line);color:var(--ink);font-weight:600;font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;transition:border-color .3s var(--e),color .3s var(--e),transform .3s var(--e);}
.lux-ghost:hover{border-color:var(--red);color:var(--red);transform:translateY(-2px);}
.lux-ghost .ar{transition:transform .3s var(--e);} .lux-ghost:hover .ar{transform:translateX(4px);}

/* animated link */
.lux-link{position:relative;display:inline-flex;align-items:center;gap:.5rem;font-weight:600;font-size:.76rem;letter-spacing:.18em;text-transform:uppercase;}
.lux-link::after{content:'';position:absolute;left:0;bottom:-5px;height:1px;width:100%;background:currentColor;transform:scaleX(0);transform-origin:left;transition:transform .35s var(--e);}
.lux-link:hover::after,.lux-link:focus-visible::after{transform:scaleX(1);}
.lux-link .ar{transition:transform .3s var(--e);} .lux-link:hover .ar{transform:translateX(4px);}

/* hairline + marks */
.lux-rule{height:1px;border:0;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.6;}
.lux-tick{width:7px;height:7px;border-radius:99px;background:var(--red);}

/* editorial image frame */
.lux-frame{position:relative;overflow:hidden;border-radius:18px;border:1px solid var(--line);box-shadow:0 40px 80px -44px rgba(42,20,16,.4);}
.lux-corner{position:absolute;width:26px;height:26px;border:1.5px solid var(--gold);}

/* glass caption card */
.lux-glass{background:rgba(255,255,255,.78);backdrop-filter:blur(12px) saturate(130%);-webkit-backdrop-filter:blur(12px) saturate(130%);border:1px solid rgba(255,255,255,.7);box-shadow:0 18px 40px -22px rgba(42,20,16,.4);}

/* story drop-cap on the first paragraph */
.lux-story > p:first-of-type::first-letter{
  font-family:'Bodoni Moda',Georgia,serif;font-weight:600;color:var(--red);
  float:left;font-size:3.6rem;line-height:.82;padding:.35rem .55rem 0 0;
}

/* hero entrance (pure CSS) */
@media (prefers-reduced-motion:no-preference){
  .lux-rise{opacity:0;transform:translateY(18px);animation:luxRise .85s var(--e) forwards;}
  .lux-d1{animation-delay:.06s;} .lux-d2{animation-delay:.16s;} .lux-d3{animation-delay:.26s;} .lux-d4{animation-delay:.36s;}
  @keyframes luxRise{to{opacity:1;transform:none;}}
}
</style>
{% endblock %}

{% block content %}
<div class="lux" data-lux>

  {# ─── HERO ───────────────────────────────────────────────────────────── #}
  <section class="relative overflow-hidden bg-white">
    <div class="pointer-events-none absolute left-1/2 top-0 -z-0 h-[34rem] w-[34rem] -translate-x-1/2 -translate-y-1/3 rounded-full" aria-hidden="true" style="background:radial-gradient(closest-side,rgba(163,22,33,.06),transparent);"></div>
    <div class="relative z-[1] mx-auto max-w-[1100px] px-5 pb-12 pt-16 text-center md:px-16 md:pb-16 md:pt-24">
      <span class="lux-rise lux-d1 inline-flex items-center gap-3">
        <span class="lux-tick"></span>
        <span class="lux-eyebrow t-bronze">Our Story</span>
        <span class="lux-tick" style="background:var(--gold);"></span>
      </span>
      <h1 class="lux-rise lux-d2 lux-display lux-h1 t-ink mx-auto mt-6 max-w-3xl text-balance">
        The art of <span class="lux-serif italic t-red">heritage</span>, kept alive.
      </h1>
      <p class="lux-rise lux-d2 mx-auto mt-7 max-w-xl text-[1.08rem] leading-relaxed t-ink-2">
        Saima's Vintage began with a single, stubborn belief — that the most
        beautiful things in a home are the ones with a past worth telling.
      </p>
    </div>

    {# large editorial image — the same arrangement that headlines our atelier #}
    <div class="lux-rise lux-d3 relative z-[1] mx-auto max-w-[1180px] px-5 pb-4 md:px-16">
      <div class="lux-frame aspect-[16/9] w-full">
        <img src="/images/atelier-heritage-collection.webp" alt="A curated arrangement of handcrafted Lippan mirror-art mandalas and Mughal Jharoka window frames resting against a sunlit plaster wall" class="h-full w-full object-cover" fetchpriority="high" />
        <span class="lux-corner left-3 top-3 border-b-0 border-r-0" aria-hidden="true"></span>
        <span class="lux-corner bottom-3 right-3 border-l-0 border-t-0" aria-hidden="true"></span>
      </div>
      <div class="lux-glass absolute -bottom-3 left-8 z-[2] hidden items-center gap-3 rounded-2xl px-5 py-4 sm:flex md:left-24">
        <span class="lux-tick" style="background:var(--gold);"></span>
        <p class="lux-kicker t-bronze">Lippan · Jharoka · Mandala</p>
      </div>
    </div>
  </section>

  {# ─── THE STORY (4 long paragraphs) ──────────────────────────────────── #}
  <section class="bg-white py-20 md:py-28">
    <div class="mx-auto max-w-[760px] px-5 md:px-0">
      <div class="text-center" data-reveal>
        <span class="lux-eyebrow t-bronze">How it began</span>
        <h2 class="lux-display lux-h2 t-ink mt-4 text-balance">A love letter, written in mirror and mud.</h2>
        <hr class="lux-rule mx-auto mt-8 w-24" />
      </div>

      <div class="lux-story mt-12 space-y-7 text-[1.12rem] leading-[1.85] t-ink-2" data-reveal>
        <p>
          It started, as the best stories do, by accident. On a slow afternoon in the
          old quarter of Kutch, our founder Saima ducked out of the heat into a
          workshop no wider than a doorway. Inside, an elderly artisan was pressing
          tiny discs of mirror into wet clay by the light of a single window — a craft
          called <em>Lippan</em>, older than anyone in the room could remember. The walls
          caught the sun and threw it back in a hundred little sparks. She stayed until
          dusk, and she left knowing, with the certainty that only comes once or twice
          in a life, that this was the thing she was meant to do.
        </p>
        <p>
          What she had fallen for was not merely decoration but a way of remembering.
          Each Lippan mandala is raised entirely by hand, swirl by patient swirl, then
          set with mirrors so that the piece is never quite the same from one hour to
          the next — it lives with the light of whatever room it hangs in. The carved
          <em>Jharoka</em> windows we love tell a parallel story: once the latticed
          balconies of Mughal courtyards, framed so that the women of the household
          could watch the world without being watched in return. To bring one home is
          to bring home a small, intricate piece of someone else's morning, three or
          four centuries ago.
        </p>
        <p>
          And so Saima's Vintage became, quietly, a rescue mission. We travel to the
          villages where these crafts still breathe, and we look for the pieces that
          others have overlooked — a sun-faded triptych, a Jharoka with a hairline
          crack, a mandala dulled by decades of woodsmoke. We carry each one back, and
          then the slow work begins. Every piece is cleaned with a soft hand and softer
          patience, its loose mirrors re-set, its colours coaxed back without ever being
          painted over. We are restorers, not renovators; our single rule is that the
          object must leave us looking like itself — only loved again. We would rather
          keep an honest crack than erase the years that earned it.
        </p>
        <p>
          That is the promise behind everything we sell. Because each treasure is sought
          out one at a time, no two are ever alike — what you bring home is genuinely the
          only one of its kind in the world. It arrives wrapped as a gift should be,
          ready to begin its next hundred years on your wall instead of someone else's.
          We are a small atelier, and we will always be a small atelier, because heritage
          cannot be mass-produced and a love letter cannot be photocopied. Thank you for
          letting us share ours with you.
        </p>
      </div>

      {# founder signature #}
      <div class="mt-12 flex items-center gap-4" data-reveal>
        <span class="h-px w-12" style="background:var(--gold);opacity:.7;"></span>
        <div>
          <p class="lux-serif text-2xl italic t-red">Saima</p>
          <p class="lux-kicker mt-1 t-ink-2">Founder &amp; Curator</p>
        </div>
      </div>
    </div>
  </section>

  {# ─── THE PROMISE (three pillars) ────────────────────────────────────── #}
  <section class="bg-paper border-y py-20 md:py-24" style="border-color:var(--line);">
    <div class="mx-auto max-w-[1180px] px-5 md:px-16">
      <div class="mb-14 text-center" data-reveal>
        <span class="lux-eyebrow t-bronze">What we promise</span>
        <h2 class="lux-display lux-h2 t-ink mt-4">Three things, always.</h2>
      </div>
      <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-8" data-reveal-stagger>
        {% set pillars = [
          { t:'Sought out', d:'Every piece is found by hand in the villages of Kutch and Gujarat — never ordered from a catalogue, never made to a quota.', i:'compass' },
          { t:'Restored, never refaced', d:'We clean, re-set and revive with a reverent hand, preserving the soulful patina that decades gave it.', i:'hand' },
          { t:'One of a kind', d:'Because each treasure is singular, the one you choose is the only one of its kind in the world — and it ships gift-wrapped.', i:'gem' }
        ] %}
        {% for p in pillars %}
        <div class="text-center">
          <span class="mx-auto grid h-14 w-14 place-items-center rounded-full t-red" style="border:1px solid var(--line-gold);">
            {% if p.i == 'compass' %}<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M15.5 8.5l-2 5-5 2 2-5z" stroke-linejoin="round"/></svg>
            {% elif p.i == 'hand' %}<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 13V5.5a1.5 1.5 0 0 1 3 0V12m0-1.5a1.5 1.5 0 0 1 3 0V12m0-1a1.5 1.5 0 0 1 3 0v4a6 6 0 0 1-6 6h-1.2a5 5 0 0 1-3.9-1.9L4 17" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {% else %}<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 3h12l3 6-9 12L3 9z" stroke-linejoin="round"/><path d="M3 9h18M9 3l-3 6 6 12M15 3l3 6-6 12" stroke-linejoin="round"/></svg>{% endif %}
          </span>
          <h3 class="lux-display mt-6 text-xl t-ink">{{ p.t }}</h3>
          <p class="mx-auto mt-3 max-w-xs text-[1rem] leading-relaxed t-ink-2">{{ p.d }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ─── PULL QUOTE (the one red band) ──────────────────────────────────── #}
  <section class="relative overflow-hidden bg-wine py-24 md:py-32">
    <div class="pointer-events-none absolute inset-0 -z-0" aria-hidden="true" style="background:radial-gradient(60% 70% at 50% 22%,rgba(196,40,59,.32),transparent 70%);"></div>
    <svg class="pointer-events-none absolute left-1/2 top-1/2 z-0 h-[42rem] w-[42rem] -translate-x-1/2 -translate-y-1/2 opacity-[.10]" viewBox="0 0 100 100" fill="none" stroke-width="0.4" style="stroke:var(--gold-bright);" aria-hidden="true">
      <circle cx="50" cy="50" r="48" stroke-dasharray="1 4"/><circle cx="50" cy="50" r="38"/><circle cx="50" cy="50" r="28" stroke-dasharray="2 5"/><circle cx="50" cy="50" r="17"/>
    </svg>
    <div class="relative z-[1] mx-auto max-w-3xl px-5 text-center md:px-16" data-reveal>
      <span class="lux-serif block text-7xl leading-none t-gold-br" aria-hidden="true">&ldquo;</span>
      <blockquote class="lux-serif lux-quote t-cream -mt-3 italic text-balance">
        We are restorers, not renovators. Our single rule is that the piece must leave us looking like itself — only loved again.
      </blockquote>
      <div class="mx-auto mt-8 h-px w-16" style="background:var(--gold-bright);opacity:.75;"></div>
      <p class="lux-kicker t-gold-br mt-6">The Saima's Vintage Atelier</p>
    </div>
  </section>

  {# ─── CLOSING CTA ────────────────────────────────────────────────────── #}
  <section class="bg-paper py-20 text-center md:py-28">
    <div class="mx-auto max-w-2xl px-5 md:px-16" data-reveal>
      <div class="mx-auto mb-7 flex items-center justify-center gap-4">
        <span class="h-px w-12" style="background:var(--gold);opacity:.6;"></span>
        <span class="lux-eyebrow t-bronze">Bring heritage home</span>
        <span class="h-px w-12" style="background:var(--gold);opacity:.6;"></span>
      </div>
      <h2 class="lux-display t-ink text-balance" style="font-size:clamp(1.9rem,3.8vw,3.1rem);">
        Every wall deserves <span class="lux-serif italic t-red">a story.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-md text-[1.02rem] t-ink-2">Discover the full collection of restored, one-of-a-kind treasures.</p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
        <a href="/products" class="lux-btn">
          <span>Explore the collection</span>
          <svg class="ar h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/" class="lux-ghost">Back to home</a>
      </div>
    </div>
  </section>

</div>
{% endblock %}
