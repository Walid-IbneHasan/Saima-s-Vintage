{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-2xl px-4 py-16 text-center">
  {% if order.status == 'PAID' or order.status == 'PROCESSING' %}
    <p class="text-sm font-medium uppercase tracking-widest text-green-700">Payment confirmed</p>
    <h1 class="mt-2 font-serif text-3xl">Thank you — you're all set!</h1>
    <p class="mt-3 text-stone-600">Order <span class="font-medium">{{ order.orderNumber }}</span> is paid and being prepared.</p>
  {% elif order.status == 'PAYMENT_REVIEW' %}
    <p class="text-sm font-medium uppercase tracking-widest text-amber-700">Under review</p>
    <h1 class="mt-2 font-serif text-3xl">We're confirming your payment</h1>
    <p class="mt-3 text-stone-600">Order <span class="font-medium">{{ order.orderNumber }}</span> is being verified. We'll email you shortly.</p>
  {% elif order.status == 'FAILED' %}
    <p class="text-sm font-medium uppercase tracking-widest text-red-700">Payment failed</p>
    <h1 class="mt-2 font-serif text-3xl">That payment didn't go through</h1>
    <p class="mt-3 text-stone-600">Order <span class="font-medium">{{ order.orderNumber }}</span> wasn't paid. Your items have been released.</p>
  {% elif order.status == 'CANCELLED' %}
    <p class="text-sm font-medium uppercase tracking-widest text-stone-500">Cancelled</p>
    <h1 class="mt-2 font-serif text-3xl">Payment cancelled</h1>
    <p class="mt-3 text-stone-600">Order <span class="font-medium">{{ order.orderNumber }}</span> was cancelled.</p>
  {% else %}
    <p class="text-sm font-medium uppercase tracking-widest text-amber-700">Order placed</p>
    <h1 class="mt-2 font-serif text-3xl">Thank you!</h1>
    <p class="mt-3 text-stone-600">Order <span class="font-medium">{{ order.orderNumber }}</span> is <span class="font-medium">awaiting payment</span>.</p>
  {% endif %}

  <div class="mt-8 rounded-lg border border-stone-200 bg-white p-6 text-left">
    <h2 class="text-base font-medium">Summary</h2>
    <div class="mt-3 space-y-2 text-sm">
      {% for item in order.items %}
        <div class="flex justify-between">
          <span class="text-stone-600">{{ item.productName }} ({{ item.variantName }}) × {{ item.quantity }}</span>
          <span>{{ item.lineTotal | money(order.currency) }}</span>
        </div>
      {% endfor %}
    </div>
    <div class="mt-4 flex justify-between border-t border-stone-200 pt-4 text-lg">
      <span>Total</span><span>{{ order.grandTotal | money(order.currency) }}</span>
    </div>
  </div>

  {% if order.status == 'AWAITING_PAYMENT' %}
    <a href="/checkout" class="mt-6 inline-block rounded-full bg-stone-900 px-6 py-3 text-sm text-white">Complete payment</a>
  {% else %}
    <a href="/" class="mt-6 inline-block rounded-full border border-stone-300 px-6 py-3 text-sm">Back to home</a>
  {% endif %}
</div>
{% endblock %}
