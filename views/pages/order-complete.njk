{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-2xl px-margin-mobile py-16 text-center md:px-margin-desktop md:py-20">
  {% if order.status == 'PAID' or order.status == 'PROCESSING' %}
    <p class="font-label-md text-label-md uppercase tracking-widest text-primary">Payment confirmed</p>
    <h1 class="mt-3 font-display-lg text-headline-lg text-on-surface">Thank you — you're all set!</h1>
    <p class="mt-4 text-on-surface-variant">Order <span class="text-on-surface">{{ order.orderNumber }}</span> is paid and being prepared.</p>
  {% elif order.status == 'PAYMENT_REVIEW' %}
    <p class="font-label-md text-label-md uppercase tracking-widest text-on-secondary-container">Under review</p>
    <h1 class="mt-3 font-display-lg text-headline-lg text-on-surface">We're confirming your payment</h1>
    <p class="mt-4 text-on-surface-variant">Order <span class="text-on-surface">{{ order.orderNumber }}</span> is being verified. We'll email you shortly.</p>
  {% elif order.status == 'FAILED' %}
    <p class="font-label-md text-label-md uppercase tracking-widest text-error">Payment failed</p>
    <h1 class="mt-3 font-display-lg text-headline-lg text-on-surface">That payment didn't go through</h1>
    <p class="mt-4 text-on-surface-variant">Order <span class="text-on-surface">{{ order.orderNumber }}</span> wasn't paid. Your items have been released.</p>
  {% elif order.status == 'CANCELLED' %}
    <p class="font-label-md text-label-md uppercase tracking-widest text-on-surface-variant">Cancelled</p>
    <h1 class="mt-3 font-display-lg text-headline-lg text-on-surface">Payment cancelled</h1>
    <p class="mt-4 text-on-surface-variant">Order <span class="text-on-surface">{{ order.orderNumber }}</span> was cancelled.</p>
  {% else %}
    <p class="font-label-md text-label-md uppercase tracking-widest text-on-secondary-container">Order placed</p>
    <h1 class="mt-3 font-display-lg text-headline-lg text-on-surface">Thank you!</h1>
    <p class="mt-4 text-on-surface-variant">Order <span class="text-on-surface">{{ order.orderNumber }}</span> is <span class="text-on-surface">awaiting payment</span>.</p>
  {% endif %}

  <div class="ambient-shadow mt-10 rounded-lg border border-outline/10 bg-surface-container-lowest p-8 text-left">
    <h2 class="font-headline-md text-headline-md text-on-surface">Summary</h2>
    <div class="mt-4 space-y-2 text-sm">
      {% for item in order.items %}
        <div class="flex justify-between">
          <span class="text-on-surface-variant">{{ item.productName }} ({{ item.variantName }}) × {{ item.quantity }}</span>
          <span class="text-on-surface">{{ item.lineTotal | money(order.currency) }}</span>
        </div>
      {% endfor %}
    </div>
    <div class="mt-5 flex justify-between border-t border-outline/10 pt-5 text-lg text-on-surface">
      <span>Total</span><span>{{ order.grandTotal | money(order.currency) }}</span>
    </div>
  </div>

  {% if order.status == 'AWAITING_PAYMENT' %}
    <a href="/checkout" class="mt-8 inline-flex items-center justify-center rounded bg-primary px-8 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Complete payment</a>
  {% else %}
    <a href="/" class="mt-8 inline-block rounded border border-outline px-6 py-3 font-label-md text-label-md uppercase tracking-widest text-on-surface transition-colors hover:border-primary hover:text-primary">Back to home</a>
  {% endif %}
</div>
{% endblock %}
