{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-5xl px-4 py-10">
  <h1 class="font-serif text-3xl">Checkout</h1>

  <form action="/checkout" method="post" class="mt-8 grid gap-8 md:grid-cols-3">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <input type="hidden" name="idempotencyKey" value="{{ idempotencyKey }}" />

    <div class="space-y-5 md:col-span-2">
      <div class="rounded-lg border border-stone-200 bg-white p-6">
        <h2 class="text-base font-medium">Contact</h2>
        <div class="mt-3 grid gap-4 md:grid-cols-2">
          <label class="block text-sm font-medium">Email
            <input name="email" type="email" required value="{{ prefill.email or '' }}"
                   {% if loggedIn %}readonly{% endif %}
                   class="mt-1 w-full rounded border-stone-300 {% if loggedIn %}bg-stone-50 text-stone-500{% endif %}" />
            {% if loggedIn %}<span class="mt-1 block text-xs text-stone-400">Using your account email.</span>{% endif %}
          </label>
          <label class="block text-sm font-medium">Phone <span class="text-red-500">*</span>
            <input name="phone" type="tel" required value="{{ prefill.phone or '' }}"
                   placeholder="01XXXXXXXXX" class="mt-1 w-full rounded border-stone-300" />
          </label>
        </div>
      </div>

      <div class="rounded-lg border border-stone-200 bg-white p-6">
        <h2 class="text-base font-medium">Shipping address</h2>
        <div class="mt-3 grid gap-4 md:grid-cols-2">
          <label class="block text-sm font-medium md:col-span-2">Full name
            <input name="shipName" required value="{{ prefill.name or '' }}" class="mt-1 w-full rounded border-stone-300" />
          </label>
          <label class="block text-sm font-medium">Postal code
            <input name="shipPostalCode" value="{{ prefill.postalCode or '' }}" class="mt-1 w-full rounded border-stone-300" />
          </label>
          <label class="block text-sm font-medium md:col-span-2">Address line 1
            <input name="shipLine1" required value="{{ prefill.line1 or '' }}" class="mt-1 w-full rounded border-stone-300" />
          </label>
          <label class="block text-sm font-medium md:col-span-2">Address line 2
            <input name="shipLine2" value="{{ prefill.line2 or '' }}" class="mt-1 w-full rounded border-stone-300" />
          </label>
          <label class="block text-sm font-medium">City
            <input name="shipCity" required value="{{ prefill.city or '' }}" class="mt-1 w-full rounded border-stone-300" />
          </label>
          <label class="block text-sm font-medium">District
            <input name="shipDistrict" value="{{ prefill.district or '' }}" class="mt-1 w-full rounded border-stone-300" />
          </label>
          <input type="hidden" name="shipCountry" value="Bangladesh" />
        </div>
      </div>
    </div>

    <div>
      <div class="rounded-lg border border-stone-200 bg-white p-6">
        <h2 class="text-base font-medium">Order summary</h2>
        <div class="mt-3 space-y-2 text-sm">
          {% for item in cart.items %}
            <div class="flex justify-between">
              <span class="text-stone-600">{{ item.productName }} × {{ item.quantity }}</span>
              <span>{{ item.lineTotal | money }}</span>
            </div>
          {% endfor %}
        </div>
        <label class="mt-4 block text-sm font-medium">Coupon code
          <input name="couponCode" placeholder="optional" class="mt-1 w-full rounded border-stone-300 uppercase" />
          <span class="mt-1 block text-xs text-stone-400">Discount is applied when your order is placed.</span>
        </label>
        <div class="mt-4 flex justify-between border-t border-stone-200 pt-4 text-lg">
          <span>Subtotal</span><span>{{ cart.subtotal | money }}</span>
        </div>
        <button type="submit" class="mt-5 w-full rounded-full bg-stone-900 px-6 py-3 text-sm text-white hover:bg-stone-700">
          Place order &amp; pay
        </button>
        <p class="mt-2 text-center text-xs text-stone-400">You'll be redirected to SSLCOMMERZ to pay securely.</p>
      </div>
    </div>
  </form>
</div>
{% endblock %}
