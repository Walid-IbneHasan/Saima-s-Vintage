{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-5xl px-margin-mobile py-16 md:px-margin-desktop">
  <h1 class="font-display-lg text-headline-lg text-on-surface">Checkout</h1>

  <form action="/checkout" method="post" class="mt-8 grid gap-8 lg:grid-cols-3">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <input type="hidden" name="idempotencyKey" value="{{ idempotencyKey }}" />

    <div class="space-y-5 lg:col-span-2">
      <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6 ambient-shadow">
        <h2 class="font-headline-md text-headline-md text-on-surface">Contact</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <label class="block">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Email</span>
            <input name="email" type="email" required value="{{ prefill.email or '' }}"
                   {% if loggedIn %}readonly{% endif %}
                   class="mt-1 w-full rounded border border-outline/30 px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0 {% if loggedIn %}bg-surface-container text-on-surface-variant{% else %}bg-surface{% endif %}" />
            {% if loggedIn %}<span class="mt-1 block text-xs text-on-surface-variant/70">Using your account email.</span>{% endif %}
          </label>
          <label class="block">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Phone <span class="text-error">*</span></span>
            <input name="phone" type="tel" required value="{{ prefill.phone or '' }}"
                   placeholder="01XXXXXXXXX" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
          </label>
        </div>
      </div>

      <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6 ambient-shadow">
        <h2 class="font-headline-md text-headline-md text-on-surface">Shipping address</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          <label class="block md:col-span-2">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Full name</span>
            <input name="shipName" required value="{{ prefill.name or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0" />
          </label>
          <label class="block">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Postal code</span>
            <input name="shipPostalCode" value="{{ prefill.postalCode or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0" />
          </label>
          <label class="block md:col-span-2">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Address line 1</span>
            <input name="shipLine1" required value="{{ prefill.line1 or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0" />
          </label>
          <label class="block md:col-span-2">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Address line 2</span>
            <input name="shipLine2" value="{{ prefill.line2 or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0" />
          </label>
          <label class="block">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">City</span>
            <input name="shipCity" required value="{{ prefill.city or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0" />
          </label>
          <label class="block">
            <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">District</span>
            <input name="shipDistrict" value="{{ prefill.district or '' }}" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md text-on-surface focus:border-primary focus:ring-0" />
          </label>
          <input type="hidden" name="shipCountry" value="Bangladesh" />
        </div>
      </div>
    </div>

    <div>
      <div class="rounded-lg border border-outline/10 bg-surface-container-lowest p-6 ambient-shadow">
        <h2 class="font-headline-md text-headline-md text-on-surface">Order summary</h2>
        <div class="mt-4 space-y-2 text-sm">
          {% for item in cart.items %}
            <div class="flex justify-between">
              <span class="text-on-surface-variant">{{ item.productName }} × {{ item.quantity }}</span>
              <span class="text-on-surface">{{ item.lineTotal | money }}</span>
            </div>
          {% endfor %}
        </div>
        <label class="mt-4 block">
          <span class="block font-label-sm text-label-sm uppercase tracking-wider text-on-surface-variant">Coupon code</span>
          <input name="couponCode" placeholder="optional" class="mt-1 w-full rounded border border-outline/30 bg-surface px-3 py-2.5 text-body-md uppercase text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
          <span class="mt-1 block text-xs text-on-surface-variant/70">Discount is applied when your order is placed.</span>
        </label>
        <div class="mt-4 flex justify-between border-t border-outline/20 pt-4 font-headline-md text-headline-md text-on-surface">
          <span>Subtotal</span><span>{{ cart.subtotal | money }}</span>
        </div>
        <button type="submit" class="mt-5 w-full rounded bg-primary px-6 py-3.5 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">
          Place order &amp; pay
        </button>
        <p class="mt-2 text-center text-xs text-on-surface-variant/70">You'll be redirected to SSLCOMMERZ to pay securely.</p>
      </div>
    </div>
  </form>
</div>
{% endblock %}
