{% extends "layouts/base.njk" %}

{% block content %}
{# pay: 'cod' | 'bkash'.  editAddr: when a saved address exists, false = reuse it
   (fields hidden but still submit their prefilled values), true = enter a new one.
   With no JS, editAddr starts true so the prefilled fields are always editable. #}
<div class="mx-auto max-w-container-max px-margin-mobile py-14 md:px-margin-desktop md:py-20">
  <div class="flex flex-col gap-2">
    <p class="eyebrow text-accent-deep">Almost yours</p>
    <h1 class="font-display-lg text-[2.25rem] leading-tight text-on-surface md:text-headline-lg">Checkout</h1>
  </div>

  {# Step indicator #}
  <ol class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 font-label-sm text-label-sm uppercase tracking-[0.14em] text-on-surface-variant">
    <li class="inline-flex items-center gap-2"><span class="grid h-6 w-6 place-items-center rounded-full border border-outline text-[11px]">1</span>Cart</li>
    <svg class="h-3.5 w-3.5 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <li class="inline-flex items-center gap-2 text-accent-deep"><span class="grid h-6 w-6 place-items-center rounded-full bg-primary text-[11px] text-on-primary">2</span>Details</li>
    <svg class="h-3.5 w-3.5 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <li class="inline-flex items-center gap-2"><span class="grid h-6 w-6 place-items-center rounded-full border border-outline text-[11px]">3</span>Payment</li>
  </ol>

  <form action="/checkout" method="post" class="mt-10 grid gap-8 lg:grid-cols-3 lg:gap-10"
        x-data="{ pay: 'cod', editAddr: {% if hasSavedAddress %}false{% else %}true{% endif %} }">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
    <input type="hidden" name="idempotencyKey" value="{{ idempotencyKey }}" />

    <div class="space-y-6 lg:col-span-2">
      <div class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-7 shadow-luxe md:p-8">
        <h2 class="font-headline-md text-xl text-on-surface">Contact</h2>
        <label class="mt-5 block">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Email</span>
          <input name="email" type="email" required value="{{ prefill.email or '' }}"
                 {% if loggedIn %}readonly{% endif %} autocomplete="email"
                 class="mt-2 w-full rounded-lg border border-outline px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0 {% if loggedIn %}bg-surface-container text-on-surface-variant{% else %}bg-surface-container-lowest{% endif %}" />
          {% if loggedIn %}<span class="mt-1.5 block text-xs text-on-surface-variant/70">Using your account email.</span>{% endif %}
        </label>
      </div>

      {% if hasSavedAddress %}
      {# ── Saved-details choice ──────────────────────────────────────────── #}
      <div class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-7 shadow-luxe md:p-8">
        <h2 class="font-headline-md text-xl text-on-surface">Delivery details</h2>
        <p class="mt-1.5 text-sm text-on-surface-variant">Use the number &amp; address saved to your account, or enter different ones just for this order.</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <label class="flex cursor-pointer items-start gap-3 rounded-xl border p-4 transition-colors" :class="!editAddr ? 'border-primary bg-primary/5' : 'border-outline/40 hover:border-outline'">
            <input type="radio" name="_addr" value="saved" checked @change="editAddr = false; $root.querySelectorAll('[data-default]').forEach(i => i.value = i.dataset.default)" class="mt-0.5 h-4 w-4" />
            <span class="font-label-md text-label-md uppercase tracking-[0.1em] text-on-surface">Use my saved details</span>
          </label>
          <label class="flex cursor-pointer items-start gap-3 rounded-xl border p-4 transition-colors" :class="editAddr ? 'border-primary bg-primary/5' : 'border-outline/40 hover:border-outline'">
            <input type="radio" name="_addr" value="new" @change="editAddr = true" class="mt-0.5 h-4 w-4" />
            <span class="font-label-md text-label-md uppercase tracking-[0.1em] text-on-surface">Use a different address</span>
          </label>
        </div>
        {# Saved summary (shown while reusing the saved details) #}
        <div x-show="!editAddr" class="mt-5 rounded-xl border border-outline/30 bg-surface-container-low px-5 py-4 text-sm text-on-surface">
          <p class="font-medium">{{ prefill.name }}</p>
          {% if prefill.phone %}<p class="text-on-surface-variant">{{ prefill.phone }}</p>{% endif %}
          <p class="mt-1 text-on-surface-variant">{{ prefill.line1 }}{% if prefill.line2 %}, {{ prefill.line2 }}{% endif %}</p>
          <p class="text-on-surface-variant">{{ prefill.city }}{% if prefill.district %}, {{ prefill.district }}{% endif %}{% if prefill.postalCode %} · {{ prefill.postalCode }}{% endif %}</p>
        </div>
      </div>
      {% endif %}

      {# ── Editable contact number + shipping address ────────────────────── #}
      <div {% if hasSavedAddress %}x-show="editAddr" x-cloak{% endif %} class="space-y-6">
        <div class="rounded-2xl border border-outline/30 bg-surface-container-lowest p-7 shadow-luxe md:p-8">
          <h2 class="font-headline-md text-xl text-on-surface">Contact number &amp; shipping</h2>
          <div class="mt-5 grid gap-5 md:grid-cols-2">
            <label class="block">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Phone <span class="text-error">*</span></span>
              <input name="phone" type="tel" required value="{{ prefill.phone or '' }}" data-default="{{ prefill.phone or '' }}" autocomplete="tel"
                     placeholder="01XXXXXXXXX" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface placeholder:text-on-surface-variant/50 transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Postal code</span>
              <input name="shipPostalCode" value="{{ prefill.postalCode or '' }}" data-default="{{ prefill.postalCode or '' }}" autocomplete="postal-code" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block md:col-span-2">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Full name <span class="text-error">*</span></span>
              <input name="shipName" required value="{{ prefill.name or '' }}" data-default="{{ prefill.name or '' }}" autocomplete="name" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block md:col-span-2">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Address line 1 <span class="text-error">*</span></span>
              <input name="shipLine1" required value="{{ prefill.line1 or '' }}" data-default="{{ prefill.line1 or '' }}" autocomplete="address-line1" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block md:col-span-2">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Address line 2</span>
              <input name="shipLine2" value="{{ prefill.line2 or '' }}" data-default="{{ prefill.line2 or '' }}" autocomplete="address-line2" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">City <span class="text-error">*</span></span>
              <input name="shipCity" required value="{{ prefill.city or '' }}" data-default="{{ prefill.city or '' }}" autocomplete="address-level2" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
            <label class="block">
              <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">District</span>
              <input name="shipDistrict" value="{{ prefill.district or '' }}" data-default="{{ prefill.district or '' }}" autocomplete="address-level1" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md text-on-surface transition-colors focus:border-accent-deep focus:ring-0" />
            </label>
          </div>
        </div>
      </div>
      <input type="hidden" name="shipCountry" value="Bangladesh" />
    </div>

    <div>
      <div class="lg:sticky lg:top-28 rounded-2xl border border-outline/30 bg-surface-container-lowest p-7 shadow-luxe">
        <h2 class="font-headline-md text-xl text-on-surface">Order summary</h2>
        <div class="mt-5 space-y-3 text-sm">
          {% for item in cart.items %}
            <div class="flex justify-between gap-3">
              <span class="text-on-surface-variant">{{ item.productName }} <span class="text-on-surface-variant/60">× {{ item.quantity }}</span></span>
              <span class="shrink-0 text-on-surface">{{ item.lineTotal | money }}</span>
            </div>
          {% endfor %}
        </div>
        <label class="mt-5 block border-t border-outline/30 pt-5">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Coupon code</span>
          <input name="couponCode" placeholder="optional" class="mt-2 w-full rounded-lg border border-outline bg-surface-container-lowest px-4 py-3 text-body-md uppercase text-on-surface placeholder:text-on-surface-variant/50 transition-colors focus:border-accent-deep focus:ring-0" />
          <span class="mt-1.5 block text-xs text-on-surface-variant/70">Discount is applied when your order is placed.</span>
        </label>

        {# ── Payment method ──────────────────────────────────────────────── #}
        <div class="mt-5 border-t border-outline/30 pt-5">
          <span class="block font-label-sm text-label-sm uppercase tracking-[0.12em] text-on-surface-variant">Payment method</span>
          <div class="mt-3 space-y-3">
            <label class="flex cursor-pointer items-start gap-3 rounded-xl border p-4 transition-colors" :class="pay === 'cod' ? 'border-primary bg-primary/5' : 'border-outline/40 hover:border-outline'">
              <input type="radio" name="paymentMethod" value="cod" x-model="pay" checked class="mt-0.5 h-4 w-4" />
              <span class="min-w-0">
                <span class="block font-label-md text-label-md uppercase tracking-[0.1em] text-on-surface">Cash on Delivery</span>
                <span class="mt-1 block text-sm text-on-surface-variant">Pay in cash when your order arrives.</span>
              </span>
            </label>
            <label class="flex cursor-pointer items-start gap-3 rounded-xl border p-4 transition-colors" :class="pay === 'bkash' ? 'border-primary bg-primary/5' : 'border-outline/40 hover:border-outline'">
              <input type="radio" name="paymentMethod" value="bkash" x-model="pay" class="mt-0.5 h-4 w-4" />
              <span class="min-w-0">
                <span class="block font-label-md text-label-md uppercase tracking-[0.1em] text-on-surface">bKash</span>
                <span class="mt-1 block text-sm text-on-surface-variant">Pay securely online via bKash.</span>
              </span>
            </label>
          </div>
        </div>

        <div class="mt-5 flex items-baseline justify-between border-t border-outline/30 pt-5">
          <span class="font-label-md text-label-md uppercase tracking-[0.12em] text-on-surface">Total</span>
          <span class="font-display-lg text-2xl text-primary">{{ cart.subtotal | money }}</span>
        </div>
        <button type="submit" class="mt-6 flex w-full items-center justify-center gap-2.5 rounded-full bg-primary px-6 py-3.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">
          <span x-text="pay === 'cod' ? 'Confirm order — Cash on Delivery' : 'Place order and pay with bKash'">Place order</span>
        </button>
        <p class="mt-3 flex items-center justify-center gap-2 text-center text-xs text-on-surface-variant/70">
          <svg class="h-4 w-4 shrink-0 text-accent-deep" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 018 0v3" stroke-linecap="round"/></svg>
          <span x-text="pay === 'cod' ? 'You will pay in cash when your order is delivered.' : 'You will be redirected to bKash to pay securely.'">Secure checkout.</span>
        </p>
      </div>
    </div>
  </form>
</div>
{% endblock %}
