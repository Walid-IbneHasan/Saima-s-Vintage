{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-16 md:px-margin-desktop md:py-20">
  <nav class="mb-4 text-sm text-on-surface-variant">
    <a href="/" class="hover:text-primary">Home</a>
    {% if category.parent %} / <a href="/c/{{ category.parent.slug }}" class="hover:text-primary">{{ category.parent.name }}</a>{% endif %}
    / <span class="text-on-surface">{{ category.name }}</span>
  </nav>

  <h1 class="font-display-lg text-headline-lg text-on-surface">{{ category.name }}</h1>
  {% if category.description %}
    <p class="mt-3 max-w-2xl text-on-surface-variant">{{ category.description }}</p>
  {% endif %}

  {% if category.children.length %}
    <div class="mt-6 flex flex-wrap gap-2">
      {% for sub in category.children %}
        <a href="/c/{{ sub.slug }}" class="rounded-full border border-outline/30 px-4 py-1.5 text-sm text-on-surface transition-colors hover:border-primary hover:text-primary">{{ sub.name }}</a>
      {% endfor %}
    </div>
  {% endif %}

  <div class="mt-8">{% include "partials/product-filters.njk" %}</div>

  {% if products.length %}
    <div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
      {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
    </div>
    {% include "partials/pagination.njk" %}
  {% else %}
    <p class="mt-10 text-on-surface-variant">No products in this category yet.</p>
  {% endif %}
</div>
{% endblock %}
