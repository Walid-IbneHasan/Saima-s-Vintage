{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-16 md:px-margin-desktop md:py-24">
  <nav aria-label="Breadcrumb" class="text-sm text-on-surface-variant">
    <ol class="flex flex-wrap items-center gap-2">
      <li class="flex items-center gap-2">
        <a href="/" class="transition-colors hover:text-accent-deep">Home</a>
        <span aria-hidden="true" class="text-on-surface-variant/40">/</span>
      </li>
      {% if category.parent %}
        <li class="flex items-center gap-2">
          <a href="/c/{{ category.parent.slug }}" class="transition-colors hover:text-accent-deep">{{ category.parent.name }}</a>
          <span aria-hidden="true" class="text-on-surface-variant/40">/</span>
        </li>
      {% endif %}
      <li><span class="text-on-surface" aria-current="page">{{ category.name }}</span></li>
    </ol>
  </nav>

  <header class="mt-8 max-w-2xl" data-reveal>
    <p class="eyebrow text-accent-deep">The collection</p>
    <h1 class="mt-4 font-display-lg text-headline-lg text-on-surface text-balance">{{ category.name }}</h1>
    {% if category.description %}
      <p class="mt-4 text-body-lg text-on-surface-variant">{{ category.description }}</p>
    {% endif %}
  </header>

  {% if category.children.length %}
    <div class="mt-7 flex flex-wrap gap-2.5">
      {% for sub in category.children %}
        <a href="/c/{{ sub.slug }}" class="rounded-full border border-outline/30 bg-surface-container-lowest px-5 py-2 font-label-sm text-label-sm uppercase tracking-[0.1em] text-on-surface transition-colors duration-300 hover:border-accent hover:text-accent-deep">{{ sub.name }}</a>
      {% endfor %}
    </div>
  {% endif %}

  <hr class="hairline-gold mt-10" />

  <div class="mt-10 grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
    <aside class="lg:col-span-3">
      <div class="lg:sticky lg:top-28">{% include "partials/product-filters.njk" %}</div>
    </aside>

    <div class="lg:col-span-9">
      {% if products.length %}
        <div class="grid grid-cols-2 gap-6 md:grid-cols-3" data-reveal-stagger>
          {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
        </div>
        {% include "partials/pagination.njk" %}
      {% else %}
        <div class="grid place-items-center rounded-2xl border border-dashed border-outline/50 bg-surface-container-low/40 px-6 py-20 text-center">
          <svg class="h-10 w-10 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M4 7l8-4 8 4v6c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V7z" stroke-linejoin="round"/></svg>
          <h2 class="mt-5 font-headline-sm text-xl text-on-surface">Nothing here just yet</h2>
          <p class="mt-2 max-w-sm text-body-md text-on-surface-variant">No products in this category yet — new heritage finds are added often.</p>
          <a href="/products" class="mt-7 inline-flex items-center justify-center gap-2 rounded-full border border-outline px-6 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface transition-colors duration-300 hover:border-accent hover:text-accent-deep">
            Browse all pieces
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
