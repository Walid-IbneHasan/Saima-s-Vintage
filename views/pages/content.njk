{% extends "layouts/base.njk" %}

{% block content %}
<article class="mx-auto max-w-3xl px-4 py-12">
  <h1 class="font-serif text-3xl">{{ page.title }}</h1>
  {% if page.excerpt %}<p class="mt-2 text-stone-500">{{ page.excerpt }}</p>{% endif %}
  <div class="prose mt-6 max-w-none text-stone-700">{{ page.body | safe }}</div>
</article>
{% endblock %}
