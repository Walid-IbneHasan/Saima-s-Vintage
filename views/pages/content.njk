{% extends "layouts/base.njk" %}

{% block content %}
<article class="mx-auto max-w-3xl px-margin-mobile py-16 md:px-margin-desktop md:py-24" data-reveal>
  <header class="text-center">
    <p class="eyebrow text-accent-deep">Saima's Vintage</p>
    <h1 class="mt-5 font-display-lg text-display-sm leading-[1.1] text-on-surface text-balance md:text-headline-lg">{{ page.title }}</h1>
    {% if page.excerpt %}
      <p class="mx-auto mt-5 max-w-xl text-body-lg text-on-surface-variant">{{ page.excerpt }}</p>
    {% endif %}
  </header>

  <hr class="hairline-gold mx-auto mt-10 w-24" />

  <div class="prose prose-stone mt-10 max-w-none text-on-surface">{{ page.body | safe }}</div>
</article>
{% endblock %}
