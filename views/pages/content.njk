{% extends "layouts/base.njk" %}

{% block content %}
<article class="mx-auto max-w-3xl px-margin-mobile py-16 md:px-margin-desktop md:py-20">
  <h1 class="font-display-lg text-headline-lg text-on-surface">{{ page.title }}</h1>
  {% if page.excerpt %}<p class="mt-3 text-on-surface-variant">{{ page.excerpt }}</p>{% endif %}
  <div class="prose mt-8 max-w-none text-on-surface">{{ page.body | safe }}</div>
</article>
{% endblock %}
