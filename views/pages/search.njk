{% extends "layouts/base.njk" %}
{% from "partials/breadcrumbs.njk" import breadcrumbs %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-16 md:px-margin-desktop md:py-20">
  {{ breadcrumbs([{ name: 'Home', path: '/' }, { name: 'Search' }]) }}
  <form action="/search" method="get" class="mb-8 flex flex-col gap-3 sm:flex-row">
    <input type="search" name="q" value="{{ query }}" placeholder="Search vintage…"
           class="w-full rounded-full border border-outline/30 bg-surface px-5 py-3 text-body-md text-on-surface placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-0" />
    <button type="submit" class="inline-flex items-center justify-center rounded bg-primary px-8 py-3 font-label-md text-label-md uppercase tracking-widest text-on-primary transition-colors hover:bg-on-primary-fixed-variant">Search</button>
  </form>

  {% if query %}
    <p class="text-sm text-on-surface-variant">{{ meta.total }} result(s) for &ldquo;{{ query }}&rdquo;</p>
  {% endif %}

  {% if products.length %}
    <div class="mt-8 grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
      {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
    </div>
    {% include "partials/pagination.njk" %}
  {% elif query %}
    <p class="mt-10 text-on-surface-variant">No matches. Try a different term.</p>
  {% endif %}
</div>
{% endblock %}
