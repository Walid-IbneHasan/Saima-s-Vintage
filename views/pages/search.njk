{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-6xl px-4 py-10">
  <form action="/search" method="get" class="mb-8 flex gap-2">
    <input type="search" name="q" value="{{ query }}" placeholder="Search vintage…"
           class="w-full max-w-md rounded-full border border-stone-300 px-5 py-2.5 focus:border-amber-600 focus:outline-none" />
    <button type="submit" class="rounded-full bg-stone-900 px-6 py-2.5 text-sm text-white">Search</button>
  </form>

  {% if query %}
    <p class="text-sm text-stone-500">{{ meta.total }} result(s) for &ldquo;{{ query }}&rdquo;</p>
  {% endif %}

  {% if products.length %}
    <div class="mt-6 grid grid-cols-2 gap-6 md:grid-cols-4">
      {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
    </div>
    {% include "partials/pagination.njk" %}
  {% elif query %}
    <p class="mt-8 text-stone-500">No matches. Try a different term.</p>
  {% endif %}
</div>
{% endblock %}
