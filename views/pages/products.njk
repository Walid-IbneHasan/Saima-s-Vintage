{% extends "layouts/base.njk" %}

{% block content %}
<div class="mx-auto max-w-6xl px-4 py-10">
  <h1 class="font-serif text-3xl">Shop all</h1>
  <p class="mt-1 text-sm text-stone-500">{{ meta.total }} product{% if meta.total != 1 %}s{% endif %}</p>

  {% include "partials/product-filters.njk" %}

  {% if products.length %}
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
      {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
    </div>
    {% include "partials/pagination.njk" %}
  {% else %}
    <p class="mt-8 text-stone-500">No products match your filters. <a href="/products" class="text-amber-700 hover:underline">Clear filters</a>.</p>
  {% endif %}
</div>
{% endblock %}
