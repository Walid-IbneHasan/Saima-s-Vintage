{% extends "layouts/base.njk" %}
{% from "partials/breadcrumbs.njk" import breadcrumbs %}

{% block content %}
{# ── Collection masthead ──────────────────────────────────────────────── #}
<section class="relative overflow-hidden border-b border-outline/30 bg-surface-container-low/50">
  <div class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-accent/[0.08] blur-3xl"></div>
  <div class="relative mx-auto max-w-container-max px-margin-mobile py-12 md:px-margin-desktop md:py-16">
    {{ breadcrumbs([{ name: 'Home', path: '/' }, { name: 'Flash Deals' if filters.onSale else 'Shop all' }]) }}
    <div class="mt-6 max-w-2xl">
      {% if filters.onSale %}
        <p class="eyebrow inline-flex items-center gap-2 text-accent-deep">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M13 2L4.5 13.5H11l-1 8.5 8.5-11.5H12l1-8.5z" stroke-linejoin="round"/></svg>
          Limited time
        </p>
        <h1 class="mt-4 font-display-lg text-[2.5rem] leading-[1.04] text-on-surface md:text-display-lg">Flash Deals</h1>
        <p class="mt-4 text-body-lg text-on-surface-variant">
          One-of-a-kind heritage pieces at a limited-time price — restored Lippan &amp; Jharoka art and vintage treasures, reduced for a short while. When they're gone, they're gone.
        </p>
      {% else %}
        <p class="eyebrow text-accent-deep">The Collection</p>
        <h1 class="mt-4 font-display-lg text-[2.5rem] leading-[1.04] text-on-surface md:text-display-lg">Curated heritage pieces</h1>
        <p class="mt-4 text-body-lg text-on-surface-variant">
          {{ meta.total }} one-of-a-kind piece{% if meta.total != 1 %}s{% endif %} — handcrafted Lippan &amp; Jharoka art and restored vintage treasures, chosen to live beautifully in modern spaces.
        </p>
      {% endif %}
    </div>
  </div>
</section>

<div class="mx-auto max-w-container-max px-margin-mobile py-12 md:px-margin-desktop md:py-16">
  <div class="flex flex-col gap-10 lg:flex-row lg:gap-12">
    {# Filters — sticky sidebar on desktop, slide-in drawer on mobile #}
    <aside class="w-full shrink-0 lg:w-72">
      {% include "partials/filter-shell.njk" %}
    </aside>

    {# Product canvas — htmx swaps this in place when filters change (no reload). #}
    <section id="product-results" class="min-w-0 flex-grow">
      {% if products.length %}
        <div class="mb-8 flex items-center justify-between border-b border-outline/30 pb-4">
          <p class="font-label-sm text-label-sm uppercase tracking-[0.14em] text-on-surface-variant">
            Showing {{ products.length }} of {{ meta.total }}
          </p>
        </div>
        <div class="grid grid-cols-1 gap-x-7 gap-y-12 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
          {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
        </div>
        {% include "partials/pagination.njk" %}
      {% elif filters.onSale %}
        {# Flash Deals view with nothing currently on sale — dedicated empty state. #}
        <div class="grid place-items-center rounded-2xl border border-dashed border-accent/40 bg-accent/[0.06] px-6 py-24 text-center">
          <span class="grid h-16 w-16 place-items-center rounded-full border border-accent/30 bg-surface-container-lowest text-accent-deep shadow-luxe">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 11.5V4a1 1 0 011-1h7.5a1 1 0 01.7.3l8 8a1 1 0 010 1.4l-6.8 6.8a1 1 0 01-1.4 0l-8-8a1 1 0 01-.3-.7z" stroke-linejoin="round"/><circle cx="7.5" cy="7.5" r="1.4"/></svg>
          </span>
          <p class="eyebrow mt-6 text-accent-deep">No flash deals right now</p>
          <h2 class="mt-3 font-display-lg text-headline-md text-on-surface">Nothing's on sale at the moment</h2>
          <p class="mt-3 max-w-md text-body-md text-on-surface-variant">
            Our pieces are one-of-a-kind, so flash deals come and go quickly. Check back soon — or explore the full collection, where every piece is restored &amp; authenticated.
          </p>
          <a href="/products" class="mt-8 inline-flex items-center justify-center gap-2.5 rounded-full bg-primary px-8 py-3.5 font-label-md text-label-md uppercase tracking-[0.16em] text-on-primary shadow-luxe transition-colors duration-300 hover:bg-on-primary-fixed-variant">
            Explore the collection
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      {% else %}
        <div class="grid place-items-center rounded-2xl border border-dashed border-outline/50 bg-surface-container-low/40 py-24 text-center">
          <svg class="h-10 w-10 text-on-surface-variant/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3" stroke-linecap="round"/></svg>
          <p class="mt-4 text-body-md text-on-surface-variant">No pieces match your filters.</p>
          <a href="/products" class="mt-5 inline-flex items-center justify-center rounded-full border border-outline px-6 py-3 font-label-md text-label-md uppercase tracking-[0.16em] text-on-surface transition-colors hover:border-accent hover:text-accent-deep">Clear filters</a>
        </div>
      {% endif %}
    </section>
  </div>
</div>
{% endblock %}
