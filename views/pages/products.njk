{% extends "layouts/base.njk" %}
{% from "partials/breadcrumbs.njk" import breadcrumbs %}

{% block content %}
<div class="mx-auto max-w-container-max px-margin-mobile py-16 md:px-margin-desktop md:py-20">
  {{ breadcrumbs([{ name: 'Home', path: '/' }, { name: 'Shop all' }]) }}
  <h1 class="font-display-lg text-headline-lg text-on-surface">Shop all</h1>
  <p class="mt-2 text-on-surface-variant">{{ meta.total }} product{% if meta.total != 1 %}s{% endif %}</p>

  <div class="mt-8">{% include "partials/product-filters.njk" %}</div>

  {% if products.length %}
    <div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
      {% for p in products %}{% include "partials/product-card.njk" %}{% endfor %}
    </div>
    {% include "partials/pagination.njk" %}
  {% else %}
    <p class="mt-10 text-on-surface-variant">No products match your filters. <a href="/products" class="text-primary hover:underline">Clear filters</a>.</p>
  {% endif %}
</div>
{% endblock %}
