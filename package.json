{
  "name": "saimas-vintage",
  "version": "0.1.0",
  "description": "Saima's Vintage — server-rendered NestJS e-commerce with SSLCOMMERZ, for cPanel/Passenger hosting",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "npm run build:client && nest build",
    "build:server": "nest build",
    "build:client": "vite build",
    "dev": "nest start --watch",
    "dev:client": "vite build --watch",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.5.0",
    "alpinejs": "^3.14.8",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^3.0.4",
    "helmet": "^8.0.0",
    "htmx.org": "^2.0.4",
    "nodemailer": "^6.10.1",
    "nunjucks": "^3.2.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.17.0",
    "@types/nodemailer": "^6.4.24",
    "@types/nunjucks": "^3.2.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "playwright": "^1.61.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "^6.5.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
