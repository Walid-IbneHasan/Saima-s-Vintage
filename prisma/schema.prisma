// Saima's Vintage — Prisma schema (MySQL / MariaDB)
// Money is always Decimal(12,2). Stock lives on ProductVariant.stock and is
// only ever mutated under a SELECT ... FOR UPDATE transaction (see InventoryService).

generator client {
  provider = "prisma-client-js"
  // `native` is for local dev. The rhel-* targets are for CloudLinux (HostSeba).
  // VERIFY the server's OpenSSL with `openssl version` over SSH and keep only the
  // matching target(s) to keep the upload small.
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────── Enums ─────────────────────────────────

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAYMENT_REVIEW
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PENDING
  SESSION_CREATED
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
  PARTIALLY_REFUNDED
  PAYMENT_REVIEW
}

enum PaymentEventType {
  INIT
  SESSION_CREATED
  SUCCESS_REDIRECT
  FAIL_REDIRECT
  CANCEL_REDIRECT
  IPN
  VALIDATION
  REFUND
}

enum InventoryMovementType {
  MANUAL_ADJUSTMENT
  SALE
  RESERVATION
  RESERVATION_RELEASE
  RESERVATION_EXPIRY
  REFUND_RESTOCK
  CANCELLATION_RESTOCK
}

enum ReservationStatus {
  ACTIVE
  COMMITTED
  RELEASED
  EXPIRED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
  EXPIRED
}

enum CouponType {
  PERCENT
  FIXED
}

enum ShipmentStatus {
  PENDING
  PACKED
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// ─────────────────────────────── Identity ────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(191)
  passwordHash String
  name         String   @db.VarChar(191)
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AdminAuditLog[]

  @@index([role])
  @@index([isActive])
}

model Customer {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(191)
  passwordHash String? // null = guest checkout or Google-only account
  name         String    @db.VarChar(191)
  phone        String?   @db.VarChar(32)
  imageUrl     String? // avatar
  googleId     String?   @unique @db.VarChar(191)
  isActive     Boolean   @default(true)
  emailVerifiedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses   Address[]
  carts       Cart[]
  orders      Order[]
  reviews     Review[]
  wishlists   Wishlist[]
  redemptions CouponRedemption[]
  otps        CustomerOtp[]

  @@index([createdAt])
  @@index([isActive])
}

enum VerificationType {
  EMAIL_VERIFY
  PASSWORD_RESET
  PASSWORD_CHANGE
}

// One-time codes for email verification and password reset (code is hashed).
model CustomerOtp {
  id         String           @id @default(cuid())
  customerId String
  type       VerificationType
  codeHash   String
  expiresAt  DateTime
  attempts   Int              @default(0)
  consumedAt DateTime?
  createdAt  DateTime         @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, type])
  @@index([expiresAt])
}

model Address {
  id         String      @id @default(cuid())
  customerId String
  type       AddressType @default(SHIPPING)
  fullName   String      @db.VarChar(191)
  phone      String      @db.VarChar(32)
  line1      String
  line2      String?
  city       String      @db.VarChar(120)
  district   String?     @db.VarChar(120)
  postalCode String?     @db.VarChar(32)
  country    String      @default("Bangladesh") @db.VarChar(120)
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ──────────────────────────────── Catalog ────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(191)
  slug        String   @unique @db.VarChar(191)
  description String?  @db.Text
  imageUrl    String?
  parentId    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  seoTitle    String?  @db.VarChar(191)
  seoDescription String? @db.VarChar(300)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]        @relation("CategoryTree")
  products CategoryProduct[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

model Product {
  id               String   @id @default(cuid())
  name             String   @db.VarChar(191)
  slug             String   @unique @db.VarChar(191)
  sku              String?  @unique @db.VarChar(191)
  shortDescription String?  @db.VarChar(500)
  description      String?  @db.Text // rich text — sanitized on write
  brand            String?  @db.VarChar(191)
  condition        String?  @db.VarChar(64) // vintage condition: e.g. Excellent / Good / Fair
  basePrice        Decimal  @db.Decimal(12, 2) // regular price
  salePrice        Decimal? @db.Decimal(12, 2) // optional discounted price (when set & lower, this is charged)
  // Time-bound "Flash Deal": while now is within [flashStartAt, flashEndAt] and
  // flashPrice is set & lower than basePrice, flashPrice is charged and the item
  // shows under Flash Deals. After flashEndAt it automatically reverts (evaluated
  // at read/charge time — no background job required).
  flashPrice       Decimal?  @db.Decimal(12, 2)
  flashStartAt     DateTime? // null = active immediately once flashPrice is set
  flashEndAt       DateTime? // required for a flash deal; deal disappears after this
  currency         String   @default("BDT") @db.VarChar(8)
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  featuredOrder    Int      @default(0) // lower = earlier in the featured section
  allowBackorder   Boolean  @default(false)
  minPerOrder      Int      @default(1)
  maxPerOrder      Int?
  seoTitle         String?  @db.VarChar(191)
  seoDescription   String?  @db.VarChar(300)
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categories   CategoryProduct[]
  variants     ProductVariant[]
  images       ProductImage[]
  translations ProductTranslation[]
  reviews      Review[]
  wishlistItems WishlistItem[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([basePrice])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([flashEndAt])
  @@fulltext([name, shortDescription])
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  locale      String  @db.VarChar(10)
  name        String  @db.VarChar(191)
  slug        String  @db.VarChar(191)
  shortDescription String? @db.VarChar(500)
  description String? @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@unique([locale, slug])
  @@index([productId])
}

model CategoryProduct {
  productId  String
  categoryId String
  sortOrder  Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  sku               String   @unique @db.VarChar(191)
  name              String   @db.VarChar(191) // e.g. "Size M / Blue" or "Default"
  size              String?  @db.VarChar(64) // optional, e.g. "S", "M", "42"
  color             String?  @db.VarChar(64) // optional label or CSS colour/hex, e.g. "Blue", "#3366cc"
  price             Decimal? @db.Decimal(12, 2) // null → inherits Product.basePrice
  salePrice         Decimal? @db.Decimal(12, 2) // optional discounted price for this variant
  stock             Int      @default(0) // mutate ONLY under SELECT ... FOR UPDATE
  lowStockThreshold Int      @default(3)
  weightGrams       Int?
  barcode           String?  @db.VarChar(191)
  position          Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product            Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images             ProductImage[]
  attributeValues    ProductVariantAttributeValue[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  movements          InventoryMovement[]
  reservations       InventoryReservation[]
  lowStockNotices    LowStockNotification[]

  @@index([productId])
  @@index([isActive])
  @@index([stock])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  variantId String?
  url       String
  alt       String? @db.VarChar(191)
  width     Int?
  height    Int?
  position  Int     @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([position])
}

model ProductAttribute {
  id     String           @id @default(cuid())
  name   String           @db.VarChar(120) // "Size", "Color"
  slug   String           @unique @db.VarChar(120)
  values AttributeValue[]

  @@index([slug])
}

model AttributeValue {
  id          String @id @default(cuid())
  attributeId String
  value       String @db.VarChar(120) // "M", "Blue"
  slug        String @db.VarChar(120)

  attribute ProductAttribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants  ProductVariantAttributeValue[]

  @@unique([attributeId, slug])
  @@index([attributeId])
}

model ProductVariantAttributeValue {
  variantId        String
  attributeValueId String

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeValueId])
  @@index([attributeValueId])
}

// ─────────────────────────────── Inventory ───────────────────────────────

model InventoryMovement {
  id            String                @id @default(cuid())
  variantId     String
  type          InventoryMovementType
  quantity      Int // signed: negative = out, positive = in
  reason        String?               @db.VarChar(255)
  orderId       String?
  reservationId String?
  actorUserId   String? // admin who made a manual adjustment
  createdAt     DateTime              @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([type])
  @@index([orderId])
  @@index([createdAt])
}

model InventoryReservation {
  id        String            @id @default(cuid())
  variantId String
  orderId   String?
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([orderId])
  @@index([status])
  @@index([expiresAt])
}

model LowStockNotification {
  id            String    @id @default(cuid())
  variantId     String
  threshold     Int
  stockAtTrigger Int
  notifiedAt    DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([resolvedAt])
}

// ──────────────────────────────── Commerce ───────────────────────────────

model Cart {
  id           String     @id @default(cuid())
  customerId   String?
  sessionToken String?    @unique @db.VarChar(191) // guest carts
  status       CartStatus @default(ACTIVE)
  currency     String     @default("BDT") @db.VarChar(8)
  expiresAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    CartItem[]

  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
}

model CartItem {
  id                String   @id @default(cuid())
  cartId            String
  variantId         String
  quantity          Int
  unitPriceSnapshot Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique @db.VarChar(32)
  customerId     String?
  email          String      @db.VarChar(191)
  phone          String?     @db.VarChar(32)
  status         OrderStatus @default(AWAITING_PAYMENT)
  currency       String      @default("BDT") @db.VarChar(8)
  subtotal       Decimal     @db.Decimal(12, 2)
  discountTotal  Decimal     @default(0) @db.Decimal(12, 2)
  shippingTotal  Decimal     @default(0) @db.Decimal(12, 2)
  taxTotal       Decimal     @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal     @db.Decimal(12, 2)
  couponId       String?
  couponCode     String?     @db.VarChar(64)
  idempotencyKey String      @unique @db.VarChar(191)

  // shipping snapshot (immutable copy)
  shipName       String  @db.VarChar(191)
  shipPhone      String  @db.VarChar(32)
  shipLine1      String
  shipLine2      String?
  shipCity       String  @db.VarChar(120)
  shipDistrict   String? @db.VarChar(120)
  shipPostalCode String? @db.VarChar(32)
  shipCountry    String  @default("Bangladesh") @db.VarChar(120)

  notes     String?  @db.Text
  placedAt  DateTime @default(now())
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer     Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  coupon       Coupon?                @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  payments     Payment[]
  paymentEvents PaymentEvent[]
  reservations InventoryReservation[]
  shipments    Shipment[]
  redemptions  CouponRedemption[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([paidAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  variantId   String? // SetNull on variant delete; snapshot fields preserve history
  productName String   @db.VarChar(191)
  variantName String   @db.VarChar(191)
  sku         String   @db.VarChar(191)
  unitPrice   Decimal  @db.Decimal(12, 2)
  quantity    Int
  lineTotal   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
}

model Coupon {
  id                   String     @id @default(cuid())
  code                 String     @unique @db.VarChar(64)
  type                 CouponType
  value                Decimal    @db.Decimal(12, 2)
  minSubtotal          Decimal?   @db.Decimal(12, 2)
  maxDiscount          Decimal?   @db.Decimal(12, 2)
  usageLimit           Int? // global cap
  usageLimitPerCustomer Int?
  usedCount            Int        @default(0)
  startsAt             DateTime?
  expiresAt            DateTime?
  isActive             Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  orders      Order[]
  redemptions CouponRedemption[]

  @@index([isActive])
  @@index([expiresAt])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  orderId    String
  customerId String?
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  coupon   Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([couponId, orderId])
  @@index([couponId])
  @@index([customerId])
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  status         ShipmentStatus @default(PENDING)
  carrier        String?        @db.VarChar(120)
  trackingNumber String?        @db.VarChar(191)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([trackingNumber])
}

// ──────────────────────────────── Payments ───────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  provider        String        @default("bkash") @db.VarChar(32)
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("BDT") @db.VarChar(8)
  // Our own reference, sent to bKash as merchantInvoiceNumber.
  tranId          String        @unique @db.VarChar(191)
  // bKash's paymentID (returned by Create Payment). The redirect callback only
  // echoes this, so it is how we correlate the callback back to this row.
  bkashPaymentID  String?       @unique @db.VarChar(191)
  // bKash's customer-facing transaction id (returned by Execute) and the masked
  // payer wallet number — both set once the payment is confirmed.
  bkashTrxID      String?       @db.VarChar(191)
  payerAccount    String?       @db.VarChar(32)
  // Holds bKash's hosted-checkout `bkashURL` (the redirect target).
  gatewayPageURL  String?       @db.Text
  // When Execute/Query confirmed the charge.
  validatedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order  Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events PaymentEvent[]

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model PaymentEvent {
  id            String           @id @default(cuid())
  paymentId     String?
  orderId       String?
  tranId        String?          @db.VarChar(191)
  type          PaymentEventType
  payload       Json // raw gateway response — NEVER contains card data
  signatureValid Boolean?
  processed     Boolean          @default(false)
  createdAt     DateTime         @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  order   Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([orderId])
  @@index([tranId])
  @@index([type])
  @@index([createdAt])
}

// ─────────────────────────────── Engagement ──────────────────────────────

model Review {
  id          String   @id @default(cuid())
  productId   String
  customerId  String?
  authorName  String   @db.VarChar(191)
  rating      Int // 1..5
  title       String?  @db.VarChar(191)
  body        String   @db.Text
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // One review per customer per product (multiple NULL customerIds allowed in MySQL).
  @@unique([productId, customerId])
  @@index([productId])
  @@index([isApproved])
  @@index([rating])
}

model Wishlist {
  id         String         @id @default(cuid())
  customerId String
  createdAt  DateTime       @default(now())

  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    WishlistItem[]

  @@index([customerId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
  @@index([wishlistId])
  @@index([productId])
}

// ──────────────────────────────── Ops / SEO ──────────────────────────────

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   @db.VarChar(120) // e.g. "product.update"
  entityType String   @db.VarChar(120)
  entityId   String?  @db.VarChar(191)
  before     Json?
  after      Json?
  ip         String?  @db.VarChar(64)
  userAgent  String?  @db.VarChar(255)
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model PageContent {
  id          String        @id @default(cuid())
  type        String        @default("page") @db.VarChar(32) // "page" | "blog"
  title       String        @db.VarChar(191)
  slug        String        @unique @db.VarChar(191)
  excerpt     String?       @db.VarChar(500)
  body        String        @db.LongText
  coverImage  String?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  seoTitle    String?       @db.VarChar(191)
  seoDescription String?    @db.VarChar(300)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type])
  @@index([status])
  @@index([publishedAt])
}

model SeoMeta {
  id         String  @id @default(cuid())
  entityType String  @db.VarChar(64) // "product" | "category" | "page" | "route"
  entityId   String? @db.VarChar(191)
  path       String? @unique @db.VarChar(191)
  title      String? @db.VarChar(191)
  description String? @db.VarChar(300)
  ogImage    String?
  canonical  String?
  robots     String? @db.VarChar(64)
  jsonLd     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityType, entityId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(191)
  value     Json
  updatedAt DateTime @updatedAt
}

// 301/302 redirects — populated when a product/category slug changes.
model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique @db.VarChar(191)
  toPath     String   @db.VarChar(191)
  statusCode Int      @default(301)
  createdAt  DateTime @default(now())
}

// Database-backed job queue, drained by cPanel cron (no Redis/worker assumed).
model Job {
  id          String    @id @default(cuid())
  type        String    @db.VarChar(120)
  payload     Json
  status      JobStatus @default(PENDING)
  runAt       DateTime  @default(now())
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  lastError   String?   @db.Text
  lockedAt    DateTime?
  lockedBy    String?   @db.VarChar(191)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@index([type])
}
