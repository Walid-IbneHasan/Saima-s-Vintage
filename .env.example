# ───────────────────────────────────────────────────────────────────
# Saima's Vintage — environment template.
# Copy to `.env` and fill real values. NEVER commit `.env`.
# On cPanel, set these in the Node.js App "Environment variables" panel.
# ───────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
# Passenger/cPanel injects PORT. Locally we fall back to 3000.
PORT=3000
APP_NAME="Saima's Vintage"
APP_URL=https://saimasvintage.com
# Comma-separated trusted proxy hops (LiteSpeed/Passenger sits in front in prod).
TRUST_PROXY=1

# Secrets (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-64-hex-chars
COOKIE_SECRET=replace-with-64-hex-chars
CSRF_SECRET=replace-with-64-hex-chars
# Token the cPanel cron jobs must send in the X-Cron-Token header.
CRON_TOKEN=replace-with-a-long-random-token
JWT_SECRET=replace-with-64-hex-chars

# Google OAuth (optional). Create credentials at console.cloud.google.com and
# register the redirect URI https://saimasvintage.com/auth/google/callback.
# GOOGLE_CALLBACK_URL can be left blank — it auto-derives from APP_URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Database (MySQL / MariaDB on cPanel)
DATABASE_URL="mysql://dbuser:dbpassword@localhost:3306/saimas_vintage"

# bKash PGW Tokenized Checkout. Get these from your bKash merchant account
# (Merchant Panel → API keys). Keep app_secret/password strictly server-side.
# For development, bKash provides shared sandbox credentials.
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
# false = sandbox (tokenized.sandbox.bka.sh), true = production (tokenized.pay.bka.sh)
BKASH_IS_LIVE=false
BKASH_CALLBACK_URL=https://saimasvintage.com/payments/bkash/callback

# Money
DEFAULT_CURRENCY=BDT

# Email (Nodemailer SMTP) — added in Phase 5
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Saima's Vintage <no-reply@example.com>"

# Inventory
RESERVATION_TTL_MINUTES=30
LOW_STOCK_DEFAULT_THRESHOLD=3
